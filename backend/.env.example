# =====================================================
# AUMAF 3D — Backend env vars
# Copie para .env e preencha. NUNCA commite o .env real.
# =====================================================

# --- Core ---
DATABASE_URL="postgresql://aumaf:aumaf123@localhost:5432/aumaf_dev?schema=public"
PORT=3000
NODE_ENV=development

# --- Auth ---
# Gere com: openssl rand -hex 32
JWT_SECRET=change-this-in-production-minimum-32-chars-aumaf
JWT_EXPIRES_IN=7d

# Admin único do backoffice (criado no seed)
ADMIN_EMAIL=admin@aumaf.com.br
ADMIN_PASSWORD=AumafAdmin2026!
ADMIN_NAME="Admin AUMAF"

# --- CORS ---
FRONTEND_ADMIN_URL=http://localhost:5174
FRONTEND_PUBLIC_URL=http://localhost:4321
BACKEND_URL=http://localhost:3000

# --- Storage (MinIO em dev, S3 em prod) ---
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=aumaf-blog-images

# --- Redis (Phase 2) ---
REDIS_URL=redis://localhost:6379

# --- Observabilidade ---
SENTRY_DSN=
LOG_FORMAT=text

# --- IA (multi-provedor) ---
# Provedor padrão quando o request não especifica
AI_PROVIDER=anthropic

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# --- Botyio — WhatsApp lead integration ---
# Obtenha as credenciais no painel: https://app.botyio.com/lead-capture/sources
#
# Estes valores são lidos APENAS NO PRIMEIRO BOOT.
# Após bootstrap, vivem criptografados em `integration_secrets` (AES-256-GCM)
# e são editáveis via /admin/integrations/botyio. Envs viram fallback.
BOTYIO_BASE_URL=https://api.botyio.com
BOTYIO_API_KEY=bty_lds_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOTYIO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOTYIO_ENABLED=false

# --- Integration secrets — encryption at rest ---
# Master key (32 bytes) para AES-256-GCM. Em produção:
#   openssl rand -out /etc/aumaf/master.key 32
#   chmod 400 /etc/aumaf/master.key && chown deploy:deploy ...
# Backend RECUSA subir em produção sem este arquivo.
MASTER_KEY_PATH=/etc/aumaf/master.key
# Apenas DEV/TEST: fallback se MASTER_KEY_PATH ausente. Gere com: openssl rand -base64 32
# MASTER_ENCRYPTION_KEY=

# --- Email / Lead notifications ---
# Email enviado ao admin quando um novo lead chega via formulário público.
# Deixe ADMIN_NOTIFICATION_EMAIL vazio para desativar notificação.
ADMIN_NOTIFICATION_EMAIL=
EMAIL_FROM=AUMAF 3D <noreply@aumaf-3d.com.br>
# console (loga payload completo, ideal em dev) | smtp (prod com SMTP) | stub (loga warn)
EMAIL_TRANSPORT=console
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_SECURE=false

# --- Cache warm-up ---
# Base URL pública usada pelos workers de warm-up. Default: FRONTEND_PUBLIC_URL
PUBLIC_BLOG_BASE_URL=

# --- Analytics próprio (docs/runbooks/analytics.md) ---
# Liga/desliga o ingest. Eventos em /collect retornam 202 mesmo quando false (no-op).
ANALYTICS_ENABLED=true
# Salt para hash sha256 do IP — TROCAR EM PRODUÇÃO (32+ chars aleatórios).
# Trocar invalida a correlação histórica de IP-hash (por design).
ANALYTICS_IP_SALT=aumaf-analytics-default-salt-change-me
# Opcional: caminho para MaxMind GeoLite2-Country.mmdb (geo-IP offline). Sem isto, country=null.
# ANALYTICS_GEOIP_DB_PATH=/srv/aumaf/data/GeoLite2-Country.mmdb

# IndexNow — push de URLs publicadas para Bing/Yandex/Seznam/Naver.
# Gerar com `openssl rand -hex 16`. Mesma chave deve ir em PUBLIC_INDEXNOW_KEY
# do frontend-public (expõe /<KEY>.txt para verificação de propriedade).
# INDEXNOW_KEY=
# Host canônico (sem protocolo). Default: derivado de PUBLIC_BLOG_BASE_URL.
# INDEXNOW_HOST=aumaf.kayoridolfi.ai

# AVISO: este Caddyfile é REFERÊNCIA — em produção a VPS roda Caddy 2.11.2
# nativo (Hostinger Ubuntu 22.04) que NÃO inclui módulo brotli (zstd está
# no core 2.8+). Antes de aplicar este arquivo na VPS, instale brotli via
# xcaddy ou substitua `encode zstd br gzip` por `encode gzip` em cada vhost.
# Ver memory/reference_caddy_vps.md (procedimento canônico de mudança).

{
	email kayocdi@gmail.com
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}

	log {
		output file /var/log/caddy/caddy.log {
			roll_size 50mb
			roll_keep 10
			roll_keep_for 720h
		}
		format json
		level INFO
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
		-Server
	}
}

aumaf.kayoridolfi.ai {
	import security_headers
	encode zstd br gzip

	# Same-origin proxy para o backend — viabiliza o SDK de analytics
	# (POST /api/v1/analytics/collect e /collect/beacon) sem CORS/preflight.
	@api path /api/*
	reverse_proxy @api 127.0.0.1:3000

	@hashed_assets path_regexp hashed ^/_astro/.+\.[a-f0-9]{8,}\..+$
	header @hashed_assets Cache-Control "public, max-age=31536000, immutable"

	# Cache longo + immutable para mídia estática (webp/avif/mp4/woff2 não mudam de URL)
	@static_media path_regexp static_media ^/(images|videos|fonts|assets)/.+\.(webp|avif|png|jpg|jpeg|svg|mp4|webm|woff2|woff|ico)$
	header @static_media Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"

	# Endpoints públicos de leitura — cache curto compartilhado, SWR generoso
	@public_api path /api/v1/posts/public* /api/v1/portfolio/public* /api/v1/settings/public
	header @public_api Cache-Control "public, max-age=60, s-maxage=300, stale-while-revalidate=86400"

	# Robots/sitemap/llms — cache de 1h (raramente mudam)
	@robots_seo path /robots.txt /sitemap*.xml /llms.txt /llms-full.txt
	header @robots_seo Cache-Control "public, max-age=3600"

	reverse_proxy 127.0.0.1:4321 {
		health_uri /
		health_interval 30s
		health_timeout 5s
	}

	log {
		output file /var/log/caddy/aumaf-public.log {
			roll_size 50mb
			roll_keep 5
		}
	}
}

admin-aumaf.kayoridolfi.ai {
	import security_headers
	encode zstd br gzip

	@hashed_assets path_regexp hashed ^/assets/.+\.[a-f0-9]{8,}\..+$
	header @hashed_assets Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy 127.0.0.1:5174 {
		health_uri /
		health_interval 60s
		health_timeout 5s
	}

	log {
		output file /var/log/caddy/aumaf-admin.log {
			roll_size 50mb
			roll_keep 5
		}
	}
}

api-aumaf.kayoridolfi.ai {
	import security_headers
	encode zstd br gzip

	reverse_proxy 127.0.0.1:3000 {
		health_uri /health
		health_interval 15s
		health_timeout 5s
		transport http {
			keepalive 60s
			keepalive_idle_conns 16
		}
	}

	log {
		output file /var/log/caddy/aumaf-api.log {
			roll_size 50mb
			roll_keep 5
		}
	}
}

# AUMAF 3D — .env.production.example
# Copie para /srv/aumaf/env/.env.production no servidor (chmod 600 owner=deploy).
# NUNCA versione valores reais.

# ─── Application URLs (homologação em subdominio kayoridolfi.ai) ─────────────
PUBLIC_BASE_URL=https://aumaf.kayoridolfi.ai
ADMIN_BASE_URL=https://admin-aumaf.kayoridolfi.ai
API_BASE_URL=https://api-aumaf.kayoridolfi.ai
PUBLIC_API_URL=https://api-aumaf.kayoridolfi.ai/api/v1

# ─── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=aumaf
POSTGRES_PASSWORD=<gerar 40 chars alfanumericos>
POSTGRES_DB=aumaf_prod
DATABASE_URL=postgresql://aumaf:<senha>@postgres:5432/aumaf_prod?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=aumaf-admin
MINIO_ROOT_PASSWORD=<gerar 40 chars>
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://api-aumaf.kayoridolfi.ai/media
MINIO_BUCKET=aumaf-media
MINIO_ACCESS_KEY=aumaf-admin
MINIO_SECRET_KEY=<igual MINIO_ROOT_PASSWORD>
MINIO_USE_SSL=false

# ─── Auth / Cookies ──────────────────────────────────────────────────────────
JWT_SECRET=<gerar 64 chars>
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=admin-aumaf.kayoridolfi.ai
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://aumaf.kayoridolfi.ai,https://admin-aumaf.kayoridolfi.ai

# ─── AI providers (configurados na Q2) ───────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENAI_API_KEY=
AI_DEFAULT_PROVIDER=anthropic

# ─── Email — sem SMTP por enquanto (Q-4 fechada: WhatsApp via Botyio futuro) ──
EMAIL_TRANSPORT=stub
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=

# ─── Sentry (preencher em F5) ────────────────────────────────────────────────
SENTRY_DSN_BACKEND=
SENTRY_DSN_PUBLIC=
SENTRY_DSN_ADMIN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Botyio (preencher quando ativar — fora desta spec) ──────────────────────
BOTYIO_API_KEY=
BOTYIO_WEBHOOK_SECRET=

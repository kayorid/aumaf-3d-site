---
export const prerender = true
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { itemListSchema } from '../lib/schemas'

const projects = [
  { slug: 'port-01-suporte-robo',         cat: 'Prototipagem',     title: 'Suporte para Robô Industrial',          mat: 'PA CF15',                 accent: true  },
  { slug: 'port-02-flange-316l',          cat: 'Metal',            title: 'Flange em Aço Inox 316L',               mat: 'BASF Ultrafuse 316L',     accent: false },
  { slug: 'port-03-encaixe-sae',          cat: 'Prototipagem',     title: 'Encaixe para Fórmula SAE USP',          mat: 'Nylon PA',                accent: false },
  { slug: 'port-04-garra-pneumatica',     cat: 'Peças Funcionais', title: 'Garra Pneumática para Automação',       mat: 'PC + TPU',                accent: true  },
  { slug: 'port-05-maquete-residencial',  cat: 'Maquetes',         title: 'Maquete Arquitetônica Residencial',     mat: 'PLA / Resina',            accent: false },
  { slug: 'port-06-conector-aeronautico', cat: 'Metal',            title: 'Conector Estrutural Aeronáutico',       mat: 'Ultrafuse 316L',          accent: false },
  { slug: 'port-07-empacotadora',         cat: 'Peças Funcionais', title: 'Peça de Reposição para Empacotadora',   mat: 'ABS Industrial',          accent: false },
  { slug: 'port-08-caixa-eletronica',     cat: 'Prototipagem',     title: 'Caixa de Eletrônica com Tampa',         mat: 'PETG CF15',               accent: false },
  { slug: 'port-09-painel-resina',        cat: 'Resina',           title: 'Painel de Controle em Resina ABS',      mat: 'Resina ABS',              accent: false },
  { slug: 'port-10-bucha-eixo',           cat: 'Peças Funcionais', title: 'Bucha de Eixo com Rosca Interna',       mat: 'Nylon + Fibra',           accent: true  },
  { slug: 'port-11-prototipo-pitch',      cat: 'Maquetes',         title: 'Protótipo de Produto para Pitch',       mat: 'PLA + Pintura',           accent: false },
  { slug: 'port-12-implante-medico',      cat: 'Resina',           title: 'Implante Educacional Médico',           mat: 'Resina Cerâmica',         accent: false },
]

const cats = ['Todos', 'Prototipagem', 'Peças Funcionais', 'Metal', 'Resina', 'Maquetes']

const description = 'Portfolio AUMAF 3D com +500 projetos entregues: peças funcionais, protótipos, peças em metal 316L, resina e maquetes arquitetônicas. Casos reais de impressão 3D industrial em São Carlos – SP.'

const schemas = [
  itemListSchema(projects.map((p) => ({ name: p.title, description: `Material: ${p.mat}. Categoria: ${p.cat}.` }))),
]
---

<Base
  title="Portfolio — Projetos de Impressão 3D"
  description={description}
  pageType="CollectionPage"
  breadcrumb={[{ name: 'Portfolio', url: '/portfolio' }]}
  schemas={schemas}
>
  <Navbar currentPath="/portfolio" />

  <!-- Hero minimalista -->
  <section class="bg-background pt-28 pb-16 relative overflow-hidden" aria-labelledby="hero-portfolio">
    <div class="absolute inset-0 bg-tech-grid opacity-25 pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <Breadcrumb items={[{ name: 'Portfolio' }]} compact />
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-4">Projetos // Realizações</span>
          <h1 id="hero-portfolio" class="text-display-xl font-bold uppercase text-white tracking-[-0.04em] leading-none">Portfolio.</h1>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[clamp(36px,5vw,56px)] font-black text-primary-container leading-none tracking-tighter">+500</span>
          <span class="text-body-md text-tertiary leading-tight max-w-[120px]">projetos<br/>entregues</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Filters -->
  <div
    id="portfolio-filter"
    class="bg-background/95 border-b border-white/8 sticky top-16 z-40 w-full"
    style="backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);"
  >
    <div class="max-w-[1600px] mx-auto px-edge py-3">
      <div class="flex flex-wrap items-center gap-2 mb-2" role="radiogroup" aria-label="Filtrar projetos por categoria">
        {cats.map((cat, i) => (
          <button
            type="button"
            role="radio"
            aria-checked={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? '0' : '-1'}
            data-filter={cat === 'Todos' ? 'all' : cat}
            class:list={[
              'filter-pill transition-all duration-200 inline-flex items-center px-4 py-1.5 rounded-full border text-label-caps uppercase tracking-widest whitespace-nowrap text-[10px]',
              i === 0
                ? 'bg-primary-container border-primary-container text-on-primary glow-effect'
                : 'border-white/30 text-on-surface-variant hover:border-primary-container hover:text-primary-container',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>
      <p id="portfolio-count" aria-live="polite" class="text-code-data text-on-surface-variant text-[11px]">
        Exibindo {projects.length} de +500 projetos
      </p>
    </div>
  </div>

  <!-- Grid -->
  <section class="bg-background py-section" aria-labelledby="portfolio-list">
    <h2 id="portfolio-list" class="sr-only">Lista de projetos</h2>
    <div class="max-w-[1600px] mx-auto px-edge">
      <ul role="list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter" id="portfolio-grid">
        {projects.map((p, i) => (
          <li>
            <article
              data-cat={p.cat}
              class="group relative overflow-hidden rounded-sm cursor-pointer h-full"
              aria-label={`${p.title} — ${p.cat} em ${p.mat}`}
            >
              <div class:list={[
                'relative overflow-hidden aspect-[4/3]',
                p.accent ? 'bg-gradient-to-br from-primary-container/15 to-surface-base' : 'bg-gradient-to-br from-surface-base to-surface-dim',
              ]}>
                <img
                  src={`/images/${p.slug}.webp`}
                  alt={`${p.title} — peça impressa em ${p.mat}`}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                  width="1376"
                  height="1032"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
                <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style={`background:radial-gradient(circle at ${30 + i * 7}% ${40 + i * 3}%, rgba(97,197,79,0.06) 0%, transparent 60%),linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.45) 100%);`}></div>

                <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400">
                  <div class="absolute bottom-0 left-0 right-0 p-6">
                    <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/60 text-primary-container text-label-caps uppercase tracking-widest mb-3 block w-fit">{p.cat}</span>
                    <h3 class="text-body-lg font-bold text-white uppercase tracking-[0.01em] mb-2">{p.title}</h3>
                    <p class="text-code-data text-tertiary">Material: {p.mat}</p>
                  </div>
                </div>

                <div class="absolute top-4 left-4">
                  <span class="pill text-[10px]">{p.cat}</span>
                </div>
              </div>

              <div class="py-4">
                <h3 class="text-body-md font-medium text-on-surface group-hover:text-white transition-colors mb-1">{p.title}</h3>
                <p class="text-code-data text-tertiary">{p.mat}</p>
              </div>
            </article>
          </li>
        ))}
      </ul>

      <!-- Empty state -->
      <div id="empty-state" hidden class="mt-12 text-center glass-panel rounded-sm p-12 border border-white/10">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-4 inline-block" aria-hidden="true">search_off</span>
        <p class="text-body-lg text-on-surface mb-2">Nenhum projeto encontrado nesta categoria</p>
        <p class="text-body-md text-tertiary mb-6">Tem um projeto diferente em mente? Solicite uma peça customizada.</p>
        <a href="/contato" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300">
          Solicitar peça customizada
          <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
        </a>
      </div>

      <!-- Load more hint -->
      <div class="mt-16 text-center">
        <a href="/contato" class="inline-flex items-center gap-2 border border-white/30 text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm hover:border-primary-container hover:text-primary-container transition-all duration-300">
          Solicitar orçamento do seu projeto
          <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('#portfolio-filter [role="radio"]'))
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-cat]'))
  const counter = document.getElementById('portfolio-count')
  const emptyState = document.getElementById('empty-state')

  const ACTIVE = 'bg-primary-container border-primary-container text-on-primary glow-effect'
  const INACTIVE = 'border-white/30 text-on-surface-variant hover:border-primary-container hover:text-primary-container'

  function setFilter(btn: HTMLButtonElement) {
    const filter = btn.dataset.filter ?? 'all'

    filterBtns.forEach((b) => {
      const active = b === btn
      b.setAttribute('aria-checked', active ? 'true' : 'false')
      b.tabIndex = active ? 0 : -1
      ACTIVE.split(' ').forEach((c) => b.classList.toggle(c, active))
      INACTIVE.split(' ').forEach((c) => b.classList.toggle(c, !active))
    })

    let visible = 0
    cards.forEach((card) => {
      const show = filter === 'all' || card.dataset.cat === filter
      if (show) {
        const li = card.parentElement!
        li.style.display = ''
        card.style.opacity = '0'
        requestAnimationFrame(() => {
          card.style.transition = 'opacity 0.3s ease'
          card.style.opacity = '1'
        })
        visible++
      } else {
        const li = card.parentElement!
        card.style.opacity = '0'
        card.style.transition = 'opacity 0.2s ease'
        setTimeout(() => { li.style.display = 'none' }, 200)
      }
    })

    if (counter) {
      counter.textContent = filter === 'all'
        ? `Exibindo ${visible} de +500 projetos`
        : `Exibindo ${visible} projeto${visible === 1 ? '' : 's'} em ${filter}`
    }
    if (emptyState) {
      if (visible === 0) emptyState.removeAttribute('hidden')
      else emptyState.setAttribute('hidden', '')
    }
  }

  filterBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => { setFilter(btn); btn.focus() })
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault()
        const next = filterBtns[(i + 1) % filterBtns.length]
        setFilter(next)
        next.focus()
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault()
        const prev = filterBtns[(i - 1 + filterBtns.length) % filterBtns.length]
        setFilter(prev)
        prev.focus()
      }
    })
  })
</script>

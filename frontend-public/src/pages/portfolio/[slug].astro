---
export const prerender = true
import Base from '../../layouts/Base.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import { COMPANY } from '../../lib/company'
import {
  portfolioProjects,
  getPortfolioProject,
  getPortfolioSiblings,
} from '../../data/portfolio'

export async function getStaticPaths() {
  return portfolioProjects.map((p) => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params
const project = getPortfolioProject(slug as string)
if (!project) {
  return Astro.redirect('/portfolio')
}

const { prev, next } = getPortfolioSiblings(project.slug)

const description = project.excerpt
const title = `${project.title} — Portfolio AUMAF 3D`

const heroImage = project.gallery[0]?.src ?? `/images/${project.slug}.webp`

const creativeWorkSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.title,
  description: project.excerpt,
  about: project.industry,
  material: project.mat,
  creator: { '@type': 'Organization', name: COMPANY.name, url: COMPANY.url },
  image: `${COMPANY.url}${heroImage}`,
  url: `${COMPANY.url}/portfolio/${project.slug}`,
  keywords: project.tags.join(', '),
}
---

<Base
  title={title}
  description={description}
  pageType="WebPage"
  breadcrumb={[
    { name: 'Portfolio', url: '/portfolio' },
    { name: project.title, url: `/portfolio/${project.slug}` },
  ]}
  schemas={[creativeWorkSchema]}
>
  <Navbar currentPath="/portfolio" />

  <!-- Hero — capa grande -->
  <section class="bg-background pt-24 pb-12 relative overflow-hidden" aria-labelledby="port-title">
    <div class="absolute inset-0 bg-tech-grid opacity-[0.18] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 60% 45% at 92% 8%,rgba(97,197,79,0.08) 0%,transparent 65%),radial-gradient(ellipse 50% 35% at 8% 92%,rgba(97,197,79,0.05) 0%,transparent 65%);"></div>

    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <Breadcrumb items={[{ name: 'Portfolio', url: '/portfolio' }, { name: project.title }]} compact />

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-end mt-6">
        <div class="lg:col-span-7">
          <div class="flex items-center gap-3 mb-5 flex-wrap">
            <span class="pill pill-green text-[10px]">{project.cat}</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] text-[10px]">{project.process}</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] text-[10px]">·</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] text-[10px]">{project.industry}</span>
          </div>
          <h1 id="port-title" class="text-display-xl font-bold uppercase text-white tracking-[-0.04em] leading-[0.95] mb-5">
            {project.title}
          </h1>
          <p class="text-body-lg text-tertiary leading-relaxed max-w-2xl">{project.excerpt}</p>

          <div class="flex flex-wrap gap-2 mt-7">
            {project.tags.map((t) => (
              <span class="inline-flex items-center px-2.5 py-1 rounded-full border border-white/12 text-on-surface-variant text-[10px] uppercase tracking-widest">{t}</span>
            ))}
          </div>
        </div>

        <aside class="lg:col-span-5 lg:pl-6 lg:border-l lg:border-white/8">
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-3 text-[10px]">Material principal</span>
          <p class="text-headline-md font-bold text-white tracking-[-0.01em] leading-tight mb-2">{project.mat}</p>
          <p class="text-body-md text-tertiary leading-relaxed">{project.delivery}</p>
        </aside>
      </div>
    </div>
  </section>

  <!-- Imagem hero grande -->
  <section class="bg-surface-low relative overflow-hidden" aria-label="Imagem principal do projeto">
    <div class="max-w-[1600px] mx-auto px-edge py-12 relative z-10">
      <div class="relative aspect-[16/9] rounded-sm overflow-hidden bg-surface-base border border-white/8" style="box-shadow:0 30px 80px rgba(0,0,0,0.55);">
        <img
          src={heroImage}
          alt={`${project.title} — vista principal`}
          class="absolute inset-0 w-full h-full object-cover"
          width="1600"
          height="900"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(circle at 50% 50%,rgba(97,197,79,0.06) 0%,transparent 70%),linear-gradient(180deg,rgba(0,0,0,0.10) 0%,rgba(0,0,0,0.45) 100%);"></div>
        <div class="absolute top-3 left-3 w-4 h-4 border-t border-l border-primary-container/40" aria-hidden="true"></div>
        <div class="absolute top-3 right-3 w-4 h-4 border-t border-r border-primary-container/40" aria-hidden="true"></div>
        <div class="absolute bottom-3 left-3 w-4 h-4 border-b border-l border-primary-container/40" aria-hidden="true"></div>
        <div class="absolute bottom-3 right-3 w-4 h-4 border-b border-r border-primary-container/40" aria-hidden="true"></div>
        <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/25 to-transparent animate-scan-line" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- Briefing + Specs -->
  <section class="bg-background py-section relative overflow-hidden" aria-labelledby="briefing-title">
    <div class="absolute inset-0 bg-tech-grid opacity-[0.06] pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Briefing -->
        <article class="lg:col-span-7" aria-labelledby="briefing-title">
          <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">01 // Briefing</span>
          <h2 id="briefing-title" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-6">O problema</h2>
          <p class="text-body-lg text-tertiary leading-relaxed mb-8">{project.briefing}</p>

          <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">02 // Entrega</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-6">A solução AUMAF 3D</h2>
          <p class="text-body-lg text-tertiary leading-relaxed">{project.delivery}</p>
        </article>

        <!-- Specs sidebar -->
        <aside class="lg:col-span-5" aria-labelledby="specs-title">
          <div class="glass-panel p-7 rounded-sm border border-primary-container/15 sticky top-24">
            <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">03 // Specs</span>
            <h2 id="specs-title" class="text-headline-md font-bold uppercase text-white tracking-[-0.01em] mb-5">Ficha técnica</h2>
            <dl class="space-y-3 divide-y divide-white/8">
              {project.specs.map((s) => (
                <div class="pt-3 first:pt-0 flex items-start justify-between gap-4">
                  <dt class="text-label-caps text-on-surface-variant uppercase tracking-widest text-[10px] flex-1">{s.label}</dt>
                  <dd class="text-code-data text-on-surface font-medium text-right max-w-[60%]">{s.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Resultados -->
  <section class="bg-surface-low py-section relative overflow-hidden" aria-labelledby="results-title">
    <div class="absolute inset-0 bg-tech-grid opacity-[0.18] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 55% 45% at 50% 0%,rgba(97,197,79,0.07) 0%,transparent 60%);"></div>
    <div class="line-glow-bright absolute top-0 left-[5%] right-[5%] pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <div class="mb-12 border-b border-white/8 pb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">04 // Resultados</span>
          <h2 id="results-title" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Métricas mensuradas</h2>
        </div>
        <p class="text-body-md text-tertiary max-w-md leading-relaxed">Números reportados pelo cliente ou medidos em bancada/produção.</p>
      </div>

      <div class:list={[
        'grid grid-cols-1 sm:grid-cols-2 gap-gutter',
        project.results.length === 3 ? 'lg:grid-cols-3' : 'lg:grid-cols-4',
      ]}>
        {project.results.map((r) => (
          <div class="glass-panel p-6 rounded-sm border border-white/8 hover:border-primary-container/30 group relative overflow-hidden transition-all duration-300">
            <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-primary-container/25 opacity-50 group-hover:opacity-100 transition-opacity" aria-hidden="true"></div>
            <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-primary-container/25 opacity-50 group-hover:opacity-100 transition-opacity" aria-hidden="true"></div>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-widest text-[10px] block mb-3">{r.label}</span>
            <p class="text-[clamp(28px,3vw,40px)] font-black text-primary-container text-glow-sm leading-none tracking-tighter mb-2">{r.value}</p>
            {r.hint && <p class="text-sm text-tertiary leading-snug">{r.hint}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Galeria adicional (apenas se houver múltiplas imagens) -->
  {project.gallery.length > 1 && (
    <section class="bg-background py-section relative overflow-hidden" aria-labelledby="gallery-title">
      <div class="absolute inset-0 bg-tech-grid opacity-[0.06] pointer-events-none" aria-hidden="true"></div>
      <div class="max-w-[1600px] mx-auto px-edge relative z-10">
        <div class="mb-10">
          <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">05 // Galeria</span>
          <h2 id="gallery-title" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Mais imagens</h2>
        </div>
        <ul role="list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
          {project.gallery.slice(1).map((img) => (
            <li class="relative aspect-[4/3] rounded-sm overflow-hidden bg-surface-base border border-white/8 group">
              <img
                src={img.src}
                alt={img.alt}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-tech-grid opacity-12 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
              <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,transparent 60%,rgba(0,0,0,0.55) 100%);"></div>
              <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-primary-container/30" aria-hidden="true"></div>
              <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-primary-container/30" aria-hidden="true"></div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Prev / Next + CTA -->
  <section class="bg-surface-low border-t border-white/8 relative overflow-hidden" aria-label="Navegação entre projetos">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 60% 40% at 50% 50%,rgba(97,197,79,0.05) 0%,transparent 65%);"></div>
    <div class="max-w-[1600px] mx-auto px-edge py-12 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {prev && (
          <a
            href={`/portfolio/${prev.slug}`}
            class="group glass-panel p-5 rounded-sm border border-white/8 hover:border-primary-container/30 transition-all duration-200 flex items-center gap-4 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          >
            <span class="material-symbols-outlined text-2xl text-on-surface-variant group-hover:text-primary-container group-hover:-translate-x-1 transition-all duration-200" aria-hidden="true">arrow_back</span>
            <div class="min-w-0">
              <span class="text-label-caps text-on-surface-variant uppercase tracking-widest text-[10px] block mb-1">Anterior</span>
              <span class="text-body-md font-medium text-white block truncate">{prev.title}</span>
              <span class="text-code-data text-tertiary text-[11px]">{prev.cat} · {prev.mat}</span>
            </div>
          </a>
        )}
        {next && (
          <a
            href={`/portfolio/${next.slug}`}
            class="group glass-panel p-5 rounded-sm border border-white/8 hover:border-primary-container/30 transition-all duration-200 flex items-center justify-end gap-4 text-right md:flex-row-reverse focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          >
            <span class="material-symbols-outlined text-2xl text-on-surface-variant group-hover:text-primary-container group-hover:translate-x-1 transition-all duration-200" aria-hidden="true">arrow_forward</span>
            <div class="min-w-0 md:text-left">
              <span class="text-label-caps text-on-surface-variant uppercase tracking-widest text-[10px] block mb-1">Próximo</span>
              <span class="text-body-md font-medium text-white block truncate">{next.title}</span>
              <span class="text-code-data text-tertiary text-[11px]">{next.cat} · {next.mat}</span>
            </div>
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-background border-t border-primary-container/20 py-section relative overflow-hidden" aria-labelledby="cta-port">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 50% 60% at 50% 50%,rgba(97,197,79,0.06) 0%,transparent 65%);"></div>
    <div class="absolute inset-0 bg-tech-grid opacity-[0.08] pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-[1600px] mx-auto px-edge text-center relative z-10">
      <h2 id="cta-port" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-4">Tem um projeto similar?</h2>
      <p class="text-body-lg text-tertiary mb-8 max-w-md mx-auto">Envie seu arquivo ou conte o desafio. Orçamento técnico em até 24 horas.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={`/contato?ref=${encodeURIComponent(project.slug)}`}
          class="inline-flex items-center justify-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300"
        >
          <span class="material-symbols-outlined text-base" aria-hidden="true" style="font-variation-settings:'FILL' 1;">upload_file</span>
          Solicitar orçamento
        </a>
        <a
          href="/portfolio"
          class="inline-flex items-center justify-center gap-2 border border-white/20 text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm hover:border-primary-container hover:text-primary-container transition-all duration-200"
        >
          Ver outros projetos
          <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <!-- Mobile sticky bottom-bar — prev/next entre projetos (somente em telas <md) -->
  <div
    class="md:hidden fixed inset-x-0 bottom-0 z-30 nav-glass-bottom pb-[max(env(safe-area-inset-bottom),0.5rem)]"
    aria-label="Navegação entre projetos (mobile)"
  >
    <div class="flex items-stretch gap-2 px-3 py-2.5">
      {prev ? (
        <a
          href={`/portfolio/${prev.slug}`}
          class="flex-1 inline-flex items-center justify-center gap-1.5 min-h-11 px-3 rounded-sm border border-white/10 bg-surface-low text-on-surface text-label-caps uppercase tracking-[0.12em] text-[10px] active:bg-primary-container/15 active:text-primary-container focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          aria-label={`Projeto anterior: ${prev.title}`}
        >
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">chevron_left</span>
          <span>Anterior</span>
        </a>
      ) : (
        <span class="flex-1 inline-flex items-center justify-center min-h-11 px-3 rounded-sm border border-white/5 text-on-surface-variant/40 text-label-caps uppercase tracking-[0.12em] text-[10px]" aria-disabled="true">
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">chevron_left</span>
        </span>
      )}
      <a
        href="/portfolio"
        class="inline-flex items-center justify-center w-11 h-11 rounded-sm border border-white/10 bg-surface-low text-on-surface active:text-primary-container focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container shrink-0"
        aria-label="Ver todos os projetos"
      ><span class="material-symbols-outlined text-lg leading-none" aria-hidden="true">grid_view</span></a>
      {next ? (
        <a
          href={`/portfolio/${next.slug}`}
          class="flex-1 inline-flex items-center justify-center gap-1.5 min-h-11 px-3 rounded-sm border border-white/10 bg-surface-low text-on-surface text-label-caps uppercase tracking-[0.12em] text-[10px] active:bg-primary-container/15 active:text-primary-container focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          aria-label={`Próximo projeto: ${next.title}`}
        >
          <span>Próximo</span>
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">chevron_right</span>
        </a>
      ) : (
        <span class="flex-1 inline-flex items-center justify-center min-h-11 px-3 rounded-sm border border-white/5 text-on-surface-variant/40 text-label-caps uppercase tracking-[0.12em] text-[10px]" aria-disabled="true">
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">chevron_right</span>
        </span>
      )}
    </div>
  </div>

  <!-- Spacer mobile para garantir que conteúdo final não fique escondido pela bar -->
  <div class="md:hidden h-16" aria-hidden="true"></div>

  <style is:inline>
    /* Esconder FAB WhatsApp no mobile — bottom-bar de navegação ocupa o espaço */
    @media (max-width: 767px) {
      .fab-stack { display: none !important; }
    }
  </style>
</Base>

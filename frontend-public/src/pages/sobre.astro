---
// ============================================================
// TEMPLATE DEMO PAGE
// Esta página contém copy específica do setor da marca original
// (AUMAF 3D — manufatura aditiva). Substitua textos, imagens e seções
// pela proposta da sua marca. A estrutura visual é reaproveitável.
// ============================================================
export const prerender = true
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { COMPANY } from '../lib/company'
import { itemListSchema } from '../lib/schemas'

const description = 'Conheça a AUMAF 3D — manufatura aditiva industrial em São Carlos, SP, desde 2022. Missão, visão, valores, parceria com Fórmula SAE USP e localização no Parque Tecnológico Damha II.'

const schemas = [
  itemListSchema([
    { name: 'Missão', description: 'Tornar a manufatura aditiva de alta performance acessível a empresas de todos os portes.' },
    { name: 'Visão', description: 'Ser o parceiro de engenharia aditiva de referência no interior de São Paulo.' },
    { name: 'Valores', description: 'Inovação contínua, qualidade comprovada, transparência e parceria.' },
  ]),
]
---

<Base
  title="Sobre"
  description={description}
  pageType="AboutPage"
  breadcrumb={[{ name: 'Sobre', url: '/sobre' }]}
  schemas={schemas}
>
  <Navbar currentPath="/sobre" />

  <!-- Hero Institucional assimétrico -->
  <section class="bg-background min-h-[65vh] flex items-end pt-28 pb-20 relative overflow-hidden" aria-labelledby="hero-sobre">
    <!-- Bg AI: workshop industrial (tema sobre/empresa) -->
    <div class="absolute inset-0 pointer-events-none bg-no-repeat bg-cover bg-center opacity-[0.30] z-[1]" aria-hidden="true" style="background-image:url('/images/bg-workshop.webp');"></div>
    <img
      src="/images/sobre-hero-hexmesh.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-60 pointer-events-none"
      width="1584"
      height="672"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 60% 50% at 70% 10%,rgba(97,197,79,0.06) 0%,transparent 60%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 35% 40% at 5% 90%,rgba(97,197,79,0.04) 0%,transparent 65%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,rgba(0,0,0,0.55) 0%,rgba(0,0,0,0.35) 50%,rgba(0,0,0,0.85) 100%);"></div>
    <div class="absolute bottom-0 inset-x-0 h-16 pointer-events-none" aria-hidden="true" style="background:linear-gradient(to bottom,transparent,rgba(0,0,0,0.6));"></div>

    <div class="max-w-[1600px] mx-auto px-edge w-full relative z-10">
      <Breadcrumb items={[{ name: 'Sobre' }]} compact />
      <div class="grid grid-cols-1 md:grid-cols-5 gap-12 items-end">
        <div class="md:col-span-3">
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-4">Empresa // História</span>
          <h1 id="hero-sobre" class="text-display-xl font-bold uppercase text-white tracking-[-0.04em] leading-none">
            Sobre a<br/>AUMAF 3D.
          </h1>
        </div>
        <div class="md:col-span-2 md:pb-2">
          <p class="text-body-lg text-tertiary leading-relaxed">
            <strong class="text-on-surface font-medium">AUMAF 3D</strong> é uma empresa de manufatura aditiva industrial localizada no Parque Tecnológico Damha II, em São Carlos – SP. Vizinhos à USP e UFSCar, no coração do polo tecnológico do interior paulista.
          </p>
          <div class="mt-6 flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-primary-container glow-effect" aria-hidden="true"></span>
            <span class="text-label-caps text-primary-container uppercase tracking-[0.2em]">
              Em produção desde <time datetime={COMPANY.founded}>{COMPANY.founded}</time>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Missão / Visão / Valores (zigzag) -->
  <section class="bg-background py-section" aria-labelledby="mvv-heading">
    <h2 id="mvv-heading" class="sr-only">Missão, Visão e Valores</h2>
    <div class="max-w-[1600px] mx-auto px-edge">
      <dl class="divide-y divide-white/5">
        {[
          {
            num: '01',
            title: 'Nossa Missão',
            body: 'Tornar a manufatura aditiva de alta performance acessível a empresas de todos os portes — sem abrir mão da qualidade, precisão e atendimento técnico de excelência. Acreditamos que a impressão 3D é o futuro da produção industrial, e trabalhamos para que esse futuro seja acessível a todos.',
            highlight: 'Qualidade + Acessibilidade',
            image: '/images/sobre-missao-qualidade.webp',
            imageAlt: 'Engenheiro AUMAF inspecionando peça impressa em 3D com paquímetro digital',
            reverse: false,
          },
          {
            num: '02',
            title: 'Nossa Visão',
            body: 'Ser o parceiro de engenharia aditiva de referência no interior de São Paulo, acelerando a inovação de indústrias, startups e laboratórios de pesquisa. Conectar a precisão da manufatura digital com as necessidades reais de quem constrói o futuro.',
            highlight: 'Hub de Inovação Regional',
            image: '/images/sobre-visao-hub.webp',
            imageAlt: 'Parque Tecnológico Damha II em São Carlos — fachada do hub de inovação onde a AUMAF está instalada',
            reverse: true,
          },
          {
            num: '03',
            title: 'Nossos Valores',
            body: 'Inovação contínua — buscamos sempre as tecnologias e materiais mais avançados. Qualidade comprovada — cada peça passa por controle dimensional antes de sair. Transparência — prazo e orçamento definidos antes do início. Parceria — não somos fornecedores, somos parceiros técnicos.',
            highlight: 'Inovação + Qualidade + Transparência',
            image: '/images/sobre-valores-bancada.webp',
            imageAlt: 'Bancada AUMAF com peças impressas, paquímetro, ordem de produção e checklist de qualidade',
            reverse: false,
          },
        ].map((item, i) => (
          <div data-animate class:list={['grid grid-cols-1 lg:grid-cols-2 gap-16 items-start py-20 reveal-hidden', `stagger-${i + 1}`]}>
            <div class:list={item.reverse ? 'lg:order-2' : ''}>
              <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">[{item.num}]</span>
              <dt class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-5">{item.title}</dt>
              <dd class="text-body-lg text-tertiary leading-relaxed mb-6">{item.body}</dd>
            </div>
            <div class:list={item.reverse ? 'lg:order-1' : ''}>
              <div class="relative aspect-[4/3] rounded-sm overflow-hidden bg-surface-base border border-primary-container/15 group/mvv" style="box-shadow:0 20px 60px rgba(0,0,0,0.5);">
                <img
                  src={item.image}
                  alt={item.imageAlt}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover/mvv:scale-[1.04]"
                  width="1200"
                  height="896"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
                <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(circle at 50% 50%,rgba(97,197,79,0.06) 0%,transparent 70%),linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.65) 100%);"></div>
                <div class="absolute top-3 left-3 w-3 h-3 border-t border-l border-primary-container/40" aria-hidden="true"></div>
                <div class="absolute top-3 right-3 w-3 h-3 border-t border-r border-primary-container/40" aria-hidden="true"></div>
                <div class="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-primary-container/40" aria-hidden="true"></div>
                <div class="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-primary-container/40" aria-hidden="true"></div>
                <div class="absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-black/85 via-black/40 to-transparent">
                  <p class="text-headline-md font-medium text-primary-container leading-snug">{item.highlight}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Case: Fórmula SAE USP -->
  <section class="bg-surface-low py-section border-y border-white/5 section-glow-top" aria-labelledby="case-sae">
    <div class="max-w-[1600px] mx-auto px-edge">
      <header class="mb-12">
        <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">Case // Parceria</span>
        <h2 id="case-sae" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Fórmula SAE — USP São Carlos</h2>
      </header>
      <article class="glass-panel rounded-sm p-10 border border-primary-container/15 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-container/40 to-transparent" aria-hidden="true"></div>
        <div class="relative -mx-10 -mt-10 mb-8 aspect-[16/6] overflow-hidden border-b border-primary-container/15">
          <img
            src="/images/SAE-formula.avif"
            alt="Equipe Fórmula SAE USP São Carlos com peças impressas em 3D pela AUMAF"
            class="absolute inset-0 w-full h-full object-cover"
            width="1600"
            height="600"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
          <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.55) 100%);"></div>
          <div class="absolute bottom-3 left-3"><span class="pill-green text-[10px]">Fórmula SAE 2024 · USP São Carlos</span></div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-center">
          <div class="lg:col-span-2">
            <span class="pill-green mb-4 inline-block">
              Parceria Universitária · <time datetime="2024-06">Jun 2024</time>
            </span>
            <p class="text-body-lg text-tertiary leading-relaxed">
              A AUMAF 3D forneceu peças estruturais e aerodinâmicas para o carro de competição da equipe de Engenharia Mecânica da USP São Carlos na Fórmula SAE 2024. Componentes em <strong class="text-on-surface">Nylon PA</strong> e <strong class="text-on-surface">PET-G CF15</strong> para suportes de suspensão, guias de cabo e elementos aerodinâmicos — com exigência de tolerância mínima e peso reduzido.
            </p>
          </div>
          <dl class="glass-panel rounded-sm p-6 space-y-4">
            {[
              { label: 'Parceiro', value: 'USP São Carlos' },
              { label: 'Evento', value: 'Fórmula SAE 2024' },
              { label: 'Materiais', value: 'PA / PET-G CF15' },
              { label: 'Aplicação', value: 'Estrutural + Aerodinâmica' },
            ].map((d) => (
              <div class="border-b border-white/8 pb-3 last:border-b-0 last:pb-0">
                <dt class="text-label-caps text-on-surface-variant uppercase tracking-widest text-[10px] mb-0.5">{d.label}</dt>
                <dd class="text-body-md text-on-surface font-medium">{d.value}</dd>
              </div>
            ))}
            <a href="/blog/formula-sae-case-study-completo" class="mt-2 inline-flex items-center gap-2 text-label-caps text-primary-container uppercase tracking-[0.15em] hover:gap-4 transition-all duration-200 group pt-2">
              Ler case completo da Fórmula SAE
              <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
            </a>
          </dl>
        </div>
      </article>
    </div>
  </section>

  <!-- Localização -->
  <section class="bg-background py-section" aria-labelledby="loc-heading">
    <div class="max-w-[1600px] mx-auto px-edge">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">Localização // Endereço</span>
          <h2 id="loc-heading" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-6">São Carlos, SP.<br/>Polo Tecnológico.</h2>
          <p class="text-body-lg text-tertiary leading-relaxed mb-8">
            Localizada no Parque Tecnológico Damha II, a AUMAF 3D está inserida em um dos principais ecossistemas de inovação do Brasil. Próxima à USP, UFSCar e centenas de startups e empresas de base tecnológica.
          </p>
          <address class="not-italic space-y-4">
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary-container text-xl mt-0.5" aria-hidden="true" style="font-variation-settings:'FILL' 1;">location_on</span>
              <p class="text-body-md text-on-surface">
                {COMPANY.address.streetAddress}, {COMPANY.address.neighborhood}<br/>
                {COMPANY.address.addressLocality} – {COMPANY.address.addressRegion}, {COMPANY.address.postalCode}
              </p>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary-container text-xl mt-0.5" aria-hidden="true" style="font-variation-settings:'FILL' 1;">phone</span>
              <a href={COMPANY.contact.whatsapp} target="_blank" rel="noopener noreferrer" aria-label={`Falar pelo WhatsApp: ${COMPANY.contact.phoneDisplay} (abre em nova aba)`} class="text-body-md text-on-surface hover:text-primary-container transition-colors">
                {COMPANY.contact.phoneDisplay}
              </a>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary-container text-xl mt-0.5" aria-hidden="true" style="font-variation-settings:'FILL' 1;">mail</span>
              <a href={`mailto:${COMPANY.contact.email}`} class="text-body-md text-on-surface hover:text-primary-container transition-colors">
                {COMPANY.contact.email}
              </a>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary-container text-xl mt-0.5" aria-hidden="true" style="font-variation-settings:'FILL' 1;">schedule</span>
              <p class="text-body-md text-on-surface">{COMPANY.hours.displayPt}</p>
            </div>
          </address>
        </div>
        <!-- Mapa real (Google Maps embed) -->
        <div class="relative h-80 rounded-sm overflow-hidden border border-white/8 bg-surface-base">
          <iframe
            title="Localização da AUMAF 3D no Google Maps"
            src={`https://maps.google.com/maps?q=${encodeURIComponent(COMPANY.address.streetAddress + ', ' + COMPANY.address.neighborhood + ', ' + COMPANY.address.addressLocality + ' - ' + COMPANY.address.addressRegion)}&z=15&output=embed`}
            class="absolute inset-0 w-full h-full"
            style="border:0; filter:invert(0.92) hue-rotate(180deg) saturate(0.4) brightness(0.95);"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary-container/30 to-transparent pointer-events-none" aria-hidden="true"></div>
          <div class="absolute bottom-3 right-3 pointer-events-none">
            <span class="text-label-caps text-primary-container/60 text-[10px] tracking-widest font-mono bg-black/60 backdrop-blur-sm px-2 py-1 rounded-sm">{COMPANY.geo.latitude}, {COMPANY.geo.longitude}</span>
          </div>
          <a
            href={`https://maps.google.com/?q=${encodeURIComponent(COMPANY.address.streetAddress + ' ' + COMPANY.address.addressLocality)}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Abrir endereço no Google Maps em uma nova aba"
            class="absolute bottom-3 left-3 pill-green inline-flex items-center gap-1 text-[10px]"
          >
            Abrir no Google Maps <span class="material-symbols-outlined text-sm" aria-hidden="true">open_in_new</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-surface-low border-t border-white/5 py-16" aria-labelledby="cta-sobre">
    <div class="max-w-[1600px] mx-auto px-edge text-center">
      <h2 id="cta-sobre" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-4">Vamos Trabalhar Juntos?</h2>
      <p class="text-body-lg text-tertiary mb-8 max-w-md mx-auto">Conte-nos sobre seu projeto. Respondemos em até 24 horas.</p>
      <a href="/contato" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300">
        Solicitar orçamento <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
      </a>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('reveal-visible')
          observer.unobserve(e.target)
        }
      })
    },
    { threshold: 0.08, rootMargin: '0px 0px -50px 0px' },
  )
  document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el))
</script>

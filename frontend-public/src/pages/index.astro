---
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
---

<Base title="Manufatura Aditiva Industrial de Precisão">
  <Navbar currentPath="/" />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-background">
    <div class="absolute inset-0 bg-tech-grid pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse at 60% 50%,rgba(97,197,79,0.06) 0%,transparent 65%);"></div>

    <!-- Geometric background visual -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-background via-background/85 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent opacity-70"></div>
      <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[50vw] h-[80vh] opacity-[0.06] pointer-events-none">
        <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <polygon points="250,20 480,140 480,360 250,480 20,360 20,140" stroke="#61c54f" stroke-width="1" fill="none"/>
          <polygon points="250,60 440,160 440,340 250,440 60,340 60,160" stroke="#61c54f" stroke-width="0.5" fill="none"/>
          <polygon points="250,100 400,180 400,320 250,400 100,320 100,180" stroke="#61c54f" stroke-width="0.5" fill="none" opacity="0.6"/>
          <line x1="250" y1="20" x2="250" y2="480" stroke="#61c54f" stroke-width="0.3" opacity="0.5"/>
          <line x1="20" y1="140" x2="480" y2="360" stroke="#61c54f" stroke-width="0.3" opacity="0.3"/>
          <line x1="480" y1="140" x2="20" y2="360" stroke="#61c54f" stroke-width="0.3" opacity="0.3"/>
          <circle cx="250" cy="250" r="60" stroke="#61c54f" stroke-width="0.5" fill="none" opacity="0.4"/>
          <circle cx="250" cy="250" r="120" stroke="#61c54f" stroke-width="0.3" fill="none" opacity="0.3"/>
          <circle cx="250" cy="250" r="5" fill="#61c54f" opacity="0.6"/>
          <circle cx="250" cy="250" r="2" fill="#61c54f"/>
        </svg>
      </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-[1440px] mx-auto px-edge pt-32 pb-20">
      <div class="max-w-3xl">
        <!-- Status pill -->
        <div class="flex items-center gap-3 mb-8">
          <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse-dot glow-effect"></span>
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em]">
            Sistema Online // Imprimindo Agora
          </span>
        </div>

        <h1 class="text-display-xl font-bold text-white uppercase leading-none tracking-[-0.04em] mb-6 opacity-0 animate-fade-up" style="animation-delay:100ms;animation-fill-mode:forwards;">
          Zero-Error<br/>
          <span style="background:linear-gradient(135deg,#7ce268,#61c54f);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Precision.</span>
        </h1>

        <p class="text-body-lg text-tertiary max-w-xl leading-relaxed mb-10 opacity-0 animate-fade-up" style="animation-delay:250ms;animation-fill-mode:forwards;">
          Manufatura aditiva industrial para aplicações críticas.
          Peças em metal, carbono e polímeros de alta performance —
          tolerância <span class="text-on-surface font-medium">±0.05mm</span>, entregues onde você precisar.
        </p>

        <div class="flex flex-wrap items-center gap-4 opacity-0 animate-fade-up" style="animation-delay:380ms;animation-fill-mode:forwards;">
          <a href="/contato" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim hover:shadow-glow-lg transition-all duration-300">
            <span class="material-symbols-outlined text-base leading-none" style="font-variation-settings:'FILL' 1;">rocket_launch</span>
            Solicitar Orçamento
          </a>
          <a href="/portfolio" class="inline-flex items-center gap-2 border border-white/20 text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm hover:border-primary-container/50 hover:text-primary-container transition-all duration-300">
            Ver Portfolio
            <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Active Build widget -->
    <div class="absolute bottom-12 right-16 hidden lg:block z-10 opacity-0 animate-fade-up" style="animation-delay:500ms;animation-fill-mode:forwards;">
      <div class="glass-panel rounded-lg p-5 w-72 relative" style="border:1px solid rgba(97,197,79,0.15);">
        <div class="flex justify-between items-center mb-4 border-b border-white/8 pb-4">
          <span class="text-label-caps text-tertiary uppercase tracking-widest">Active Build</span>
          <span class="text-label-caps text-primary-container tracking-widest">ID_409X</span>
        </div>
        <div class="space-y-3">
          <div>
            <div class="flex justify-between text-code-data text-white/60 mb-1.5">
              <span>Impressão</span>
              <span class="text-primary-container font-medium">80%</span>
            </div>
            <div class="h-px bg-surface-high rounded overflow-hidden">
              <div class="h-full bg-primary-container glow-effect" style="width:80%;"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-code-data text-white/60 mb-1.5">
              <span>Temperatura</span>
              <span class="text-error font-medium">265°C</span>
            </div>
            <div class="h-px bg-surface-high rounded overflow-hidden">
              <div class="h-full bg-error" style="width:95%;"></div>
            </div>
          </div>
          <div class="pt-1 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-primary-container animate-pulse-dot"></span>
            <span class="text-code-data text-tertiary text-[11px]">PA CF15 · Layer: 0.15mm</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30 z-10">
      <span class="text-label-caps text-tertiary uppercase tracking-widest text-[10px]">Scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-tertiary to-transparent"></div>
    </div>
  </section>


  <!-- STATS STRIP -->
  <div class="border-y border-primary-container/20 bg-surface-dim">
    <div class="max-w-[1440px] mx-auto px-edge py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/8">
        {[
          {value:'+500',label:'Projetos Entregues'},
          {value:'20+',label:'Materiais Disponíveis'},
          {value:'±0.05mm',label:'Tolerância Dimensional'},
          {value:'3',label:'Tecnologias de Impressão'},
        ].map(s => (
          <div class="flex flex-col items-center md:items-start px-6 md:px-10 py-2 gap-1.5 first:pl-0 last:border-r-0">
            <span class="text-[clamp(28px,4vw,48px)] font-bold tracking-tighter text-white leading-none">{s.value}</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.15em] text-[10px]">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>


  <!-- CAPACIDADES — Zigzag -->
  <section class="bg-background py-section">
    <div class="max-w-[1440px] mx-auto px-edge">
      <div class="mb-20 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">01 // Módulos</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Capacidades Core</h2>
        </div>
        <a href="/servicos" class="text-label-caps text-primary-container uppercase tracking-[0.15em] flex items-center gap-2 hover:gap-4 transition-all duration-200">
          Todos os Serviços <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>

      <div class="divide-y divide-white/5">
        {[
          {num:'01',title:'Prototipagem Rápida',body:'Valide conceitos em horas, não semanas. Processos FDM e SLA entregam protótipos funcionais com geometrias complexas e tolerância dimensional rigorosa para ciclos de iteração acelerados.',specs:['FDM / SLA / SLS','Entrega 24–72h','Geometria Complexa'],href:'/servicos',reverse:false},
          {num:'02',title:'Peças Funcionais & Metal',body:'Do projeto à peça final em materiais de engenharia: carbono, nylon de alta temperatura, PEEK e aço inoxidável via BASF Ultrafuse 316L. Componentes para ambientes industriais severos.',specs:['Metal 316L','PA CF15 / PEEK','Alta Temperatura'],href:'/servicos',reverse:true},
          {num:'03',title:'Modelagem & Engenharia Reversa',body:'Transformamos desenhos, esboços e peças físicas em modelos digitais precisos. Scanner 3D para captura de geometrias complexas e otimização DfAM para manufatura aditiva.',specs:['CAD Profissional','Scanner 3D','DfAM'],href:'/servicos',reverse:false},
          {num:'04',title:'Peças de Reposição Sob Demanda',body:'Pare de esperar por peças descontinuadas. Fabricamos substitutas em plástico técnico ou metal em prazo reduzido, sem mínimo de quantidade.',specs:['Sem Mínimo','Sob Medida','Entrega Ágil'],href:'/servicos',reverse:true},
        ].map((item) => (
          <div class:list={['grid grid-cols-1 lg:grid-cols-2 gap-16 items-center py-20', item.reverse ? 'direction-rtl' : '']}>
            <div class:list={item.reverse ? 'lg:order-2' : ''}>
              <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">[{item.num}]</span>
              <h3 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-5">{item.title}</h3>
              <p class="text-body-lg text-tertiary leading-relaxed mb-6">{item.body}</p>
              <div class="flex flex-wrap gap-2 mb-8">
                {item.specs.map(s => <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest">{s}</span>)}
              </div>
              <a href={item.href} class="inline-flex items-center gap-2 text-label-caps text-primary-container uppercase tracking-[0.15em] hover:gap-4 transition-all duration-200 group">
                Saiba mais
                <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </a>
            </div>
            <div class:list={item.reverse ? 'lg:order-1' : ''}>
              <div class="relative aspect-square max-w-md mx-auto rounded-sm overflow-hidden bg-surface-base border border-white/5">
                <div class="absolute inset-0 bg-tech-grid opacity-50"></div>
                <div class="absolute inset-0" style={`background:radial-gradient(circle at 50% 50%,rgba(97,197,79,0.08) 0%,transparent 70%);`}></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="text-[100px] font-black text-white/[0.025] leading-none select-none tracking-tighter">{item.num}</div>
                </div>
                <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/30 to-transparent animate-scan-line"></div>
                <div class="absolute top-4 right-4 text-label-caps text-primary-container/30 text-[10px] tracking-widest uppercase">MODULE_{item.num}</div>
                <div class="absolute bottom-4 left-4">
                  <span class="pill-green text-[10px]">{item.specs[0]}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- DIFERENCIAIS -->
  <section class="bg-surface-low py-section">
    <div class="max-w-[1440px] mx-auto px-edge">
      <div class="mb-16 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">02 // Diferenciais</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Por que AUMAF 3D</h2>
        </div>
        <p class="text-body-md text-tertiary max-w-sm">Precisão industrial, entrega ágil e parceria técnica em cada projeto.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {[
          {icon:'precision_manufacturing',num:'01',title:'Precisão Certificada',body:'±0.05mm em FDM industrial. Peças dimensionalmente consistentes entre lotes, rastreáveis por projeto.',tag:'QUALIDADE'},
          {icon:'category',num:'02',title:'Portfólio de Materiais',body:'20+ materiais: PA CF15, PEEK, TPU, ABS, Policarbonato, Resina e BASF Ultrafuse 316L (aço inoxidável).',tag:'MATERIAIS'},
          {icon:'tune',num:'03',title:'Feito Sob Medida',body:'Personalização total de geometria, material e acabamento. Sem mínimo de produção para projetos unitários.',tag:'FLEXIBILIDADE'},
          {icon:'support_agent',num:'04',title:'Consultoria Técnica',body:'Equipe especializada indica tecnologia, material e processo ideal. Suporte do arquivo à entrega final.',tag:'SUPORTE'},
          {icon:'location_on',num:'05',title:'Hub de Inovação',body:'Parque Tecnológico Damha II, São Carlos – SP. Polo tecnológico próximo à USP e UFSCar.',tag:'SÃO CARLOS'},
          {icon:'local_shipping',num:'06',title:'Entrega Ágil',body:'Orçamento em até 24h, produção ágil, atendimento nacional com prazo definido desde o primeiro contato.',tag:'LOGÍSTICA'},
        ].map(card => (
          <div class="glass-panel p-8 group hover:-translate-y-1 transition-all duration-300" style="border-radius:2px;">
            <div class="flex justify-between items-start mb-6">
              <span class="material-symbols-outlined text-primary-container text-3xl" style="font-variation-settings:'FILL' 1;">{card.icon}</span>
              <span class="text-code-data text-white/10 font-bold">[{card.num}]</span>
            </div>
            <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest mb-4">{card.tag}</span>
            <h3 class="text-headline-md font-semibold uppercase text-white mb-3 tracking-[0.02em]">{card.title}</h3>
            <p class="text-body-md text-tertiary leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- TECNOLOGIAS -->
  <section class="bg-background py-section">
    <div class="max-w-[1440px] mx-auto px-edge">
      <div class="mb-16 border-b border-white/8 pb-10">
        <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">03 // Sistemas</span>
        <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Tecnologias Disponíveis</h2>
      </div>

      <!-- SLS destaque -->
      <div class="glass-panel p-10 mb-gutter" style="border:1px solid rgba(97,197,79,0.12);border-radius:2px;">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div>
            <div class="flex items-center gap-4 mb-6">
              <span class="text-[52px] font-black text-primary-container leading-none tracking-[-0.04em]">SLS</span>
              <div class="border-l border-white/10 pl-4">
                <p class="text-body-md text-on-surface font-medium">Sinterização Seletiva a Laser</p>
                <p class="text-sm text-tertiary">Sem estruturas de suporte</p>
              </div>
            </div>
            <p class="text-body-md text-tertiary leading-relaxed mb-6">Peças com densidade máxima e geometrias internas complexas impossíveis por outros métodos. Ideal para protótipos funcionais de alta precisão e pequenas séries técnicas.</p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest">Resolução 100μm</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest">Sem Suporte</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest">Nylon / PA / TPU</span>
            </div>
          </div>
          <div class="relative h-52 rounded-sm overflow-hidden bg-surface-high border border-white/5">
            <div class="absolute inset-0 bg-tech-grid opacity-40"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-25">
              <svg viewBox="0 0 120 120" fill="none" class="w-28 h-28">
                <rect x="20" y="20" width="80" height="80" stroke="#61c54f" stroke-width="0.8"/>
                <rect x="35" y="35" width="50" height="50" stroke="#61c54f" stroke-width="0.5"/>
                <line x1="20" y1="60" x2="100" y2="60" stroke="#61c54f" stroke-width="0.3"/>
                <line x1="60" y1="20" x2="60" y2="100" stroke="#61c54f" stroke-width="0.3"/>
                <circle cx="60" cy="60" r="8" stroke="#61c54f" stroke-width="0.8" fill="rgba(97,197,79,0.1)"/>
                <circle cx="60" cy="60" r="2" fill="#61c54f"/>
              </svg>
            </div>
            <div class="absolute top-3 right-3 text-label-caps text-primary-container/40 text-[10px] tracking-widest">LASER_HEAD</div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
        {[
          {code:'SLA',title:'Estereolitografia',body:'Alta resolução com resinas fotopoliméricas. Superfícies lisas, detalhes finos e transparência óptica.',specs:['Resina ABS/Cerâmica','Resolução 25μm','Acabamento Premium']},
          {code:'FDM',title:'Deposição de Material Fundido',body:'Tecnologia versátil com o maior portfólio de materiais: termoplásticos, carbono, metal e flexíveis.',specs:['20+ Materiais','Metal Disponível','Maior Portfólio']},
        ].map(t => (
          <div class="glass-panel p-8 hover:border-primary-container/20 transition-all duration-300" style="border-radius:2px;">
            <span class="text-[40px] font-black text-on-surface leading-none tracking-[-0.04em] block mb-2">{t.code}</span>
            <p class="text-sm text-tertiary mb-1">{t.title}</p>
            <p class="text-body-md text-on-surface-variant leading-relaxed mb-6">{t.body}</p>
            <div class="flex flex-wrap gap-2">
              {t.specs.map(s => <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest">{s}</span>)}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/materiais" class="inline-flex items-center gap-2 border border-white/15 text-on-surface-variant text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm hover:border-primary-container/50 hover:text-primary-container transition-all duration-300">
          Ver Catálogo de Materiais <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>


  <!-- INDÚSTRIAS -->
  <section class="bg-surface-dim py-section">
    <div class="max-w-[1440px] mx-auto px-edge">
      <div class="mb-16 text-center">
        <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">04 // Setores</span>
        <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Indústrias que Atendemos</h2>
        <p class="text-body-md text-tertiary mt-4 max-w-lg mx-auto">Da prototipagem de pesquisa universitária à produção de componentes aeroespaciais.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          {icon:'directions_car',label:'Automotiva'},
          {icon:'flight',label:'Aeroespacial'},
          {icon:'medical_services',label:'Médica & Hospitalar'},
          {icon:'precision_manufacturing',label:'Robótica Industrial'},
          {icon:'architecture',label:'Arquitetura & AEC'},
          {icon:'sports_motorsports',label:'Fórmula SAE / Racing'},
          {icon:'science',label:'P&D Universitária'},
          {icon:'factory',label:'Agroindustrial'},
        ].map(i => (
          <div class="glass-panel p-5 flex flex-col items-center gap-3 text-center group hover:border-primary-container/20 hover:-translate-y-0.5 transition-all duration-300" style="border-radius:2px;">
            <span class="material-symbols-outlined text-2xl text-white/30 group-hover:text-primary-container transition-colors">{i.icon}</span>
            <span class="text-code-data text-on-surface-variant uppercase tracking-widest text-[11px] group-hover:text-on-surface transition-colors">{i.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- DEPOIMENTOS -->
  <section class="bg-background py-section">
    <div class="max-w-[1440px] mx-auto px-edge">
      <div class="mb-16 border-b border-white/8 pb-10">
        <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">05 // Clientes</span>
        <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">O que Nossos Parceiros Dizem</h2>
      </div>

      <div class="relative">
        <div class="overflow-hidden">
          <div id="testimonial-track" class="flex transition-transform duration-500 ease-in-out">
            {[
              {quote:'Peças impressas com rapidez, personalização e muita precisão. Usamos a AUMAF 3D como fornecedora de componentes para máquinas e robôs. Impressionante!',name:'Raissa Ninelli',role:'Diretora',company:'Fugini Alimentos'},
              {quote:'Agilidade no orçamento e na entrega do projeto. Produtos chegaram com a qualidade e acabamento esperados. Recomendo para projetos exigentes.',name:'Thiago Gerotto',role:'Responsável Técnico',company:'Callamarys'},
              {quote:'Utilizamos maquetes e protótipos produzidos pela AUMAF 3D. Sempre fomos muito bem atendidos, com suporte completo em todas as etapas do projeto.',name:'Vitor Gonçalez',role:'Sócio Proprietário',company:'Aulevi'},
            ].map(t => (
              <div class="min-w-full px-4">
                <div class="max-w-3xl mx-auto glass-panel p-10 md:p-16" style="border-radius:2px;border:1px solid rgba(255,255,255,0.08);">
                  <div class="flex gap-1 mb-8">
                    {Array(5).fill(0).map(() => <span class="material-symbols-outlined text-primary-container text-lg" style="font-variation-settings:'FILL' 1;">star</span>)}
                  </div>
                  <blockquote class="text-headline-md font-light text-on-surface leading-relaxed mb-10">"{t.quote}"</blockquote>
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full border border-primary-container/30 flex items-center justify-center bg-primary-container/10">
                      <span class="text-primary-container font-bold text-sm">{t.name[0]}</span>
                    </div>
                    <div>
                      <p class="text-label-caps text-primary-container uppercase tracking-[0.15em] font-bold">{t.name}</p>
                      <p class="text-sm text-tertiary">{t.role} · {t.company}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center justify-center gap-4 mt-8">

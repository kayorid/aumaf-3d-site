<script>
  // ─── CONTADORES ANIMADOS (Intersection Observer) ───────────────────────────
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]')
  if (counters.length) {
    const ease = (t: number) => t < 0.5 ? 2*t*t : -1+(4-2*t)*t

    function animateCounter(el: HTMLElement) {
      const target = parseFloat(el.dataset.target || '0')
      const decimals = parseInt(el.dataset.decimals || '0')
      const duration = 1800
      const start = performance.now()
      function tick(now: number) {
        const progress = Math.min((now - start) / duration, 1)
        el.textContent = (target * ease(progress)).toFixed(decimals)
        if (progress < 1) requestAnimationFrame(tick)
        else el.textContent = target.toFixed(decimals)
      }
      requestAnimationFrame(tick)
    }

    const cntObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement)
          cntObs.unobserve(entry.target)
        }
      })
    }, { threshold: 0.4 })

    counters.forEach(el => cntObs.observe(el))
  }

  // ─── TESTIMONIALS CAROUSEL ─────────────────────────────────────────────────
  let cur = 0
  const track = document.getElementById('testimonial-track')
  const dots = document.querySelectorAll('#t-dots button')
  let autoTimer: ReturnType<typeof setInterval>

  function goTo(i: number) {
    cur = i
    if (track) track.style.transform = `translateX(-${i * 100}%)`
    dots.forEach((d, idx) => {
      const active = idx === i
      ;(d as HTMLElement).style.backgroundColor = active ? '#61c54f' : 'rgba(255,255,255,0.2)'
      ;(d as HTMLElement).style.boxShadow = active ? '0 0 8px rgba(97,197,79,0.4)' : ''
      d.setAttribute('aria-selected', String(active))
    })
  }

  function startAuto() {
    autoTimer = setInterval(() => goTo((cur + 1) % 3), 6000)
  }

  function resetAuto() {
    clearInterval(autoTimer)
    startAuto()
  }

  document.getElementById('prev-t')?.addEventListener('click', () => { goTo((cur - 1 + 3) % 3); resetAuto() })
  document.getElementById('next-t')?.addEventListener('click', () => { goTo((cur + 1) % 3); resetAuto() })
  dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); resetAuto() }))
  startAuto()

  // Scroll reveal com IntersectionObserver
  const revealEls = document.querySelectorAll('[data-animate]')
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement
          el.classList.remove('reveal-hidden', 'reveal-hidden-left')
          el.classList.add('reveal-visible')
          revealObserver.unobserve(el)
        }
      })
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  )
  revealEls.forEach(el => revealObserver.observe(el))
</script>

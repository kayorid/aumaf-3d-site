<script>
  // Testimonials carousel
  let cur = 0
  const track = document.getElementById('testimonial-track')
  const dots = document.querySelectorAll('#t-dots button')

  function goTo(i: number) {
    cur = i
    if (track) track.style.transform = `translateX(-${i * 100}%)`
    dots.forEach((d, idx) => {
      const active = idx === i
      ;(d as HTMLElement).style.backgroundColor = active ? '#61c54f' : 'rgba(255,255,255,0.2)'
      ;(d as HTMLElement).style.boxShadow = active ? '0 0 8px rgba(97,197,79,0.4)' : ''
    })
  }

  document.getElementById('prev-t')?.addEventListener('click', () => goTo((cur - 1 + 3) % 3))
  document.getElementById('next-t')?.addEventListener('click', () => goTo((cur + 1) % 3))
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)))
  setInterval(() => goTo((cur + 1) % 3), 6000)
</script>

---
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
---

<Base title="Manufatura Aditiva Industrial de Precisão">
  <Navbar currentPath="/" />

  <!-- =============================================
       HERO — 2 colunas: conteúdo + painel de mídia
       ============================================= -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-background">
    <!-- Grid técnico de fundo -->
    <div class="absolute inset-0 bg-tech-grid pointer-events-none opacity-50"></div>

    <!-- Glow 1: halo central difuso -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 60% at 65% 50%,rgba(97,197,79,0.08) 0%,transparent 65%);"></div>

    <!-- Glow 2: halo mais quente no canto superior direito -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 40% 40% at 90% 10%,rgba(97,197,79,0.05) 0%,transparent 70%);"></div>

    <!-- Glow 3: reflexo inferior esquerdo -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 30% 25% at 5% 95%,rgba(97,197,79,0.04) 0%,transparent 70%);"></div>

    <!-- Gradiente esquerdo para legibilidade do texto -->
    <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(90deg,rgba(0,0,0,0.75) 0%,rgba(0,0,0,0.25) 55%,transparent 100%);"></div>

    <!-- Elementos geométricos flutuantes decorativos -->
    <div class="absolute top-24 right-[12%] w-px h-32 bg-gradient-to-b from-transparent via-primary-container/20 to-transparent animate-float-slow hidden lg:block pointer-events-none"></div>
    <div class="absolute bottom-32 right-[8%] w-16 h-px bg-gradient-to-r from-transparent via-primary-container/15 to-transparent animate-float hidden lg:block pointer-events-none"></div>
    <div class="absolute top-1/3 left-8 w-1.5 h-1.5 rounded-full bg-primary-container/20 animate-pulse-dot hidden lg:block pointer-events-none"></div>
    <div class="absolute top-2/3 left-16 w-1 h-1 rounded-full bg-primary-container/15 animate-pulse-dot hidden lg:block pointer-events-none" style="animation-delay:1s;"></div>

    <!-- Conteúdo principal -->
    <div class="relative z-10 w-full max-w-[1440px] mx-auto px-edge pt-28 pb-16 lg:pt-32 lg:pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[calc(100vh-80px)]">

        <!-- Coluna esquerda: texto + CTAs -->
        <div class="flex flex-col justify-center">
          <!-- Status pill -->
          <div class="flex items-center gap-3 mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse-dot glow-effect flex-shrink-0"></span>
            <span class="text-label-caps text-primary-container uppercase tracking-[0.2em]">
              Sistema Online // Imprimindo Agora
            </span>
          </div>

          <h1 class="text-display-xl font-bold text-white uppercase leading-none tracking-[-0.04em] mb-6 opacity-0 animate-fade-up" style="animation-delay:100ms;animation-fill-mode:forwards;">
            Zero-Error<br/>
            <span style="background:linear-gradient(135deg,#7ce268,#61c54f);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Precision.</span>
          </h1>

          <p class="text-body-lg text-tertiary max-w-lg leading-relaxed mb-10 opacity-0 animate-fade-up" style="animation-delay:250ms;animation-fill-mode:forwards;">
            Manufatura aditiva industrial para aplicações críticas.
            Peças em metal, carbono e polímeros de alta performance —
            tolerância <span class="text-on-surface font-medium">±0.05mm</span>, entregues onde você precisar.
          </p>

          <div class="flex flex-wrap items-center gap-4 opacity-0 animate-fade-up" style="animation-delay:380ms;animation-fill-mode:forwards;">
            <a
              href="/contato"
              class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim hover:shadow-glow-lg transition-all duration-300"
            >
              <span class="material-symbols-outlined text-base leading-none" style="font-variation-settings:'FILL' 1;">rocket_launch</span>
              Solicitar Orçamento
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center gap-2 border border-white/20 text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm hover:border-primary-container/50 hover:text-primary-container transition-all duration-300"
            >
              Ver Portfolio
              <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
            </a>
          </div>

          <!-- Métricas rápidas sob os CTAs -->
          <div class="flex items-center gap-8 mt-12 pt-8 border-t border-white/8 opacity-0 animate-fade-up" style="animation-delay:500ms;animation-fill-mode:forwards;">
            {[
              {value:'+500',label:'Projetos'},
              {value:'20+',label:'Materiais'},
              {value:'±0.05mm',label:'Tolerância'},
            ].map(m => (
              <div class="flex flex-col gap-1">
                <span class="text-2xl font-bold text-white tracking-tighter leading-none">{m.value}</span>
                <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.15em] text-[10px]">{m.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Coluna direita: painel de vídeo/mídia -->
        <div class="hidden lg:flex flex-col gap-4 opacity-0 animate-fade-up" style="animation-delay:300ms;animation-fill-mode:forwards;">
          <!-- VIDEO_HERO: slot de vídeo principal -->
          <div class="relative aspect-video rounded-sm overflow-hidden bg-surface-base border border-white/8 group" style="box-shadow:0 0 60px rgba(0,0,0,0.8),0 0 30px rgba(97,197,79,0.05);">
            <!--
              VIDEO_HERO — Substituir pelo vídeo real da impressora em ação:
              <video class="absolute inset-0 w-full h-full object-cover" autoplay loop muted playsinline>
                <source src="/videos/hero-printing.mp4" type="video/mp4" />
              </video>
            -->
            <div class="absolute inset-0 bg-tech-grid opacity-30"></div>
            <div class="absolute inset-0" style="background:radial-gradient(ellipse at 50% 40%,rgba(97,197,79,0.1) 0%,transparent 65%);"></div>

            <!-- Conteúdo do placeholder -->
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
              <div class="w-16 h-16 rounded-full border border-primary-container/30 flex items-center justify-center bg-black/50 backdrop-blur-sm group-hover:border-primary-container/60 transition-colors duration-300">
                <span class="material-symbols-outlined text-primary-container/70 text-3xl" style="font-variation-settings:'FILL' 1;">play_circle</span>
              </div>
              <div class="text-center">
                <p class="text-label-caps text-primary-container/60 uppercase tracking-[0.2em] text-[10px]">Showreel de Impressão</p>
                <p class="text-label-caps text-white/20 uppercase tracking-[0.15em] text-[9px] mt-1">Vídeo em produção</p>
              </div>
            </div>

            <!-- Corner decorations -->
            <div class="absolute top-3 left-3 w-4 h-4 border-t border-l border-primary-container/40"></div>
            <div class="absolute top-3 right-3 w-4 h-4 border-t border-r border-primary-container/40"></div>
            <div class="absolute bottom-3 left-3 w-4 h-4 border-b border-l border-primary-container/40"></div>
            <div class="absolute bottom-3 right-3 w-4 h-4 border-b border-r border-primary-container/40"></div>

            <!-- Labels sobrepostos -->
            <div class="absolute top-3 left-1/2 -translate-x-1/2">
              <span class="text-label-caps text-primary-container/30 uppercase tracking-widest text-[9px]">VIDEO_HERO</span>
            </div>
            <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/20 to-transparent animate-scan-line"></div>
          </div>

          <!-- Active Build widget — abaixo do vídeo -->
          <div class="glass-panel rounded-sm p-5 w-full" style="border:1px solid rgba(97,197,79,0.12);">
            <div class="flex justify-between items-center mb-4 border-b border-white/8 pb-3">
              <span class="text-label-caps text-tertiary uppercase tracking-widest text-[10px]">Active Build</span>
              <span class="text-label-caps text-primary-container tracking-widest text-[10px]">ID_409X</span>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <div class="flex justify-between text-[11px] text-white/50 mb-1.5">
                  <span class="uppercase tracking-wider">Impressão</span>
                  <span class="text-primary-container font-semibold">80%</span>
                </div>
                <div class="h-px bg-surface-high rounded overflow-hidden">
                  <div class="h-full bg-primary-container glow-effect transition-all duration-1000" style="width:80%;"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-[11px] text-white/50 mb-1.5">
                  <span class="uppercase tracking-wider">Temperatura</span>
                  <span class="text-error font-semibold">265°C</span>
                </div>
                <div class="h-px bg-surface-high rounded overflow-hidden">
                  <div class="h-full bg-error" style="width:95%;"></div>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-container animate-pulse-dot flex-shrink-0"></span>
              <span class="text-[11px] text-tertiary tracking-wide font-mono">PA CF15 · Layer: 0.15mm · Nozzle: 0.4mm</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Indicador de rolagem animado -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10 select-none pointer-events-none">
      <div class="w-5 h-8 border border-white/15 rounded-full flex items-start justify-center pt-1.5">
        <div class="w-0.5 h-1.5 bg-primary-container/60 rounded-full" style="animation:mouseScroll 1.8s ease-in-out infinite;"></div>
      </div>
      <div class="flex flex-col items-center gap-0.5">
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none" style="animation:chevronFade 1.8s ease-in-out infinite;">
          <path d="M1 1L5 5L9 1" stroke="rgba(97,197,79,0.45)" stroke-width="1" stroke-linecap="round"/>
        </svg>
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none" style="animation:chevronFade 1.8s ease-in-out infinite;animation-delay:0.25s;">
          <path d="M1 1L5 5L9 1" stroke="rgba(97,197,79,0.25)" stroke-width="1" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="text-[8px] text-white/20 uppercase tracking-[0.35em] font-light mt-0.5">Rolar</span>
    </div>

    <!-- Transição gradiente hero → próxima seção -->
    <div class="absolute bottom-0 inset-x-0 h-24 pointer-events-none" style="background:linear-gradient(to bottom,transparent,rgba(0,0,0,0.8));"></div>
  </section>

  <!-- =============================================
       TICKER — Especificações em loop
       ============================================= -->
  <div class="bg-surface-dim border-y border-white/5 overflow-hidden py-3 relative">
    <div class="absolute inset-y-0 left-0 w-16 z-10 pointer-events-none" style="background:linear-gradient(90deg,#0e0e0e,transparent);"></div>
    <div class="absolute inset-y-0 right-0 w-16 z-10 pointer-events-none" style="background:linear-gradient(-90deg,#0e0e0e,transparent);"></div>
    <div class="flex animate-marquee whitespace-nowrap gap-0">
      {[
        'PA CF15','PEEK','TPU','Metal 316L','FDM','SLA','SLS',
        '±0.05mm','+500 Projetos','24h Orçamento','São Carlos – SP',
        'PA CF15','PEEK','TPU','Metal 316L','FDM','SLA','SLS',
        '±0.05mm','+500 Projetos','24h Orçamento','São Carlos – SP',
      ].map((item, i) => (
        <span class="inline-flex items-center gap-3 px-6 text-label-caps text-on-surface-variant uppercase tracking-[0.15em] text-[10px]">
          <span class="w-1 h-1 rounded-full bg-primary-container/50 flex-shrink-0"></span>
          {item}
        </span>
      ))}
    </div>
  </div>


  <!-- =============================================
       STATS STRIP
       ============================================= -->
  <div class="border-y border-primary-container/15 bg-surface-dim">
    <div class="max-w-[1440px] mx-auto px-edge py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 md:gap-y-0">
        {[
          {value:'+500',label:'Projetos Entregues',icon:'check_circle'},
          {value:'20+',label:'Materiais Disponíveis',icon:'category'},
          {value:'±0.05mm',label:'Tolerância Dimensional',icon:'precision_manufacturing'},
          {value:'3',label:'Tecnologias de Impressão',icon:'settings_suggest'},
        ].map((s, i) => (
          <div class:list={[
            'flex flex-col items-center md:items-start px-6 md:px-10 py-2 gap-2',
            i < 3 ? 'md:border-r md:border-white/8' : '',
            i % 2 === 0 ? 'border-r border-white/8 md:border-r-0' : '',
          ]}>
            <span class="material-symbols-outlined text-primary-container/40 text-lg" style="font-variation-settings:'FILL' 1;">{s.icon}</span>
            <span class="text-[clamp(28px,4vw,48px)] font-bold tracking-tighter text-white leading-none">{s.value}</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.12em] text-[10px] text-center md:text-left">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>


  <!-- =============================================
       CAPACIDADES — Zigzag com video containers
       ============================================= -->
  <section class="bg-background py-section">
    <div class="max-w-[1440px] mx-auto px-edge">
      <!-- Header da seção -->
      <div class="mb-20 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">01 // Módulos</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Capacidades Core</h2>
        </div>
        <a href="/servicos" class="text-label-caps text-primary-container uppercase tracking-[0.15em] flex items-center gap-2 hover:gap-4 transition-all duration-200 group">
          Todos os Serviços
          <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>

      <div class="divide-y divide-white/5">
        {[
          {
            num:'01',
            title:'Prototipagem Rápida',
            body:'Valide conceitos em horas, não semanas. Processos FDM e SLA entregam protótipos funcionais com geometrias complexas e tolerância dimensional rigorosa para ciclos de iteração acelerados.',
            specs:['FDM / SLA / SLS','Entrega 24–72h','Geometria Complexa'],
            href:'/servicos',
            videoId:'VIDEO_CAP_01',
            videoLabel:'Prototipagem em ação',
            videoFile:'prototipagem.mp4',
            reverse:false,
          },
          {
            num:'02',
            title:'Peças Funcionais & Metal',
            body:'Do projeto à peça final em materiais de engenharia: carbono, nylon de alta temperatura, PEEK e aço inoxidável via BASF Ultrafuse 316L. Componentes para ambientes industriais severos.',
            specs:['Metal 316L','PA CF15 / PEEK','Alta Temperatura'],
            href:'/servicos',
            videoId:'VIDEO_CAP_02',
            videoLabel:'Peça metálica finalizada',
            videoFile:'metal-parts.mp4',
            reverse:true,
          },
          {
            num:'03',
            title:'Modelagem & Engenharia Reversa',
            body:'Transformamos desenhos, esboços e peças físicas em modelos digitais precisos. Scanner 3D para captura de geometrias complexas e otimização DfAM para manufatura aditiva.',
            specs:['CAD Profissional','Scanner 3D','DfAM'],
            href:'/servicos',
            videoId:'VIDEO_CAP_03',
            videoLabel:'Scanner 3D em operação',
            videoFile:'reverse-engineering.mp4',
            reverse:false,
          },
          {
            num:'04',
            title:'Peças de Reposição Sob Demanda',
            body:'Pare de esperar por peças descontinuadas. Fabricamos substitutas em plástico técnico ou metal em prazo reduzido, sem mínimo de quantidade.',
            specs:['Sem Mínimo','Sob Medida','Entrega Ágil'],
            href:'/servicos',
            videoId:'VIDEO_CAP_04',
            videoLabel:'Linha de produção customizada',
            videoFile:'on-demand.mp4',
            reverse:true,
          },
        ].map((item) => (
          <div class:list={['grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center py-20']}>
            <!-- Texto -->
            <div class:list={item.reverse ? 'lg:order-2' : ''}>
              <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">[{item.num}]</span>
              <h3 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-5">{item.title}</h3>
              <p class="text-body-lg text-tertiary leading-relaxed mb-7">{item.body}</p>
              <div class="flex flex-wrap gap-2 mb-8">
                {item.specs.map(s => (
                  <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/40 text-primary-container text-label-caps uppercase tracking-widest">{s}</span>
                ))}
              </div>
              <a href={item.href} class="inline-flex items-center gap-2 text-label-caps text-primary-container uppercase tracking-[0.15em] hover:gap-4 transition-all duration-200 group">
                Saiba mais
                <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </a>
            </div>

            <!-- Video container -->
            <div class:list={item.reverse ? 'lg:order-1' : ''}>
              <div class="relative aspect-square max-w-md mx-auto rounded-sm overflow-hidden bg-surface-base border border-white/8 group/media" style="box-shadow:0 20px 60px rgba(0,0,0,0.6);">
                <!--
                  {item.videoId} — substituir pelo vídeo real:
                  <video class="absolute inset-0 w-full h-full object-cover" autoplay loop muted playsinline>
                    <source src={`/videos/${item.videoFile}`} type="video/mp4" />
                  </video>
                -->
                <div class="absolute inset-0 bg-tech-grid opacity-40"></div>
                <div class="absolute inset-0" style={`background:radial-gradient(circle at 50% 50%,rgba(97,197,79,0.07) 0%,transparent 65%);`}></div>

                <!-- Número grande decorativo -->
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
                  <span class="text-[120px] font-black text-white/[0.03] leading-none tracking-tighter">{item.num}</span>
                </div>

                <!-- Play button -->
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-14 h-14 rounded-full border border-primary-container/25 flex items-center justify-center bg-black/30 backdrop-blur-sm group-hover/media:border-primary-container/50 group-hover/media:bg-black/50 transition-all duration-300">
                    <span class="material-symbols-outlined text-primary-container/50 text-2xl group-hover/media:text-primary-container/80 transition-colors duration-300" style="font-variation-settings:'FILL' 1;">play_arrow</span>
                  </div>
                </div>

                <!-- Scan line animation -->
                <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/25 to-transparent animate-scan-line"></div>

                <!-- Labels -->
                <div class="absolute top-4 right-4 text-label-caps text-primary-container/30 text-[10px] tracking-widest uppercase font-mono">{item.videoId}</div>
                <div class="absolute bottom-4 left-4">
                  <span class="pill-green text-[10px]">{item.specs[0]}</span>
                </div>
                <div class="absolute bottom-4 right-4 text-label-caps text-white/20 text-[9px] tracking-widest">{item.videoLabel}</div>

                <!-- Corner brackets -->
                <div class="absolute top-3 left-3 w-3 h-3 border-t border-l border-primary-container/30"></div>
                <div class="absolute top-3 right-3 w-3 h-3 border-t border-r border-primary-container/30"></div>
                <div class="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-primary-container/30"></div>
                <div class="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-primary-container/30"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- =============================================
       DIFERENCIAIS — Grid de cards
       ============================================= -->
  <section class="bg-surface-low py-section section-glow-top relative overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-edge">
      <div class="mb-16 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">02 // Diferenciais</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Por que AUMAF 3D</h2>
        </div>
        <p class="text-body-md text-tertiary max-w-sm leading-relaxed">Precisão industrial, entrega ágil e parceria técnica em cada projeto.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {[
          {icon:'precision_manufacturing',num:'01',title:'Precisão Certificada',body:'±0.05mm em FDM industrial. Peças dimensionalmente consistentes entre lotes, rastreáveis por projeto.',tag:'QUALIDADE',stagger:'stagger-1'},
          {icon:'category',num:'02',title:'Portfólio de Materiais',body:'20+ materiais: PA CF15, PEEK, TPU, ABS, Policarbonato, Resina e BASF Ultrafuse 316L (aço inoxidável).',tag:'MATERIAIS',stagger:'stagger-2'},
          {icon:'tune',num:'03',title:'Feito Sob Medida',body:'Personalização total de geometria, material e acabamento. Sem mínimo de produção para projetos unitários.',tag:'FLEXIBILIDADE',stagger:'stagger-3'},
          {icon:'support_agent',num:'04',title:'Consultoria Técnica',body:'Equipe especializada indica tecnologia, material e processo ideal. Suporte do arquivo à entrega final.',tag:'SUPORTE',stagger:'stagger-4'},
          {icon:'location_on',num:'05',title:'Hub de Inovação',body:'Parque Tecnológico Damha II, São Carlos – SP. Polo tecnológico próximo à USP e UFSCar.',tag:'SÃO CARLOS',stagger:'stagger-5'},
          {icon:'local_shipping',num:'06',title:'Entrega Ágil',body:'Orçamento em até 24h, produção ágil, atendimento nacional com prazo definido desde o primeiro contato.',tag:'LOGÍSTICA',stagger:'stagger-6'},
        ].map(card => (
          <div class:list={['glass-panel p-8 rounded-sm group hover:-translate-y-1 hover:border-primary-container/15 transition-all duration-300 reveal-hidden', card.stagger]} data-animate>
            <div class="flex justify-between items-start mb-6">
              <div class="w-10 h-10 rounded-sm bg-primary-container/10 border border-primary-container/20 flex items-center justify-center group-hover:bg-primary-container/15 transition-colors duration-300">
                <span class="material-symbols-outlined text-primary-container text-xl" style="font-variation-settings:'FILL' 1;">{card.icon}</span>
              </div>
              <span class="text-code-data text-white/10 font-bold font-mono">[{card.num}]</span>
            </div>
            <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/30 text-primary-container text-label-caps uppercase tracking-widest mb-4 text-[10px]">{card.tag}</span>
            <h3 class="text-headline-md font-semibold uppercase text-white mb-3 tracking-[0.01em]">{card.title}</h3>
            <p class="text-body-md text-tertiary leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- =============================================
       TECNOLOGIAS DISPONÍVEIS

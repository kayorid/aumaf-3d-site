---
export const prerender = true
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import ReviewsHomeWidget from '../components/reviews/ReviewsHomeWidget.astro'
import { COMPANY } from '../lib/company'
import { itemListSchema } from '../lib/schemas'
import { fetchPublicPosts } from '../lib/api'
import { resolveCoverImage } from '../lib/blog-defaults'
import { formatPostDateShort } from '../lib/render-post'

let allPosts: Awaited<ReturnType<typeof fetchPublicPosts>>['data'] = []
try {
  const res = await fetchPublicPosts({ pageSize: 12 })
  allPosts = res.data
} catch (err) {
  console.warn('[home] fetchPublicPosts falhou, usando fallback estático:', (err as Error).message)
}
const featuredPost = allPosts.find((p) => p.featured) ?? allPosts[0] ?? null
const otherPosts = allPosts.filter((p) => p.slug !== featuredPost?.slug).slice(0, 3)

const description = 'AUMAF 3D — manufatura aditiva industrial em São Carlos, SP. Impressão 3D em metal 316L, polímeros (PEEK, PA, PET-G CF15) e resina, com tolerância ±0.05mm. +500 projetos entregues, orçamento em até 24h.'

const homeSchemas = [
  itemListSchema([
    { name: 'Prototipagem Rápida', url: `${COMPANY.url}/servicos#prototipagem` },
    { name: 'Peças Funcionais & Metal', url: `${COMPANY.url}/servicos#funcionais` },
    { name: 'Modelagem 3D & DfAM', url: `${COMPANY.url}/servicos#modelagem` },
    { name: 'Engenharia Reversa', url: `${COMPANY.url}/servicos#reposicao` },
  ]),
]
---

<Base title="Impressão 3D Industrial em São Carlos | AUMAF 3D" description={description} schemas={homeSchemas}>
  <Navbar currentPath="/" />

  <!-- =============================================
       HERO — 2 colunas: conteúdo + painel de mídia
       ============================================= -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-background">
    <!-- Background AI: hexmesh neon (cobre toda a viewport, atrás dos overlays) -->
    <img
      src="/images/hero-bg-hexmesh.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-55 pointer-events-none"
      width="1584"
      height="672"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Textura circuit + grid combinados (preservados sobre o background) -->
    <div class="absolute inset-0 bg-tech-grid pointer-events-none opacity-25 mix-blend-overlay"></div>
    <div class="absolute inset-0 bg-circuit pointer-events-none opacity-40 mix-blend-overlay"></div>

    <!-- Glow 1: halo central difuso (intensificado) -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 60% at 65% 50%,rgba(97,197,79,0.11) 0%,transparent 65%);"></div>

    <!-- Glow 2: halo quente canto superior direito -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 40% 40% at 92% 8%,rgba(97,197,79,0.07) 0%,transparent 70%);"></div>

    <!-- Glow 3: reflexo inferior esquerdo -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 30% 25% at 4% 96%,rgba(97,197,79,0.05) 0%,transparent 70%);"></div>

    <!-- Orb focal brilhante — alinhado ao painel de vídeo -->
    <div class="absolute hidden lg:block pointer-events-none" style="top:30%;right:8%;width:360px;height:360px;background:radial-gradient(circle,rgba(97,197,79,0.16) 0%,rgba(97,197,79,0.06) 35%,transparent 70%);filter:blur(2px);border-radius:50%;"></div>

    <!-- Gradiente esquerdo para legibilidade do texto -->
    <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(90deg,rgba(0,0,0,0.78) 0%,rgba(0,0,0,0.25) 55%,transparent 100%);"></div>

    <!-- Linhas flutuantes decorativas -->
    <div class="absolute top-24 right-[12%] w-px h-36 bg-gradient-to-b from-transparent via-primary-container/30 to-transparent animate-float-slow hidden lg:block pointer-events-none" style="box-shadow:0 0 4px rgba(97,197,79,0.3);"></div>
    <div class="absolute bottom-32 right-[8%] w-20 h-px bg-gradient-to-r from-transparent via-primary-container/25 to-transparent animate-float hidden lg:block pointer-events-none" style="box-shadow:0 0 4px rgba(97,197,79,0.2);"></div>
    <div class="absolute top-1/3 left-8 w-2 h-2 rounded-full bg-primary-container/30 animate-pulse-dot dot-glow hidden lg:block pointer-events-none"></div>
    <div class="absolute top-2/3 left-16 w-1.5 h-1.5 rounded-full bg-primary-container/20 animate-pulse-dot hidden lg:block pointer-events-none" style="animation-delay:1.2s;box-shadow:0 0 6px rgba(97,197,79,0.4);"></div>
    <div class="absolute top-1/2 right-[52%] w-1 h-1 rounded-full bg-primary-container/15 animate-pulse-dot hidden lg:block pointer-events-none" style="animation-delay:2.1s;"></div>

    <!-- Conteúdo principal -->
    <div class="relative z-10 w-full max-w-[1600px] mx-auto px-edge pt-28 pb-16 lg:pt-32 lg:pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[calc(100vh-80px)]">

        <!-- Coluna esquerda: texto + CTAs -->
        <div class="flex flex-col justify-center">
          <!-- Status pill -->
          <div class="flex items-center gap-3 mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse-dot dot-glow flex-shrink-0"></span>
            <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em]">
              Sistema Online // Imprimindo Agora
            </span>
          </div>

          <h1 class="text-display-xl font-bold text-white text-glow-white uppercase leading-none tracking-[-0.04em] mb-6 opacity-0 animate-fade-up" style="animation-delay:100ms;animation-fill-mode:forwards;">
            Tolerância Zero.<br/>
            <span class="text-gradient-glow">Precisão Total.</span>
          </h1>

          <p class="text-body-lg text-tertiary max-w-lg leading-relaxed mb-10 opacity-0 animate-fade-up" style="animation-delay:250ms;animation-fill-mode:forwards;">
            Manufatura aditiva industrial para aplicações críticas.
            Peças em metal, carbono e polímeros de alta performance —
            tolerância <span class="text-on-surface font-medium">±0.05mm</span>, entregues onde você precisar.
          </p>

          <div class="flex flex-wrap items-center gap-4 opacity-0 animate-fade-up" style="animation-delay:380ms;animation-fill-mode:forwards;">
            <a
              href="/contato"
              class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim hover:shadow-glow-lg transition-all duration-300"
            >
              <span class="material-symbols-outlined text-base leading-none" style="font-variation-settings:'FILL' 1;">rocket_launch</span>
              Solicitar Orçamento
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center gap-2 border border-white/20 text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm hover:border-primary-container/50 hover:text-primary-container transition-all duration-300"
            >
              Ver Portfolio
              <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
            </a>
          </div>

          <!-- Métricas rápidas sob os CTAs -->
          <div class="flex items-center gap-8 mt-12 pt-8 opacity-0 animate-fade-up relative" style="animation-delay:500ms;animation-fill-mode:forwards;">
            <div class="line-glow-bright absolute top-0 left-0 right-0"></div>
            {[
              {value:'+500',label:'Projetos'},
              {value:'20+',label:'Materiais'},
              {value:'±0.05mm',label:'Tolerância'},
            ].map(m => (
              <div class="flex flex-col gap-1">
                <span class="text-2xl font-bold text-white tracking-tighter leading-none">{m.value}</span>
                <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.15em] text-[10px]">{m.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Coluna direita: painel de vídeo/mídia -->
        <div class="hidden lg:flex flex-col gap-4 opacity-0 animate-fade-up" style="animation-delay:300ms;animation-fill-mode:forwards;">
          <!-- IMAGE_HERO: imagem principal — impressora AUMAF 3D -->
          <div class="relative aspect-video rounded-sm overflow-hidden bg-surface-base border border-white/8 group" style="box-shadow:0 0 60px rgba(0,0,0,0.8),0 0 30px rgba(97,197,79,0.05);">
            <img
              src="/images/hero-aumaf-printer.webp"
              alt="Impressora 3D industrial AUMAF 3D imprimindo engrenagem metálica — extrusor com glow verde, ambiente cinematográfico"
              class="absolute inset-0 w-full h-full object-cover"
              width="1920"
              height="1072"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            <div class="absolute inset-0 bg-tech-grid opacity-20 mix-blend-overlay"></div>
            <div class="absolute inset-0" style="background:radial-gradient(ellipse at 50% 40%,rgba(97,197,79,0.08) 0%,transparent 65%),linear-gradient(180deg,rgba(0,0,0,0.15) 0%,rgba(0,0,0,0.45) 100%);"></div>

            <!-- Corner decorations -->
            <div class="absolute top-3 left-3 w-4 h-4 border-t border-l border-primary-container/40"></div>
            <div class="absolute top-3 right-3 w-4 h-4 border-t border-r border-primary-container/40"></div>
            <div class="absolute bottom-3 left-3 w-4 h-4 border-b border-l border-primary-container/40"></div>
            <div class="absolute bottom-3 right-3 w-4 h-4 border-b border-r border-primary-container/40"></div>

            <!-- Labels sobrepostos -->
            <div class="absolute top-3 left-1/2 -translate-x-1/2">
              <span class="text-label-caps text-primary-container/30 uppercase tracking-widest text-[9px]">AUMAF_3D // CORE_UNIT</span>
            </div>
            <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/20 to-transparent animate-scan-line"></div>
          </div>

          <!-- Active Build widget — abaixo do vídeo -->
          <div class="glass-panel rounded-sm p-5 w-full" style="border:1px solid rgba(97,197,79,0.12);">
            <div class="flex justify-between items-center mb-4 border-b border-white/8 pb-3">
              <span class="text-label-caps text-tertiary uppercase tracking-widest text-[10px]">Active Build</span>
              <span class="text-label-caps text-primary-container tracking-widest text-[10px]">ID_409X</span>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <div class="flex justify-between text-[11px] text-tertiary mb-1.5">
                  <span class="uppercase tracking-wider">Impressão</span>
                  <span class="text-primary-container font-semibold">80%</span>
                </div>
                <div class="h-px bg-surface-high rounded overflow-hidden">
                  <div class="h-full bg-primary-container glow-effect transition-all duration-1000" style="width:80%;"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-[11px] text-tertiary mb-1.5">
                  <span class="uppercase tracking-wider">Temperatura</span>
                  <span class="text-error font-semibold">265°C</span>
                </div>
                <div class="h-px bg-surface-high rounded overflow-hidden">
                  <div class="h-full bg-error" style="width:95%;"></div>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-container animate-pulse-dot flex-shrink-0"></span>
              <span class="text-[11px] text-tertiary tracking-wide font-mono">PA CF15 · Layer: 0.15mm · Nozzle: 0.4mm</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Indicador de rolagem animado -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10 select-none pointer-events-none">
      <div class="w-5 h-8 border border-white/15 rounded-full flex items-start justify-center pt-1.5">
        <div class="w-0.5 h-1.5 bg-primary-container/60 rounded-full" style="animation:mouseScroll 1.8s ease-in-out infinite;"></div>
      </div>
      <div class="flex flex-col items-center gap-0.5">
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none" style="animation:chevronFade 1.8s ease-in-out infinite;">
          <path d="M1 1L5 5L9 1" stroke="rgba(97,197,79,0.45)" stroke-width="1" stroke-linecap="round"/>
        </svg>
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none" style="animation:chevronFade 1.8s ease-in-out infinite;animation-delay:0.25s;">
          <path d="M1 1L5 5L9 1" stroke="rgba(97,197,79,0.25)" stroke-width="1" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="text-[10px] text-on-surface-variant uppercase tracking-[0.35em] font-light mt-0.5">Rolar</span>
    </div>

    <!-- Transição gradiente hero → próxima seção -->
    <div class="absolute bottom-0 inset-x-0 h-24 pointer-events-none" style="background:linear-gradient(to bottom,transparent,rgba(0,0,0,0.8));"></div>
  </section>

  <!-- =============================================
       TICKER — Especificações em loop
       ============================================= -->
  <div class="bg-surface-dim border-y border-white/5 overflow-hidden py-3 relative">
    <div class="absolute inset-y-0 left-0 w-16 z-10 pointer-events-none" style="background:linear-gradient(90deg,#0e0e0e,transparent);"></div>
    <div class="absolute inset-y-0 right-0 w-16 z-10 pointer-events-none" style="background:linear-gradient(-90deg,#0e0e0e,transparent);"></div>
    <div class="flex animate-marquee whitespace-nowrap gap-0">
      {[
        'PA CF15','PEEK','TPU','Metal 316L','FDM','SLA','SLS',
        '±0.05mm','+500 Projetos','24h Orçamento','São Carlos – SP',
        'PA CF15','PEEK','TPU','Metal 316L','FDM','SLA','SLS',
        '±0.05mm','+500 Projetos','24h Orçamento','São Carlos – SP',
      ].map((item) => (
        <span class="inline-flex items-center gap-3 px-6 text-label-caps text-on-surface-variant uppercase tracking-[0.15em] text-[10px]">
          <span class="w-1 h-1 rounded-full bg-primary-container/50 flex-shrink-0" aria-hidden="true"></span>
          {item}
        </span>
      ))}
    </div>
  </div>


  <!-- =============================================
       STATS STRIP
       ============================================= -->
  <div class="border-y border-primary-container/15 bg-surface-dim">
    <div class="max-w-[1600px] mx-auto px-edge py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 md:gap-y-0">
        {[
          {value:'+500',label:'Projetos Entregues',icon:'check_circle'},
          {value:'20+',label:'Materiais Disponíveis',icon:'category'},
          {value:'±0.05mm',label:'Tolerância Dimensional',icon:'precision_manufacturing'},
          {value:'3',label:'Tecnologias de Impressão',icon:'settings_suggest'},
        ].map((s, i) => (
          <div class:list={[
            'flex flex-col items-center md:items-start px-6 md:px-10 py-2 gap-2',
            i < 3 ? 'md:border-r md:border-white/8' : '',
            i % 2 === 0 ? 'border-r border-white/8 md:border-r-0' : '',
          ]}>
            <span class="material-symbols-outlined text-primary-container/40 text-lg" style="font-variation-settings:'FILL' 1;">{s.icon}</span>
            <span class="text-[clamp(28px,4vw,48px)] font-bold tracking-tighter text-white leading-none">{s.value}</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.12em] text-[10px] text-center md:text-left">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>


  <!-- =============================================
       PROVA REAL — Contadores animados + Depoimento
       ============================================= -->
  <section class="bg-surface-dim py-section relative overflow-hidden" id="prova-real">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(97,197,79,0.05) 0%,transparent 70%);"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-container/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-container/20 to-transparent"></div>

    <div class="max-w-[1600px] mx-auto px-edge">
      <div class="mb-16 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">00 // Credenciais</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">
            Prova Real.<br/>
            <span class="text-on-surface-variant font-light">Números que não mentem.</span>
          </h2>
        </div>
        <p class="text-body-md text-tertiary max-w-sm leading-relaxed">Cada número abaixo representa um projeto real, um cliente satisfeito, uma peça que funcionou.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Contadores animados -->
        <div class="grid grid-cols-2 gap-4">
          {[
            {id:'cnt-projetos',   target:500,  suffix:'+', label:'Projetos Entregues',    sub:'desde 2022',            icon:'inventory_2'},
            {id:'cnt-prazo',      target:99,   suffix:'%', label:'Taxa de Aprovação',     sub:'no primeiro lote',      icon:'verified'},
            {id:'cnt-materiais',  target:20,   suffix:'+', label:'Materiais no Catálogo', sub:'termoplásticos + metal', icon:'science'},
            {id:'cnt-tolerancia', target:0.05, suffix:'mm',label:'Tolerância Dimensional',sub:'±0.05mm garantida',     icon:'precision_manufacturing'},
          ].map(c => (
            <div class="glass-panel p-6 lg:p-8 rounded-sm border border-white/6 hover:border-primary-container/20 transition-all duration-300 group">
              <div class="w-9 h-9 rounded-sm bg-primary-container/10 border border-primary-container/20 flex items-center justify-center mb-5 group-hover:bg-primary-container/15 transition-colors duration-300">
                <span class="material-symbols-outlined text-primary-container text-lg" style="font-variation-settings:'FILL' 1;">{c.icon}</span>
              </div>
              <div class="flex items-end gap-1 mb-1">
                {c.id === 'cnt-tolerancia' && <span class="text-[clamp(20px,3vw,32px)] font-bold text-white tracking-tighter leading-none">±</span>}
                <span
                  class="text-[clamp(28px,4vw,48px)] font-black text-white tracking-tighter leading-none tabular-nums"
                  data-counter
                  data-target={c.target}
                  data-decimals={c.id === 'cnt-tolerancia' ? '2' : '0'}
                >0</span>
                <span class="text-[clamp(14px,2vw,22px)] font-bold text-primary-container leading-none mb-1">{c.suffix}</span>
              </div>
              <p class="text-label-caps text-on-surface uppercase tracking-[0.12em] text-[11px] mb-1">{c.label}</p>
              <p class="text-[11px] text-tertiary tracking-wide">{c.sub}</p>
            </div>
          ))}
        </div>

        <!-- Depoimento destaque + case -->
        <div class="flex flex-col gap-4">
          <div class="glass-panel p-8 lg:p-10 rounded-sm relative overflow-hidden" style="border:1px solid rgba(97,197,79,0.10);">
            <div class="absolute top-4 right-6 text-[80px] leading-none font-serif text-primary-container/8 select-none pointer-events-none">"</div>
            <div class="flex gap-1 mb-5">
              {Array(5).fill(0).map(() => (
                <span class="material-symbols-outlined text-primary-container text-base" style="font-variation-settings:'FILL' 1;">star</span>
              ))}
            </div>
            <blockquote class="text-body-lg text-on-surface leading-relaxed mb-7 relative z-10">
              "Peças impressas com rapidez, personalização e muita precisão. Usamos a AUMAF 3D como fornecedora de componentes para máquinas e robôs. <span class="text-primary-container font-medium">Impressionante!</span>"
            </blockquote>
            <div class="flex items-center gap-4">
              <img
                src="/images/raissa-ninelli.avif"
                alt="Foto de Raissa Ninelli, Diretora da Fugini Alimentos"
                width="44"
                height="44"
                loading="lazy"
                decoding="async"
                class="w-11 h-11 rounded-full border border-primary-container/30 object-cover flex-shrink-0"
              />
              <div>
                <p class="text-label-caps text-primary-container uppercase tracking-[0.15em] font-bold">Raissa Ninelli</p>
                <p class="text-sm text-tertiary mt-0.5">Diretora · <span class="text-on-surface-variant">Fugini Alimentos</span></p>
              </div>
              <div class="ml-auto">
                <span class="pill-green text-[9px]">Verificado</span>
              </div>
            </div>
          </div>

          <a href="/blog/formula-sae-case-study-completo" class="glass-panel p-6 rounded-sm flex items-start gap-5 hover:border-primary-container/20 transition-all duration-300 group border border-white/6">
            <div class="w-12 h-12 rounded-sm bg-primary-container/10 border border-primary-container/20 flex items-center justify-center flex-shrink-0 group-hover:bg-primary-container/20 transition-colors duration-300">
              <span class="material-symbols-outlined text-primary-container text-2xl" style="font-variation-settings:'FILL' 1;">sports_score</span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="pill-green text-[9px]">Case Study</span>
                <span class="text-[10px] text-tertiary">USP São Carlos</span>
              </div>
              <p class="text-body-md text-on-surface font-medium leading-snug mb-1 group-hover:text-white transition-colors duration-200">Fórmula SAE 2024 — Componentes de Alta Performance</p>
              <p class="text-sm text-tertiary leading-relaxed">Nylon PA + PET-G CF15 para suspensão e aerodinâmica. Entregue em 5 dias, aprovado sem retrabalho.</p>
            </div>
            <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary-container transition-colors duration-200 mt-1 flex-shrink-0" aria-hidden="true">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- =============================================
       CAPACIDADES — Zigzag com video containers
       ============================================= -->
  <section class="bg-background py-section">
    <div class="max-w-[1600px] mx-auto px-edge">
      <!-- Header da seção -->
      <div class="mb-20 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">01 // Módulos</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Capacidades Core</h2>
        </div>
        <a href="/servicos" class="text-label-caps text-primary-container uppercase tracking-[0.15em] flex items-center gap-2 hover:gap-4 transition-all duration-200 group">
          Todos os Serviços
          <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>

      <div class="divide-y divide-white/5">
        {[
          {
            num:'01',
            title:'Prototipagem Rápida',
            body:'Valide conceitos em horas, não semanas. Processos FDM e SLA entregam protótipos funcionais com geometrias complexas e tolerância dimensional rigorosa para ciclos de iteração acelerados.',
            specs:['FDM / SLA / SLS','Entrega 24–72h','Geometria Complexa'],
            href:'/servicos',

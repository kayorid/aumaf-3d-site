---
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { COMPANY } from '../lib/company'
import { serviceSchema, howToSchema, itemListSchema } from '../lib/schemas'

const services = [
  {
    id: 'prototipagem',
    num: '01',
    title: 'Prototipagem Rápida',
    body: 'Reduza o ciclo de desenvolvimento com protótipos funcionais entregues em dias. Ideal para validação de forma, encaixe e montagem antes da produção em série. Tecnologias FDM, SLA e SLS disponíveis conforme o nível de detalhe e material necessário.',
    specs: ['FDM / SLA / SLS', 'Entrega 24–72h', 'Geometria Complexa', 'Sem Molde'],
    details: [
      { label: 'Prazo típico', value: '24–72h' },
      { label: 'Materiais', value: 'PLA, ABS, PETG, Resina' },
      { label: 'Tolerância', value: '±0.1mm (FDM) / ±0.05mm (SLA)' },
      { label: 'Aplicação', value: 'Validação de conceito' },
    ],
    reverse: false,
  },
  {
    id: 'funcionais',
    num: '02',
    title: 'Peças Funcionais & Metal',
    body: 'Peças de reposição para máquinas, componentes para robôs e equipamentos industriais. Fabricadas sob demanda em plásticos de alta performance ou aço inoxidável via sinterização BASF Ultrafuse 316L. Sem molde, sem mínimo de quantidade.',
    specs: ['Metal 316L', 'PA CF15 / PEEK / Ultem', 'Alta Temperatura', '+260°C'],
    details: [
      { label: 'Prazo típico', value: '3–7 dias úteis' },
      { label: 'Metal prazo', value: '15–20 dias (sinterização)' },
      { label: 'Tolerância', value: '±0.05mm' },
      { label: 'Aplicação', value: 'Uso final industrial' },
    ],
    reverse: true,
  },
  {
    id: 'modelagem',
    num: '03',
    title: 'Modelagem 3D & Otimização DfAM',
    body: 'Nossa equipe converte desenhos técnicos, esboços ou especificações verbais em modelos 3D prontos para impressão, com otimização para manufatura aditiva (DfAM). Entregamos arquivos .STL, .STEP e .OBJ validados e prontos para produção.',
    specs: ['CAD Profissional', 'DfAM', 'Análise de Topologia', 'STEP / STL / OBJ'],
    details: [
      { label: 'Entregável', value: '.STL / .STEP / .OBJ' },
      { label: 'Prazo', value: 'Sob consulta' },
      { label: 'Inclui', value: 'Análise de impressibilidade' },
      { label: 'Aplicação', value: 'Projeto do zero ou conversão' },
    ],
    reverse: false,
  },
  {
    id: 'reposicao',
    num: '04',
    title: 'Engenharia Reversa (Scanner 3D)',
    body: 'Capturamos peças físicas existentes com scanner 3D de alta resolução e geramos o modelo digital para replicação exata ou modificação de design. Ideal para peças descontinuadas pelo fabricante original ou componentes orgânicos complexos.',
    specs: ['Scanner 3D', 'Engenharia Reversa', 'Nuvem de Pontos', 'Réplica Exata'],
    details: [
      { label: 'Tecnologia', value: 'Scanner portátil HD' },
      { label: 'Precisão', value: '±0.02mm na captura' },
      { label: 'Entregável', value: 'Modelo 3D + arquivo pronto' },
      { label: 'Aplicação', value: 'Peças descontinuadas / orgânicas' },
    ],
    reverse: true,
  },
]

const processSteps = [
  { n: '01', title: 'Envio do Arquivo', body: 'Envie .STL, .OBJ, .STEP ou descreva o projeto.' },
  { n: '02', title: 'Análise Técnica', body: 'Revisamos viabilidade, material e processo.' },
  { n: '03', title: 'Orçamento', body: 'Retornamos em até 24h com valor e prazo.' },
  { n: '04', title: 'Produção', body: 'Impressão com monitoramento em tempo real.' },
  { n: '05', title: 'Controle de Qualidade', body: 'Verificação dimensional antes do envio.' },
  { n: '06', title: 'Entrega & Suporte', body: 'Envio nacional + suporte técnico pós-entrega.' },
]

const description = 'Serviços de impressão 3D industrial AUMAF 3D: prototipagem rápida (24–72h), peças funcionais em metal 316L e polímeros (PEEK, PA CF15), modelagem 3D, engenharia reversa. Tolerância ±0.05mm. São Carlos – SP.'

const schemas = [
  ...services.map((s) =>
    serviceSchema({
      name: s.title,
      description: s.body,
      url: `${COMPANY.url}/servicos#${s.id}`,
      serviceType: s.title,
    }),
  ),
  howToSchema({
    name: 'Como funciona o processo de impressão 3D na AUMAF 3D',
    description: 'Passo a passo do envio do arquivo até a entrega da peça impressa.',
    steps: processSteps.map((s) => ({ name: `${s.n}. ${s.title}`, text: s.body })),
  }),
  itemListSchema(services.map((s) => ({ name: s.title, url: `${COMPANY.url}/servicos#${s.id}`, description: s.body }))),
]
---

<Base
  title="Serviços de Impressão 3D Industrial"
  description={description}
  breadcrumb={[{ name: 'Serviços', url: '/servicos' }]}
  schemas={schemas}
>
  <Navbar currentPath="/servicos" />

  <!-- Hero Institucional (coffee-tech style: assimétrico) -->
  <section class="min-h-[60vh] flex items-end bg-background pt-28 pb-20 relative overflow-hidden" aria-labelledby="hero-servicos">
    <div class="absolute inset-0 bg-tech-grid opacity-40 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 70% 50% at 85% 15%,rgba(97,197,79,0.07) 0%,transparent 60%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 40% 40% at 10% 80%,rgba(97,197,79,0.04) 0%,transparent 65%);"></div>
    <div class="absolute bottom-0 inset-x-0 h-16 pointer-events-none" aria-hidden="true" style="background:linear-gradient(to bottom,transparent,rgba(0,0,0,0.5));"></div>

    <div class="max-w-[1600px] mx-auto px-edge w-full relative z-10">
      <Breadcrumb items={[{ name: 'Serviços' }]} compact />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-end">
        <div>
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-4">Sistemas // Capacidades</span>
          <h1 id="hero-servicos" class="text-display-xl font-bold uppercase text-white tracking-[-0.04em] leading-none">
            Soluções de<br/>Manufatura<br/>Aditiva.
          </h1>
        </div>
        <div class="md:pb-2">
          <p class="text-body-lg text-tertiary leading-relaxed max-w-md">
            Engenharia aditiva completa: do arquivo digital à peça funcional. <strong class="text-on-surface">Quatro serviços integrados</strong> para cada fase do desenvolvimento de produto, com tolerância de até <strong class="text-on-surface">±0.05mm</strong>.
          </p>
          <div class="flex items-center gap-3 mt-8">
            <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse-dot glow-effect" aria-hidden="true"></span>
            <span class="text-label-caps text-primary-container uppercase tracking-[0.2em]">Orçamento em até 24h</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Separator -->
  <div class="border-t border-white/5" aria-hidden="true"></div>

  <!-- Serviços Zigzag -->
  <section class="bg-background py-section" aria-labelledby="servicos-list">
    <h2 id="servicos-list" class="sr-only">Lista de serviços</h2>
    <div class="max-w-[1600px] mx-auto px-edge divide-y divide-white/5">
      {services.map((service, i) => (
        <article id={service.id} data-animate class:list={['grid grid-cols-1 lg:grid-cols-2 gap-16 items-start py-20 reveal-hidden', `stagger-${i + 1}`]} aria-labelledby={`svc-${service.id}-title`}>
          <div class:list={service.reverse ? 'lg:order-2' : ''}>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">[{service.num}]</span>
            <h3 id={`svc-${service.id}-title`} class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-5">{service.title}</h3>
            <p class="text-body-lg text-tertiary leading-relaxed mb-6">{service.body}</p>
            <ul role="list" class="flex flex-wrap gap-2 mb-8">
              {service.specs.map((s) => (
                <li class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest">
                  {s}
                </li>
              ))}
            </ul>
            <a
              href="/contato"
              class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300"
            >
              Solicitar orçamento de {service.title.toLowerCase()}
              <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
          <div class:list={service.reverse ? 'lg:order-1' : ''}>
            <dl class="glass-panel card-hover-glow p-8 rounded-sm border border-white/8 grid grid-cols-2 gap-4">
              {service.details.map((d) => (
                <div class="border-b border-white/8 pb-4">
                  <dt class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-1">{d.label}</dt>
                  <dd class="text-body-md text-on-surface font-medium">{d.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Como Funciona -->
  <section class="bg-surface-low py-section" aria-labelledby="como-funciona">
    <div class="max-w-[1600px] mx-auto px-edge">
      <header class="mb-16 border-b border-white/8 pb-10">
        <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">Processo</span>
        <h2 id="como-funciona" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Como Funciona</h2>
        <p class="text-body-md text-tertiary mt-4 max-w-2xl">
          Do envio do arquivo à entrega da peça final: 6 etapas controladas com prazo definido em até 24 horas após análise técnica.
        </p>
      </header>
      <ol class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {processSteps.map((step, i) => (
          <li data-animate class:list={['glass-panel card-hover-glow p-6 relative rounded-sm group hover:border-primary-container/20 transition-all duration-300 reveal-hidden list-none', `stagger-${i + 1}`]}>
            <span class="text-[32px] font-black text-white/[0.06] leading-none block mb-3" aria-hidden="true">{step.n}</span>
            <span class="text-label-caps text-primary-container uppercase tracking-widest block mb-2">Etapa {step.n}</span>
            <h3 class="text-body-md font-semibold text-white uppercase mb-2 tracking-[0.02em]">{step.title}</h3>
            <p class="text-sm text-tertiary leading-relaxed">{step.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-background border-t border-primary-container/20 py-section" aria-labelledby="cta-servicos">
    <div class="max-w-[1600px] mx-auto px-edge text-center">
      <h2 id="cta-servicos" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-4">Inicie seu Projeto Agora</h2>
      <p class="text-body-lg text-tertiary mb-8 max-w-md mx-auto">Envie seu arquivo ou descreva o projeto. Orçamento em até 24 horas.</p>
      <a href="/contato" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-10 py-5 rounded-sm glow-effect-lg hover:bg-primary-dim transition-all duration-300">
        <span class="material-symbols-outlined text-base" aria-hidden="true" style="font-variation-settings:'FILL' 1;">upload_file</span>
        Solicitar orçamento
      </a>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('reveal-visible')
          observer.unobserve(e.target)
        }
      })
    },
    { threshold: 0.08, rootMargin: '0px 0px -50px 0px' },
  )
  document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el))
</script>

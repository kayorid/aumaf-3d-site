---
export const prerender = true
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import SectionSeparator from '../components/SectionSeparator.astro'
import { COMPANY } from '../lib/company'
import { serviceSchema, howToSchema, itemListSchema } from '../lib/schemas'

const services = [
  {
    id: 'prototipagem',
    num: '01',
    title: 'Prototipagem Rápida',
    body: 'Reduza o ciclo de desenvolvimento com protótipos funcionais entregues em dias. Ideal para validação de forma, encaixe e montagem antes da produção em série. Tecnologias FDM, SLA e SLS disponíveis conforme o nível de detalhe e material necessário.',
    specs: ['FDM / SLA / SLS', 'Entrega 24–72h', 'Geometria Complexa', 'Sem Molde'],
    details: [
      { label: 'Prazo típico', value: '24–72h' },
      { label: 'Materiais', value: 'PLA, ABS, PETG, Resina' },
      { label: 'Tolerância', value: '±0.1mm (FDM) / ±0.05mm (SLA)' },
      { label: 'Aplicação', value: 'Validação de conceito' },
    ],
    reverse: false,
  },
  {
    id: 'funcionais',
    num: '02',
    title: 'Peças Funcionais & Metal',
    body: 'Peças de reposição para máquinas, componentes para robôs e equipamentos industriais. Fabricadas sob demanda em plásticos de alta performance ou aço inoxidável via sinterização BASF Ultrafuse 316L. Sem molde, sem mínimo de quantidade.',
    specs: ['Metal 316L', 'PA CF15 / PEEK / Ultem', 'Alta Temperatura', '+260°C'],
    details: [
      { label: 'Prazo típico', value: '3–7 dias úteis' },
      { label: 'Metal prazo', value: '15–20 dias (sinterização)' },
      { label: 'Tolerância', value: '±0.05mm' },
      { label: 'Aplicação', value: 'Uso final industrial' },
    ],
    reverse: true,
  },
  {
    id: 'modelagem',
    num: '03',
    title: 'Modelagem 3D & Otimização DfAM',
    body: 'Nossa equipe converte desenhos técnicos, esboços ou especificações verbais em modelos 3D prontos para impressão, com otimização para manufatura aditiva (DfAM). Entregamos arquivos .STL, .STEP e .OBJ validados e prontos para produção.',
    specs: ['CAD Profissional', 'DfAM', 'Análise de Topologia', 'STEP / STL / OBJ'],
    details: [
      { label: 'Entregável', value: '.STL / .STEP / .OBJ' },
      { label: 'Prazo', value: 'Sob consulta' },
      { label: 'Inclui', value: 'Análise de impressibilidade' },
      { label: 'Aplicação', value: 'Projeto do zero ou conversão' },
    ],
    reverse: false,
  },
  {
    id: 'reposicao',
    num: '04',
    title: 'Engenharia Reversa (Scanner 3D)',
    body: 'Capturamos peças físicas existentes com scanner 3D de alta resolução e geramos o modelo digital para replicação exata ou modificação de design. Ideal para peças descontinuadas pelo fabricante original ou componentes orgânicos complexos.',
    specs: ['Scanner 3D', 'Engenharia Reversa', 'Nuvem de Pontos', 'Réplica Exata'],
    details: [
      { label: 'Tecnologia', value: 'Scanner portátil HD' },
      { label: 'Precisão', value: '±0.02mm na captura' },
      { label: 'Entregável', value: 'Modelo 3D + arquivo pronto' },
      { label: 'Aplicação', value: 'Peças descontinuadas / orgânicas' },
    ],
    reverse: true,
  },
]

const processSteps = [
  { n: '01', title: 'Envio do Arquivo', body: 'Envie .STL, .OBJ, .STEP ou descreva o projeto.' },
  { n: '02', title: 'Análise Técnica', body: 'Revisamos viabilidade, material e processo.' },
  { n: '03', title: 'Orçamento', body: 'Retornamos em até 24h com valor e prazo.' },
  { n: '04', title: 'Produção', body: 'Impressão com monitoramento em tempo real.' },
  { n: '05', title: 'Controle de Qualidade', body: 'Verificação dimensional antes do envio.' },
  { n: '06', title: 'Entrega & Suporte', body: 'Envio nacional + suporte técnico pós-entrega.' },
]

const description = 'Serviços de impressão 3D industrial AUMAF 3D: prototipagem rápida (24–72h), peças funcionais em metal 316L e polímeros (PEEK, PA CF15), modelagem 3D, engenharia reversa. Tolerância ±0.05mm. São Carlos – SP.'

const schemas = [
  ...services.map((s) =>
    serviceSchema({
      name: s.title,
      description: s.body,
      url: `${COMPANY.url}/servicos#${s.id}`,
      serviceType: s.title,
    }),
  ),
  howToSchema({
    name: 'Como funciona o processo de impressão 3D na AUMAF 3D',
    description: 'Passo a passo do envio do arquivo até a entrega da peça impressa.',
    steps: processSteps.map((s) => ({ name: `${s.n}. ${s.title}`, text: s.body })),
  }),
  itemListSchema(services.map((s) => ({ name: s.title, url: `${COMPANY.url}/servicos#${s.id}`, description: s.body }))),
]
---

<Base
  title="Serviços de Impressão 3D Industrial"
  description={description}
  breadcrumb={[{ name: 'Serviços', url: '/servicos' }]}
  schemas={schemas}
>
  <Navbar currentPath="/servicos" />

  <!-- Hero Institucional (coffee-tech style: assimétrico) -->
  <section class="min-h-[60vh] flex items-end bg-background pt-28 pb-20 relative overflow-hidden" aria-labelledby="hero-servicos">
    <!-- Background AI: blueprint da impressora -->
    <div
      class="absolute inset-0 pointer-events-none bg-no-repeat bg-cover bg-center opacity-[0.40]"
      aria-hidden="true"
      style="background-image:url('/images/bg-blueprint.webp');"
    ></div>
    <div class="absolute inset-0 bg-tech-grid opacity-25 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 70% 50% at 85% 15%,rgba(97,197,79,0.12) 0%,transparent 60%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 40% 40% at 10% 80%,rgba(97,197,79,0.07) 0%,transparent 65%);"></div>
    <!-- Vinheta para legibilidade do conteúdo -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,rgba(0,0,0,0.50) 0%,transparent 30%,transparent 65%,rgba(0,0,0,0.65) 100%);"></div>
    <div class="absolute bottom-0 inset-x-0 h-16 pointer-events-none" aria-hidden="true" style="background:linear-gradient(to bottom,transparent,rgba(0,0,0,0.6));"></div>

    <div class="max-w-[1600px] mx-auto px-edge w-full relative z-10">
      <Breadcrumb items={[{ name: 'Serviços' }]} compact />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-end">
        <div>
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-4">Sistemas // Capacidades</span>
          <h1 id="hero-servicos" class="text-display-xl font-bold uppercase text-white tracking-[-0.04em] leading-none">
            Soluções de<br/>Manufatura<br/>Aditiva.
          </h1>
        </div>
        <div class="md:pb-2">
          <p class="text-body-lg text-tertiary leading-relaxed max-w-md">
            Engenharia aditiva completa: do arquivo digital à peça funcional. <strong class="text-on-surface">Quatro serviços integrados</strong> para cada fase do desenvolvimento de produto, com tolerância de até <strong class="text-on-surface">±0.05mm</strong>.
          </p>
          <div class="flex items-center gap-3 mt-8">
            <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse-dot glow-effect" aria-hidden="true"></span>
            <span class="text-label-caps text-primary-container uppercase tracking-[0.2em]">Orçamento em até 24h</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionSeparator variant="glow" spacing="md" />

  <!-- Serviços Zigzag -->
  <section class="bg-background py-section relative overflow-hidden" aria-labelledby="servicos-list">
    <!-- Background AI: hexágonos -->
    <div
      class="absolute inset-0 pointer-events-none bg-no-repeat bg-cover bg-center opacity-[0.20]"
      aria-hidden="true"
      style="background-image:url('/images/bg-hex.webp');"
    ></div>
    <div class="absolute inset-0 bg-tech-grid opacity-[0.08] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 60% 40% at 95% 0%,rgba(97,197,79,0.08) 0%,transparent 65%),radial-gradient(ellipse 50% 35% at 5% 100%,rgba(97,197,79,0.07) 0%,transparent 65%);"></div>
    <h2 id="servicos-list" class="sr-only">Lista de serviços</h2>
    <div class="max-w-[1600px] mx-auto px-edge divide-y divide-white/5 relative z-10">
      {services.map((service, i) => (
        <article id={service.id} data-animate class:list={['grid grid-cols-1 lg:grid-cols-2 gap-16 items-start py-20 reveal-hidden', `stagger-${i + 1}`]} aria-labelledby={`svc-${service.id}-title`}>
          <div class:list={service.reverse ? 'lg:order-2' : ''}>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">[{service.num}]</span>
            <h3 id={`svc-${service.id}-title`} class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-5">{service.title}</h3>
            <p class="text-body-lg text-tertiary leading-relaxed mb-6">{service.body}</p>
            <ul role="list" class="flex flex-wrap gap-2 mb-8">
              {service.specs.map((s) => (
                <li class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest">
                  {s}
                </li>
              ))}
            </ul>
            <a
              href="/contato"
              class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300"
            >
              Solicitar orçamento de {service.title.toLowerCase()}
              <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
          <div class:list={service.reverse ? 'lg:order-1' : ''}>
            <dl class="glass-panel card-hover-glow p-8 rounded-sm border border-white/8 grid grid-cols-2 gap-4">
              {service.details.map((d) => (
                <div class="border-b border-white/8 pb-4">
                  <dt class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-1">{d.label}</dt>
                  <dd class="text-body-md text-on-surface font-medium">{d.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Como Funciona — Industrial Control Surface (refeito) -->
  <section class="bg-surface-low py-section relative overflow-hidden" aria-labelledby="como-funciona">
    <!-- Background AI (blueprint da impressora) — mais presente -->
    <div
      class="absolute inset-0 pointer-events-none bg-no-repeat bg-cover bg-center opacity-[0.42]"
      aria-hidden="true"
      style="background-image:url('/images/bg-blueprint.webp');"
    ></div>
    <!-- Camadas geométricas overlay -->
    <div class="absolute inset-0 bg-tech-grid opacity-[0.14] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 60% 50% at 88% 12%,rgba(97,197,79,0.16) 0%,transparent 65%),radial-gradient(ellipse 50% 40% at 8% 88%,rgba(97,197,79,0.11) 0%,transparent 65%);"></div>
    <!-- Vinheta vertical para foco no conteúdo -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,rgba(0,0,0,0.50) 0%,transparent 18%,transparent 82%,rgba(0,0,0,0.70) 100%);"></div>

    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <header class="mb-14 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-3">Processo</span>
          <h2 id="como-funciona" class="text-headline-lg md:text-display-xl font-bold uppercase text-white tracking-[-0.03em] leading-[0.95]">Como<br/>Funciona.</h2>
        </div>
        <p class="text-body-md text-tertiary md:text-right max-w-md leading-relaxed">
          Do envio do arquivo à entrega da peça final: <strong class="text-on-surface">6 etapas controladas</strong> com prazo definido em até 24h após análise técnica.
        </p>
      </header>

      <!-- Grid 2×3 (lg) / 1×6 stack mobile — mais respirável que 1×6 horizontal -->
      <ol class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {processSteps.map((step, i) => {
          const isLast = i === processSteps.length - 1
          // Conector chevron entre etapas: aparece à direita em desktop (exceto última coluna), embaixo em mobile/tablet
          const showRightArrow = !isLast && ((i + 1) % 3 !== 0)
          return (
            <li
              data-animate
              class:list={[
                'glass-panel relative rounded-sm group transition-all duration-300 reveal-hidden list-none overflow-hidden border border-white/8 hover:border-primary-container/35 hover:-translate-y-1',
                `stagger-${i + 1}`,
              ]}
            >
              <!-- Corner brackets (4 cantos) -->
              <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-primary-container/30 opacity-60 group-hover:opacity-100 transition-opacity" aria-hidden="true"></div>
              <div class="absolute top-2 right-2 w-3 h-3 border-t border-r border-primary-container/30 opacity-60 group-hover:opacity-100 transition-opacity" aria-hidden="true"></div>
              <div class="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-primary-container/30 opacity-60 group-hover:opacity-100 transition-opacity" aria-hidden="true"></div>
              <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-primary-container/30 opacity-60 group-hover:opacity-100 transition-opacity" aria-hidden="true"></div>
              <!-- Scan-line no hover -->
              <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/40 to-transparent animate-scan-line opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>
              <!-- Glow superior linear -->
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-container/40 to-transparent opacity-50 group-hover:opacity-100 transition-opacity" aria-hidden="true"></div>

              <div class="p-7 lg:p-8 flex flex-col gap-3 h-full">
                <!-- Header com numeral grande + label etapa -->
                <div class="flex items-baseline justify-between mb-2">
                  <span
                    class="text-[64px] lg:text-[72px] font-black text-white/[0.10] group-hover:text-primary-container/35 group-hover:text-glow-sm leading-none tracking-[-0.04em] transition-all duration-300"
                    aria-hidden="true"
                  >{step.n}</span>
                  <span class="text-label-caps text-primary-container uppercase tracking-[0.18em] text-[10px]">Etapa {step.n}</span>
                </div>

                <h3 class="text-headline-md font-bold text-white uppercase tracking-[0.01em] leading-tight">{step.title}</h3>
                <p class="text-body-md text-tertiary leading-relaxed flex-1">{step.body}</p>
              </div>

              <!-- Chevron conector (só desktop, entre cards da mesma fileira) -->
              {showRightArrow && (
                <div
                  class="hidden lg:flex absolute top-1/2 -right-4 -translate-y-1/2 w-8 h-8 items-center justify-center pointer-events-none z-10"
                  aria-hidden="true"
                >
                  <span class="material-symbols-outlined text-primary-container/40 text-2xl group-hover:text-primary-container/70 transition-colors duration-300" style="font-variation-settings:'FILL' 1;">chevron_right</span>
                </div>
              )}
            </li>
          )
        })}
      </ol>
    </div>

    <!-- Fade gradient para próxima seção -->
    <div class="absolute bottom-0 inset-x-0 h-24 pointer-events-none" aria-hidden="true" style="background:linear-gradient(to bottom,transparent,rgba(0,0,0,0.55));"></div>
  </section>

  <SectionSeparator variant="strong" spacing="md" />

  <!-- CTA -->
  <section class="bg-background py-section relative overflow-hidden" aria-labelledby="cta-servicos">
    <!-- Background AI: particles -->
    <div
      class="absolute inset-0 pointer-events-none bg-no-repeat bg-cover bg-center opacity-[0.32]"
      aria-hidden="true"
      style="background-image:url('/images/bg-particles.webp');"
    ></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 60% 70% at 50% 50%,rgba(97,197,79,0.12) 0%,transparent 65%);"></div>
    <div class="absolute inset-0 bg-tech-grid opacity-[0.08] pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-[1600px] mx-auto px-edge text-center relative z-10">
      <h2 id="cta-servicos" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-4">Inicie seu Projeto Agora</h2>
      <p class="text-body-lg text-tertiary mb-8 max-w-md mx-auto">Envie seu arquivo ou descreva o projeto. Orçamento em até 24 horas.</p>
      <a href="/contato" data-track="cta_quote_hero" data-track-location="page-footer" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-10 py-5 rounded-sm glow-effect-lg hover:bg-primary-dim transition-all duration-300">
        <span class="material-symbols-outlined text-base" aria-hidden="true" style="font-variation-settings:'FILL' 1;">upload_file</span>
        Solicitar orçamento
      </a>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('reveal-visible')
          observer.unobserve(e.target)
        }
      })
    },
    { threshold: 0.08, rootMargin: '0px 0px -50px 0px' },
  )
  document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el))
</script>

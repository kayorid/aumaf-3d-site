    slug: 'mat-16-pa12-sls', cat: 'Pó (SLS/SLM)', name: 'PA12 em Pó (SLS)', tempMax: '170°C', flex: 'Semi-rígido', app: 'Peças funcionais SLS', highlight: true,
    description: 'Poliamida 12 em pó para sinterização seletiva a laser (SLS). Permite peças funcionais com geometrias complexas, canais internos e estruturas em treliça — sem necessidade de suporte. Excelente combinação de resistência mecânica, leveza e estabilidade dimensional. Acabamento natural fosco com textura levemente porosa.',
    properties: [
      { label: 'Resistência tração', value: '48–55 MPa' },
      { label: 'Módulo elástico', value: '1,6–1,8 GPa' },
      { label: 'Alongamento', value: '15–25%' },
      { label: 'Densidade', value: '1,01 g/cm³' },
      { label: 'Temp. máx. uso', value: '170°C' },
      { label: 'HDT', value: '~160°C' },
    ],
    printing: [{ label: 'Tecnologia', value: 'SLS — laser sintering' }, { label: 'Camada', value: '100–120 µm' }, { label: 'Volume máx.', value: '400 × 400 × 420 mm' }, { label: 'Pós-processo', value: 'Despoeiramento + jateamento' }],
    useCases: ['Peças funcionais sem suporte', 'Dutos e canais internos', 'Estruturas em treliça', 'Pequenas séries', 'Carcaças leves'],
    pros: ['Sem necessidade de suporte', 'Geometrias internas livres', 'Boa resistência mecânica', 'Estabilidade dimensional'],
    cons: ['Acabamento poroso natural', 'Cor original cinza-bege', 'Pintura precisa de selante'],
  },
  {
    slug: 'mat-17-aco-inox-316l-slm', cat: 'Pó (SLS/SLM)', name: 'Aço Inox 316L (SLM)', tempMax: '800°C+', flex: 'Aço Inox', app: 'Componentes metálicos finais', highlight: true,
    description: 'Aço inoxidável 316L sinterizado por laser (SLM — Selective Laser Melting) a partir de pó metálico. Peças metálicas finais com densidade próxima ao maciço, prontas para aplicação industrial, alimentícia e marítima. Excelente resistência à corrosão e a temperaturas extremas.',
    properties: [
      { label: 'Densidade', value: '>99% do aço maciço' },
      { label: 'Resist. tração', value: '500–650 MPa' },
      { label: 'Alongamento', value: '40–50%' },
      { label: 'Norma', value: 'ASTM 316L' },
      { label: 'Temp. máx. uso', value: '800°C+' },
      { label: 'Resist. corrosão', value: 'Alimentícia / marinha' },
    ],
    printing: [{ label: 'Tecnologia', value: 'SLM — laser melting' }, { label: 'Camada', value: '20–50 µm' }, { label: 'Volume máx.', value: '470 × 270 × 300 mm' }, { label: 'Pós-processo', value: 'Tratamento térmico + acabamento' }],
    useCases: ['Componentes metálicos finais', 'Indústria alimentícia', 'Aplicações marítimas', 'Peças sob alta temperatura', 'Substituição de usinagem complexa'],
    pros: ['Aço inox real de alta densidade', 'Geometrias impossíveis em usinagem', 'Certificação ASTM 316L'],
    cons: ['Prazo estendido', 'Pós-processo térmico obrigatório', 'Custo elevado'],
  },
]

const categories = ['Todos', 'Termoplásticos', 'Alta Performance', 'Flexíveis', 'Resinas', 'Pó (SLS/SLM)']

const description = 'Catálogo de materiais para impressão 3D na AUMAF 3D: termoplásticos (PLA, PA, ABS, PETG, PC), alta performance (PA CF15, Tritan), resinas, PA12 em pó (SLS) e Aço Inox 316L sinterizado (SLM). Especificações técnicas, temperatura e aplicações.'

const schemas = [
  itemListSchema(materials.map((m) => ({ name: m.name, description: `${m.cat}. Temperatura máxima: ${m.tempMax}. ${m.flex}. Aplicação: ${m.app}.` }))),
]
---

<Base
  title="Materiais para Impressão 3D"
  description={description}
  pageType="CollectionPage"
  breadcrumb={[{ name: 'Materiais', url: '/materiais' }]}
  schemas={schemas}
>
  <Navbar currentPath="/materiais" />

  <!-- Hero — compacto em mobile -->
  <section class="bg-background pt-24 pb-12 md:pt-28 md:pb-20 relative overflow-hidden" aria-labelledby="hero-mat">
    <!-- Bg AI: hexágonos (tema materiais/portfólio técnico) -->
    <div class="absolute inset-0 pointer-events-none bg-no-repeat bg-cover bg-center opacity-[0.28]" aria-hidden="true" style="background-image:url('/images/bg-hex.webp');"></div>
    <div class="absolute inset-0 bg-tech-grid opacity-[0.20] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 65% 55% at 75% 20%,rgba(97,197,79,0.10) 0%,transparent 65%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 30% 35% at 0% 100%,rgba(97,197,79,0.06) 0%,transparent 60%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,rgba(0,0,0,0.40) 0%,transparent 35%,rgba(0,0,0,0.55) 100%);"></div>
    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <Breadcrumb items={[{ name: 'Materiais' }]} compact />
      <div class="max-w-2xl">
        <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-3 md:mb-4 text-[10px] md:text-xs">Catálogo // Materiais</span>
        <h1 id="hero-mat" class="text-headline-lg md:text-display-xl font-bold uppercase text-white tracking-[-0.03em] md:tracking-[-0.04em] leading-[0.95] md:leading-none mb-4 md:mb-6">
          Materiais de<br/>Primeira Linha.
        </h1>
        <p class="text-body-md md:text-body-lg text-tertiary leading-relaxed mb-6 md:mb-8">
          <strong class="text-on-surface">{materials.length} materiais certificados</strong> em estoque. Atendemos de protótipos de conceito até peças de uso final em ambientes industriais severos.
        </p>
        <ul role="list" class="flex flex-wrap items-center gap-x-3 md:gap-x-4 gap-y-2 text-code-data text-on-surface-variant text-[10px] md:text-[11px]">
          <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary-container" aria-hidden="true"></span> Termoplásticos</li>
          <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-on-surface" aria-hidden="true"></span> Alta Performance</li>
          <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-tertiary" aria-hidden="true"></span> Resinas</li>
          <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-error" aria-hidden="true"></span> Pó (SLS/SLM)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Filter pills — wrap multi-linha em mobile (sem scroll horizontal) -->
  <div
    id="materiais-filter"
    class="nav-glass-sub sticky z-40 w-full"
    style="top: calc(4rem + env(safe-area-inset-top, 0px));"
  >
    <div class="max-w-[1600px] mx-auto px-edge py-3">
      <div
        class="flex flex-wrap items-center gap-2 mb-2"
        role="radiogroup"
        aria-label="Filtrar materiais por categoria"
      >
        {categories.map((cat, i) => (
          <button
            type="button"
            role="radio"
            aria-checked={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? '0' : '-1'}
            data-filter={cat === 'Todos' ? 'all' : cat}
            class:list={[
              'mat-filter shrink-0 transition-all duration-200 inline-flex items-center px-4 py-2 md:py-1.5 rounded-full border text-label-caps uppercase tracking-widest whitespace-nowrap text-[10px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container',
              i === 0
                ? 'bg-primary-container border-primary-container text-on-primary glow-effect'
                : 'border-white/30 text-on-surface-variant hover:border-primary-container hover:text-primary-container',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>
      <p id="mat-count" aria-live="polite" class="text-code-data text-on-surface-variant text-[10px] md:text-[11px]">
        Exibindo {materials.length} materiais
      </p>
    </div>
  </div>

  <!-- Grid -->
  <section class="bg-background py-section" aria-labelledby="mat-list">
    <h2 id="mat-list" class="sr-only">Lista de materiais</h2>
    <div class="max-w-[1600px] mx-auto px-edge">
      <ul role="list" id="materials-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter">
        {materials.map((mat) => (
          <li>
            <article
              data-cat={mat.cat}
              data-mat-slug={mat.slug}
              role="button"
              tabindex="0"
              aria-haspopup="dialog"
              aria-controls="mat-modal"
              class:list={[
                'glass-panel card-hover-glow p-6 rounded-sm group transition-all duration-300 relative overflow-hidden h-full text-left cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container',
                mat.highlight ? 'border border-primary-container/25' : '',
              ]}
              aria-labelledby={`mat-${mat.name.replace(/\s+/g, '-').toLowerCase()}`}
            >
              {mat.highlight && (
                <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-container/50 to-transparent z-10" aria-hidden="true"></div>
              )}

              <div class="relative -mx-6 -mt-6 mb-5 aspect-[16/9] overflow-hidden border-b border-white/8 bg-surface-base">
                <img
                  src={`/images/${mat.slug}.webp`}
                  alt={`Amostra de ${mat.name} — ${mat.app}`}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                  width="1376"
                  height="768"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
                <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(11,11,11,0.85) 100%);"></div>
              </div>

              <div class="flex justify-between items-start mb-4">
                <span class:list={[
                  'pill text-[10px]',
                  mat.cat === 'Pó (SLS/SLM)' ? 'border-error/60 text-error' :
                  mat.cat === 'Alta Performance' ? 'pill-green' :
                  mat.cat === 'Flexíveis' ? 'border-tertiary/60 text-tertiary' :
                  mat.cat === 'Resinas' ? 'border-on-surface-variant text-on-surface-variant' :
                  'border-white/30 text-on-surface-variant',
                ]}>{mat.cat}</span>
                {mat.highlight && (
                  <span class="text-label-caps text-primary-container text-[10px]">
                    <span aria-hidden="true">✦</span> Destaque
                  </span>
                )}
              </div>

              <h3 id={`mat-${mat.name.replace(/\s+/g, '-').toLowerCase()}`} class="text-headline-md font-bold uppercase text-white mb-4 tracking-[0.02em] group-hover:text-gradient-green transition-all">
                {mat.name}
              </h3>

              <dl class="space-y-2 border-t border-white/12 pt-4">
                <div class="flex justify-between">
                  <dt class="text-code-data text-on-surface-variant">Temp. máx.</dt>
                  <dd class="text-code-data text-on-surface font-medium">{mat.tempMax}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-code-data text-on-surface-variant">Flexibilidade</dt>
                  <dd class="text-code-data text-on-surface font-medium">{mat.flex}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-code-data text-on-surface-variant">Aplicação</dt>
                  <dd class="text-code-data text-primary-container font-medium text-right max-w-[60%]">{mat.app}</dd>
                </div>
              </dl>

              <div class="mt-4 pt-3 border-t border-white/8 flex items-center justify-between text-label-caps uppercase tracking-[0.18em] text-[10px] text-on-surface-variant group-hover:text-primary-container transition-colors">
                <span>Ficha técnica completa</span>
                <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">arrow_forward</span>
              </div>
            </article>
          </li>
        ))}
      </ul>

      <div id="mat-empty" hidden class="mt-12 text-center glass-panel rounded-sm p-12 border border-white/10">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-4 inline-block" aria-hidden="true">science</span>
        <p class="text-body-lg text-on-surface mb-2">Nenhum material encontrado nesta categoria</p>
        <p class="text-body-md text-tertiary mb-6">Trabalhamos sob demanda — consulte se podemos importar ou processar o material que você precisa.</p>
        <a href="/contato" data-track="cta_quote_hero" data-track-location="page-footer" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300">
          Consultar material específico
          <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Destaque Metal -->
  <section class="bg-surface-low py-section border-y border-white/8" aria-labelledby="dest-metal">
    <div class="max-w-[1600px] mx-auto px-edge">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">Destaque // Metal</span>
          <h2 id="dest-metal" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-4">Aço Inox 316L — SLM</h2>
          <p class="text-body-lg text-tertiary leading-relaxed mb-6">
            Aço inoxidável 316L sinterizado por laser (SLM) a partir de pó metálico. Peças metálicas finais com densidade próxima ao maciço, prontas para aplicação industrial, alimentícia e marítima. Resistência à corrosão, temperaturas extremas e cargas mecânicas elevadas — atendendo norma ASTM 316L.
          </p>
          <dl class="grid grid-cols-2 gap-4 mb-8">
            {[
              { label: 'Temperatura', value: '800°C+' },
              { label: 'Densidade',   value: '>99% do aço' },
              { label: 'Norma',       value: '316L ASTM' },
              { label: 'Tecnologia',  value: 'SLM' },
            ].map((d) => (
              <div class="glass-panel p-4 rounded-sm">
                <dt class="text-label-caps text-on-surface-variant uppercase tracking-widest mb-1">{d.label}</dt>
                <dd class="text-body-md text-primary-container font-semibold">{d.value}</dd>
              </div>
            ))}
          </dl>
          <a href="/contato" data-track="cta_quote_hero" data-track-location="page-footer" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300">
            Solicitar orçamento de peça em metal 316L
          </a>
        </div>
        <div class="relative h-72 lg:h-full min-h-[300px] rounded-sm overflow-hidden bg-surface-base border border-white/8 group/hero">
          <img
            src="/images/mat-17-aco-inox-316l-slm.webp"
            alt="Peça impressa em aço inoxidável 316L sinterizado por SLM — vista aproximada"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover/hero:scale-[1.03]"
            width="1376"
            height="768"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
          <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(circle at 50% 50%,rgba(97,197,79,0.06) 0%,transparent 70%),linear-gradient(180deg,rgba(0,0,0,0.05) 0%,rgba(0,0,0,0.55) 100%);"></div>
          <div class="absolute top-3 left-3 w-3 h-3 border-t border-l border-primary-container/40" aria-hidden="true"></div>
          <div class="absolute top-3 right-3 w-3 h-3 border-t border-r border-primary-container/40" aria-hidden="true"></div>
          <div class="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-primary-container/40" aria-hidden="true"></div>
          <div class="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-primary-container/40" aria-hidden="true"></div>
          <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/25 to-transparent animate-scan-line" aria-hidden="true"></div>
          <div class="absolute top-4 right-4">
            <span class="pill-green text-[10px]">Aço Inox · Sinterizado</span>
          </div>
          <div class="absolute bottom-4 left-4 right-4 text-code-data text-on-surface-variant text-[10px] flex justify-between bg-black/40 backdrop-blur-sm rounded-sm px-3 py-1.5">
            <span>SLM // METAL</span>
            <span>ASTM 316L</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-background border-t border-primary-container/20 py-section" aria-labelledby="cta-mat">
    <div class="max-w-[1600px] mx-auto px-edge text-center">
      <h2 id="cta-mat" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-4">Não sabe qual material usar?</h2>
      <p class="text-body-lg text-tertiary mb-8 max-w-md mx-auto">Nossa equipe técnica indica o material ideal para cada aplicação, temperatura, carga e custo.</p>
      <a href="/contato" data-track="cta_quote_hero" data-track-location="page-footer" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300">
        Falar com especialista em materiais
        <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
      </a>
    </div>
  </section>

  <!-- =============================================
       MODAL — Ficha técnica completa do material
       ============================================= -->
  <div
    id="mat-modal"
    class="mat-modal fixed inset-0 z-[200] hidden items-stretch md:items-center justify-center"
    style="height: 100dvh; min-height: 100vh;"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mat-modal-title"
    aria-hidden="true"
  >
    <!-- Overlay -->
    <div
      class="mat-modal__overlay absolute inset-0 bg-black/75 backdrop-blur-md opacity-0 transition-opacity duration-200"
      data-modal-close
      aria-hidden="true"
    ></div>

    <!-- Container -->
    <div
      class="mat-modal__container relative w-full md:w-[min(1180px,92vw)] h-[100dvh] md:h-[min(880px,90vh)] bg-surface-base md:rounded-sm border-0 md:border md:border-primary-container/15 flex flex-col overflow-hidden shadow-[0_30px_80px_rgba(0,0,0,0.7)] opacity-0 translate-y-4 md:translate-y-0 md:scale-[0.98] transition-all duration-200"
    >
      <!-- Glow superior -->
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-container/60 to-transparent pointer-events-none" aria-hidden="true"></div>

      <!-- Header sticky -->
      <header class="nav-glass-sub flex items-center justify-between gap-4 px-4 md:px-8 h-14 md:h-16 border-b border-white/8 shrink-0">
        <div class="min-w-0 flex items-center gap-2.5 flex-nowrap">
          <span data-mat-cat-pill class="pill text-[10px] shrink-0 max-w-[140px] truncate">—</span>
          <span class="w-px h-3 bg-white/15 shrink-0" aria-hidden="true"></span>
          <span class="font-mono text-[10px] text-on-surface-variant tracking-widest uppercase shrink-0 tabular-nums">
            <span data-mat-position>1</span><span class="opacity-40 mx-0.5">/</span><span data-mat-total>{materials.length}</span>
          </span>
        </div>

        <!-- Desktop controls (≥md) -->
        <div class="hidden md:flex items-center gap-1.5">
          <button
            type="button"
            data-mat-prev
            class="w-9 h-9 inline-flex items-center justify-center rounded-full bg-surface-low border border-white/10 text-on-surface hover:text-primary-container hover:border-primary-container/40 transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container disabled:opacity-30 disabled:cursor-not-allowed"
            aria-label="Material anterior"
          ><span class="material-symbols-outlined text-lg leading-none" aria-hidden="true">chevron_left</span></button>
          <button
            type="button"
            data-mat-next
            class="w-9 h-9 inline-flex items-center justify-center rounded-full bg-surface-low border border-white/10 text-on-surface hover:text-primary-container hover:border-primary-container/40 transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container disabled:opacity-30 disabled:cursor-not-allowed"
            aria-label="Próximo material"
          ><span class="material-symbols-outlined text-lg leading-none" aria-hidden="true">chevron_right</span></button>
          <span class="w-px h-4 bg-white/10 mx-1.5" aria-hidden="true"></span>
          <button
            type="button"
            data-modal-close
            class="w-9 h-9 inline-flex items-center justify-center rounded-full bg-surface-low border border-white/10 text-on-surface hover:text-error hover:border-error/40 transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
            aria-label="Fechar ficha técnica"
          ><span class="material-symbols-outlined text-lg leading-none" aria-hidden="true">close</span></button>
        </div>

        <!-- Mobile close-only no header -->
        <button
          type="button"
          data-modal-close
          class="md:hidden shrink-0 -mr-1 w-11 h-11 inline-flex items-center justify-center rounded-full bg-surface-low border border-white/12 text-on-surface active:bg-primary-container/10 active:text-primary-container active:border-primary-container/30 transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          aria-label="Fechar ficha técnica"
        ><span class="material-symbols-outlined text-[22px] leading-none" aria-hidden="true">close</span></button>
      </header>

      <!-- Conteúdo scrollável -->
      <div data-mat-body class="flex-1 min-h-0 overflow-y-auto overflow-x-hidden overscroll-contain">
        <div class="grid grid-cols-1 lg:grid-cols-12 min-w-0">
          <!-- Coluna imagem -->
          <div class="lg:col-span-5 relative bg-surface-low border-b lg:border-b-0 lg:border-r border-white/8 min-h-[260px] lg:min-h-[420px]">
            <img
              data-mat-image
              src=""
              alt=""
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
            <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(circle at 30% 30%,rgba(97,197,79,0.10) 0%,transparent 65%),linear-gradient(180deg,rgba(0,0,0,0.10) 0%,rgba(0,0,0,0.55) 100%);"></div>
            <div class="absolute top-3 left-3 w-3 h-3 border-t border-l border-primary-container/40" aria-hidden="true"></div>
            <div class="absolute top-3 right-3 w-3 h-3 border-t border-r border-primary-container/40" aria-hidden="true"></div>
            <div class="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-primary-container/40" aria-hidden="true"></div>
            <div class="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-primary-container/40" aria-hidden="true"></div>
            <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/25 to-transparent animate-scan-line" aria-hidden="true"></div>
            <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between gap-3">
              <span data-mat-quickapp class="text-label-caps text-on-surface uppercase tracking-[0.18em] text-[10px] truncate"></span>
              <span data-mat-quicktemp class="text-code-data text-primary-container font-semibold"></span>
            </div>
          </div>

          <!-- Coluna dados -->
          <div class="lg:col-span-7 p-6 md:p-8 flex flex-col gap-7">
            <div>
              <span data-mat-cat class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-3 text-[11px]">—</span>
              <h2 id="mat-modal-title" data-mat-name class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] leading-tight mb-3">—</h2>
              <p data-mat-desc class="text-body-md text-tertiary leading-relaxed"></p>
            </div>

            <!-- Propriedades técnicas -->
            <section aria-labelledby="mat-props-title">
              <h3 id="mat-props-title" class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] text-[10px] mb-3">Propriedades técnicas</h3>
              <dl data-mat-props class="grid grid-cols-2 sm:grid-cols-3 gap-3"></dl>
            </section>

            <!-- Parâmetros de impressão -->
            <section aria-labelledby="mat-print-title">
              <h3 id="mat-print-title" class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] text-[10px] mb-3">Parâmetros de impressão</h3>
              <dl data-mat-printing class="grid grid-cols-2 sm:grid-cols-4 gap-3"></dl>
            </section>

            <!-- Aplicações -->
            <section aria-labelledby="mat-uses-title">
              <h3 id="mat-uses-title" class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] text-[10px] mb-3">Aplicações típicas</h3>
              <ul data-mat-uses role="list" class="flex flex-wrap gap-2"></ul>
            </section>

            <!-- Pros / Cons -->
            <section class="grid sm:grid-cols-2 gap-4" aria-label="Pontos fortes e limitações">
              <div class="glass-panel p-4 rounded-sm border border-primary-container/15">
                <h3 class="text-label-caps text-primary-container uppercase tracking-[0.18em] text-[10px] mb-3 flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-sm leading-none" aria-hidden="true">check_circle</span>
                  Pontos fortes
                </h3>
                <ul data-mat-pros role="list" class="space-y-1.5 text-sm text-on-surface"></ul>
              </div>
              <div class="glass-panel p-4 rounded-sm border border-white/8">
                <h3 class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] text-[10px] mb-3 flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-sm leading-none" aria-hidden="true">info</span>
                  Considerações
                </h3>
                <ul data-mat-cons role="list" class="space-y-1.5 text-sm text-tertiary"></ul>
              </div>
            </section>
          </div>
        </div>
      </div>

      <!-- Mobile bottom-bar — prev/next + CTA condensado, parte natural do flex column -->
      <div
        class="md:hidden shrink-0 z-10 nav-glass-bottom border-t border-white/8 pb-[max(env(safe-area-inset-bottom),0.5rem)]"
        aria-label="Controles do material"
      >
        <div class="flex items-center gap-2 px-4 py-3">
          <button
            type="button"
            data-mat-prev
            class="w-11 h-11 inline-flex items-center justify-center rounded-full bg-surface-low border border-white/10 text-on-surface active:bg-primary-container/15 active:text-primary-container transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container disabled:opacity-30 disabled:cursor-not-allowed shrink-0"
            aria-label="Material anterior"
          ><span class="material-symbols-outlined text-xl leading-none" aria-hidden="true">chevron_left</span></button>
          <a
            data-mat-cta
            href="/contato"
            class="flex-1 inline-flex items-center justify-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.12em] px-3 py-3 rounded-sm glow-effect text-[10px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container min-w-0"
          >
            <span class="truncate">Solicitar orçamento</span>
            <span class="material-symbols-outlined text-base leading-none shrink-0" aria-hidden="true">arrow_forward</span>
          </a>
          <button
            type="button"
            data-mat-next
            class="w-11 h-11 inline-flex items-center justify-center rounded-full bg-surface-low border border-white/10 text-on-surface active:bg-primary-container/15 active:text-primary-container transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container disabled:opacity-30 disabled:cursor-not-allowed shrink-0"
            aria-label="Próximo material"
          ><span class="material-symbols-outlined text-xl leading-none" aria-hidden="true">chevron_right</span></button>
        </div>
      </div>

      <!-- Desktop footer com CTA -->
      <footer class="hidden md:flex border-t border-white/8 px-5 md:px-8 py-4 flex-col sm:flex-row items-stretch sm:items-center sm:justify-between gap-3 bg-surface-low shrink-0">
        <span class="text-[11px] text-tertiary hidden sm:block">
          Use as setas <kbd class="font-mono text-on-surface-variant">←</kbd> <kbd class="font-mono text-on-surface-variant">→</kbd> para navegar · <kbd class="font-mono text-on-surface-variant">ESC</kbd> fecha
        </span>
        <a
          data-mat-cta
          href="/contato"
          class="inline-flex items-center justify-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-200 text-[11px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
        >
          Solicitar orçamento com este material
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">arrow_forward</span>
        </a>
      </footer>
    </div>
  </div>

  <!-- Data store (consumido pelo controller do modal) -->
  <script is:inline type="application/json" id="materials-data" set:html={JSON.stringify(materials)}></script>

  <Footer />
</Base>

<script>
  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('#materiais-filter [role="radio"]'))
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-cat]'))
  const counter = document.getElementById('mat-count')
  const emptyEl = document.getElementById('mat-empty')

  const ACTIVE = 'bg-primary-container border-primary-container text-on-primary glow-effect'
  const INACTIVE = 'border-white/30 text-on-surface-variant hover:border-primary-container hover:text-primary-container'

  function setFilter(btn: HTMLButtonElement) {
    const filter = btn.dataset.filter ?? 'all'
    filterBtns.forEach((b) => {
      const active = b === btn
      b.setAttribute('aria-checked', active ? 'true' : 'false')
      b.tabIndex = active ? 0 : -1
      ACTIVE.split(' ').forEach((c) => b.classList.toggle(c, active))
      INACTIVE.split(' ').forEach((c) => b.classList.toggle(c, !active))
    })

    let visible = 0
    cards.forEach((card) => {
      const li = card.parentElement!
      const show = filter === 'all' || card.dataset.cat === filter
      if (show) {
        li.style.display = ''
        card.style.opacity = '0'
        requestAnimationFrame(() => {
          card.style.transition = 'opacity 0.3s ease'
          card.style.opacity = '1'
        })
        visible++
      } else {
        card.style.opacity = '0'
        card.style.transition = 'opacity 0.2s ease'
        setTimeout(() => { li.style.display = 'none' }, 200)
      }
    })

    if (counter) {
      counter.textContent = filter === 'all'
        ? `Exibindo ${visible} materiais`
        : `Exibindo ${visible} material${visible === 1 ? '' : 'is'} em ${filter}`
    }
    if (emptyEl) {
      if (visible === 0) emptyEl.removeAttribute('hidden')
      else emptyEl.setAttribute('hidden', '')
    }
  }

  filterBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => { setFilter(btn); btn.focus() })
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault()
        const next = filterBtns[(i + 1) % filterBtns.length]
        setFilter(next)
        next.focus()
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault()
        const prev = filterBtns[(i - 1 + filterBtns.length) % filterBtns.length]
        setFilter(prev)
        prev.focus()
      }
    })
  })

  // ====================================================================
  // MODAL — Ficha técnica do material
  // ====================================================================
  interface MaterialDetail {
    slug: string; cat: string; name: string; tempMax: string; flex: string; app: string; highlight: boolean
    description: string
    properties: { label: string; value: string }[]
    printing: { label: string; value: string }[]
    useCases: string[]; pros: string[]; cons: string[]
  }

  const dataNode = document.getElementById('materials-data')
  const allMaterials: MaterialDetail[] = dataNode ? JSON.parse(dataNode.textContent || '[]') : []
  const materialsBySlug = new Map(allMaterials.map((m) => [m.slug, m]))

  const modal = document.getElementById('mat-modal')

  if (modal && allMaterials.length > 0) {
    const overlay = modal.querySelector<HTMLElement>('.mat-modal__overlay')
    const container = modal.querySelector<HTMLElement>('.mat-modal__container')
    const body = modal.querySelector<HTMLElement>('[data-mat-body]')
    const prevBtns = Array.from(modal.querySelectorAll<HTMLButtonElement>('[data-mat-prev]'))
    const nextBtns = Array.from(modal.querySelectorAll<HTMLButtonElement>('[data-mat-next]'))
    const ctaLinks = Array.from(modal.querySelectorAll<HTMLAnchorElement>('[data-mat-cta]'))
    const closeBtns = Array.from(modal.querySelectorAll<HTMLElement>('[data-modal-close]'))

    const elCatPill = modal.querySelector<HTMLElement>('[data-mat-cat-pill]')
    const elPos = modal.querySelector<HTMLElement>('[data-mat-position]')
    const elTotal = modal.querySelector<HTMLElement>('[data-mat-total]')
    const elImg = modal.querySelector<HTMLImageElement>('[data-mat-image]')
    const elQuickApp = modal.querySelector<HTMLElement>('[data-mat-quickapp]')
    const elQuickTemp = modal.querySelector<HTMLElement>('[data-mat-quicktemp]')
    const elCat = modal.querySelector<HTMLElement>('[data-mat-cat]')
    const elName = modal.querySelector<HTMLElement>('[data-mat-name]')
    const elDesc = modal.querySelector<HTMLElement>('[data-mat-desc]')
    const elProps = modal.querySelector<HTMLElement>('[data-mat-props]')
    const elPrinting = modal.querySelector<HTMLElement>('[data-mat-printing]')
    const elUses = modal.querySelector<HTMLElement>('[data-mat-uses]')
    const elPros = modal.querySelector<HTMLElement>('[data-mat-pros]')
    const elCons = modal.querySelector<HTMLElement>('[data-mat-cons]')

    let currentSlug: string | null = null
    let triggerEl: HTMLElement | null = null

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    function visibleCards(): HTMLElement[] {
      return cards.filter((c) => {
        const li = c.parentElement as HTMLElement | null
        return li && li.style.display !== 'none'
      })
    }

    function categoryPillClass(cat: string): string {
      if (cat === 'Pó (SLS/SLM)') return 'pill border-error/60 text-error'
      if (cat === 'Alta Performance') return 'pill pill-green'
      if (cat === 'Flexíveis') return 'pill border-tertiary/60 text-tertiary'
      if (cat === 'Resinas') return 'pill border-on-surface-variant text-on-surface-variant'
      return 'pill border-white/30 text-on-surface-variant'
    }

    function buildDl(target: HTMLElement, items: { label: string; value: string }[]) {
      target.innerHTML = items.map((it) => `
        <div class="glass-panel p-3 rounded-sm border border-white/8">
          <dt class="text-label-caps text-on-surface-variant uppercase tracking-widest text-[9px] mb-1">${escapeHtml(it.label)}</dt>
          <dd class="text-code-data text-on-surface font-medium">${escapeHtml(it.value)}</dd>
        </div>
      `).join('')
    }

    function buildList(target: HTMLElement, items: string[], chip = false) {
      if (chip) {
        target.innerHTML = items.map((t) => `
          <li class="inline-flex items-center px-3 py-1.5 rounded-full border border-primary-container/30 text-primary-container text-label-caps uppercase tracking-widest text-[10px]">${escapeHtml(t)}</li>
        `).join('')
      } else {
        target.innerHTML = items.map((t) => `
          <li class="flex items-start gap-2 leading-snug">
            <span class="text-primary-container mt-1 text-[10px]" aria-hidden="true">▸</span>
            <span>${escapeHtml(t)}</span>
          </li>
        `).join('')
      }
    }

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!))
    }

    function render(slug: string) {
      const m = materialsBySlug.get(slug)
      if (!m) return
      currentSlug = slug

      if (elCatPill) { elCatPill.textContent = m.cat; elCatPill.className = `${categoryPillClass(m.cat)} text-[10px] shrink-0` }
      if (elCat) elCat.textContent = `${m.cat} // ${m.flex}`
      if (elName) elName.textContent = m.name
      if (elDesc) elDesc.textContent = m.description
      if (elImg) { elImg.src = `/images/${m.slug}.webp`; elImg.alt = `Amostra de ${m.name} — ${m.app}` }
      if (elQuickApp) elQuickApp.textContent = m.app
      if (elQuickTemp) elQuickTemp.textContent = m.tempMax
      if (elProps) buildDl(elProps, m.properties)
      if (elPrinting) buildDl(elPrinting, m.printing)
      if (elUses) buildList(elUses, m.useCases, true)
      if (elPros) buildList(elPros, m.pros)
      if (elCons) buildList(elCons, m.cons)
      ctaLinks.forEach((a) => { a.href = `/contato?material=${encodeURIComponent(m.name)}` })

      // Posição dentro dos cards visíveis
      const visible = visibleCards()
      const idx = visible.findIndex((c) => c.dataset.matSlug === slug)
      if (elPos) elPos.textContent = String(idx >= 0 ? idx + 1 : 1)
      if (elTotal) elTotal.textContent = String(visible.length)
      prevBtns.forEach((b) => { b.disabled = idx <= 0 })
      nextBtns.forEach((b) => { b.disabled = idx === -1 || idx >= visible.length - 1 })

      // Reset scroll do conteúdo
      if (body) body.scrollTop = 0
    }

    function open(slug: string, fromCard?: HTMLElement) {
      if (!materialsBySlug.has(slug)) return
      triggerEl = fromCard ?? (document.querySelector<HTMLElement>(`[data-mat-slug="${slug}"]`) || null)
      render(slug)

      modal!.classList.remove('hidden')
      modal!.classList.add('flex')
      modal!.setAttribute('aria-hidden', 'false')
      document.documentElement.style.overflow = 'hidden'
      document.body.style.overflow = 'hidden'

      // Anima entrada
      requestAnimationFrame(() => {
        if (overlay) overlay.style.opacity = '1'
        if (container) {
          container.style.opacity = '1'
          container.style.transform = prefersReduced ? '' : 'translateY(0) scale(1)'
        }
      })

      // Atualiza hash sem trigger de scroll
      if (location.hash !== `#${slug}`) {
        history.replaceState(null, '', `#${slug}`)
      }

      // Foco inicial no botão de fechar (mais seguro que conteúdo)
      const closeBtn = closeBtns[closeBtns.length - 1] as HTMLElement | undefined
      closeBtn?.focus()
    }

    function close() {
      if (!modal!.classList.contains('flex')) return
      if (overlay) overlay.style.opacity = '0'
      if (container) {
        container.style.opacity = '0'
        container.style.transform = prefersReduced ? '' : 'translateY(4px) scale(0.98)'
      }
      const finish = () => {
        modal!.classList.add('hidden')
        modal!.classList.remove('flex')
        modal!.setAttribute('aria-hidden', 'true')
        document.documentElement.style.overflow = ''
        document.body.style.overflow = ''
        if (location.hash) history.replaceState(null, '', location.pathname + location.search)
        triggerEl?.focus()
        currentSlug = null
      }
      if (prefersReduced) finish()
      else setTimeout(finish, 180)
    }

    function navigate(delta: number) {
      if (!currentSlug) return
      const visible = visibleCards()
      const idx = visible.findIndex((c) => c.dataset.matSlug === currentSlug)
      if (idx === -1) return
      const next = visible[idx + delta]
      if (!next) return
      const nextSlug = next.dataset.matSlug
      if (nextSlug) {
        triggerEl = next
        render(nextSlug)
        history.replaceState(null, '', `#${nextSlug}`)
      }
    }

    // Wire-up — cards
    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const slug = card.dataset.matSlug
        if (slug) open(slug, card)
      })
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault()
          const slug = card.dataset.matSlug
          if (slug) open(slug, card)
        }
      })
    })

    // Wire-up — controles
    closeBtns.forEach((b) => b.addEventListener('click', close))
    prevBtns.forEach((b) => b.addEventListener('click', () => navigate(-1)))
    nextBtns.forEach((b) => b.addEventListener('click', () => navigate(+1)))

    // Teclado global enquanto o modal está aberto
    document.addEventListener('keydown', (e) => {
      if (modal!.classList.contains('hidden')) return
      if (e.key === 'Escape') { e.preventDefault(); close() }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); navigate(-1) }
      else if (e.key === 'ArrowRight') { e.preventDefault(); navigate(+1) }
      else if (e.key === 'Tab') {
        // Focus trap simples
        const focusables = modal!.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"]), input, select, textarea'
        )
        if (focusables.length === 0) return
        const first = focusables[0]
        const last = focusables[focusables.length - 1]
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus() }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus() }
      }
    })

    // Touch swipe (mobile) entre materiais
    let touchStartX = 0
    let touchStartY = 0
    container?.addEventListener('touchstart', (e) => {
      const t = e.changedTouches[0]
      touchStartX = t.clientX; touchStartY = t.clientY
    }, { passive: true })
    container?.addEventListener('touchend', (e) => {
      const t = e.changedTouches[0]
      const dx = t.clientX - touchStartX
      const dy = t.clientY - touchStartY
      if (Math.abs(dx) > 60 && Math.abs(dx) > Math.abs(dy) * 1.4) {
        if (dx < 0) navigate(+1); else navigate(-1)
      }
    }, { passive: true })

    // Deep-link inicial via hash
    function openFromHash() {
      const slug = location.hash.replace(/^#/, '')
      if (slug && materialsBySlug.has(slug)) open(slug)
    }
    window.addEventListener('hashchange', openFromHash)
    if (location.hash) openFromHash()
  }
</script>

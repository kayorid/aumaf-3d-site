---
export const prerender = true
import Base from '../../layouts/Base.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
---

<Base title="[V2] Manufatura Aditiva Industrial de Precisão — AUMAF 3D">
  <Navbar currentPath="/" />

  <!-- =============================================
       HERO V2 — Canvas 3D interativo + HUD
       ============================================= -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-background">
    <div class="absolute inset-0 bg-tech-grid pointer-events-none opacity-50"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 60% at 65% 50%,rgba(97,197,79,0.08) 0%,transparent 65%);"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 40% 40% at 90% 10%,rgba(97,197,79,0.05) 0%,transparent 70%);"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 30% 25% at 5% 95%,rgba(97,197,79,0.04) 0%,transparent 70%);"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(90deg,rgba(0,0,0,0.80) 0%,rgba(0,0,0,0.30) 55%,transparent 100%);"></div>

    <!-- Elementos flutuantes decorativos -->
    <div class="absolute top-24 right-[12%] w-px h-32 bg-gradient-to-b from-transparent via-primary-container/20 to-transparent animate-float-slow hidden lg:block pointer-events-none"></div>
    <div class="absolute bottom-32 right-[8%] w-16 h-px bg-gradient-to-r from-transparent via-primary-container/15 to-transparent animate-float hidden lg:block pointer-events-none"></div>
    <div class="absolute top-1/3 left-8 w-1.5 h-1.5 rounded-full bg-primary-container/20 animate-pulse-dot hidden lg:block pointer-events-none"></div>
    <div class="absolute top-2/3 left-16 w-1 h-1 rounded-full bg-primary-container/15 animate-pulse-dot hidden lg:block pointer-events-none" style="animation-delay:1s;"></div>

    <div class="relative z-10 w-full max-w-[1600px] mx-auto px-edge pt-28 pb-16 lg:pt-32 lg:pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[calc(100vh-80px)]">

        <!-- Coluna esquerda: texto + CTAs -->
        <div class="flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse-dot glow-effect flex-shrink-0"></span>
            <span class="text-label-caps text-primary-container uppercase tracking-[0.2em]">Sistema Online // Imprimindo Agora</span>
          </div>

          <h1 class="text-display-xl font-bold text-white uppercase leading-none tracking-[-0.04em] mb-6 opacity-0 animate-fade-up" style="animation-delay:100ms;animation-fill-mode:forwards;">
            Zero-Error<br/>
            <span style="background:linear-gradient(135deg,#7ce268,#61c54f);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Precision.</span>
          </h1>

          <p class="text-body-lg text-tertiary max-w-lg leading-relaxed mb-10 opacity-0 animate-fade-up" style="animation-delay:250ms;animation-fill-mode:forwards;">
            Manufatura aditiva industrial para aplicações críticas.
            Peças em metal, carbono e polímeros de alta performance —
            entregues onde você precisar.
          </p>

          <div class="flex flex-wrap items-center gap-4 opacity-0 animate-fade-up" style="animation-delay:380ms;animation-fill-mode:forwards;">
            <a href="/contato" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim hover:shadow-glow-lg transition-all duration-300">
              <span class="material-symbols-outlined text-base leading-none" style="font-variation-settings:'FILL' 1;">rocket_launch</span>
              Solicitar Orçamento
            </a>
            <a href="/portfolio" class="inline-flex items-center gap-2 border border-white/20 text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm hover:border-primary-container/50 hover:text-primary-container transition-all duration-300">
              Ver Portfolio
              <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
            </a>
          </div>

          <div class="flex items-center gap-8 mt-12 pt-8 border-t border-white/8 opacity-0 animate-fade-up" style="animation-delay:500ms;animation-fill-mode:forwards;">
            {[
              {value:'+500',label:'Projetos'},
              {value:'20+',label:'Materiais'},
              {value:'4',label:'Tecnologias'},
            ].map(m => (
              <div class="flex flex-col gap-1">
                <span class="text-2xl font-bold text-white tracking-tighter leading-none">{m.value}</span>
                <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.15em] text-[10px]">{m.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Coluna direita: Canvas 3D interativo -->
        <div class="hidden lg:flex flex-col gap-4 opacity-0 animate-fade-up" style="animation-delay:300ms;animation-fill-mode:forwards;">
          <div class="relative aspect-video rounded-sm overflow-hidden bg-background border border-white/8 group" style="box-shadow:0 0 60px rgba(0,0,0,0.8),0 0 30px rgba(97,197,79,0.06);">
            <!-- Canvas 3D -->
            <canvas id="hero-3d" class="absolute inset-0 w-full h-full"></canvas>

            <!-- Overlay HUD — não bloqueia o canvas -->
            <div class="absolute inset-0 pointer-events-none">
              <!-- Corner brackets -->
              <div class="absolute top-3 left-3 w-5 h-5 border-t-2 border-l-2 border-primary-container/50"></div>
              <div class="absolute top-3 right-3 w-5 h-5 border-t-2 border-r-2 border-primary-container/50"></div>
              <div class="absolute bottom-3 left-3 w-5 h-5 border-b-2 border-l-2 border-primary-container/50"></div>
              <div class="absolute bottom-3 right-3 w-5 h-5 border-b-2 border-r-2 border-primary-container/50"></div>
              <!-- Scan line -->
              <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/25 to-transparent animate-scan-line"></div>
              <!-- Labels HUD -->
              <div class="absolute top-3 left-1/2 -translate-x-1/2">
                <span class="text-label-caps text-primary-container/40 uppercase tracking-widest text-[9px] font-mono">RENDER_3D // INTERACTIVE</span>
              </div>
              <div class="absolute bottom-4 left-4 flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-container animate-pulse-dot"></span>
                <span class="text-[10px] text-primary-container/60 font-mono tracking-wide uppercase">Mesh Loaded</span>
              </div>
              <div class="absolute bottom-4 right-4 text-[9px] text-white/20 font-mono tracking-widest">Move cursor to interact</div>
            </div>
          </div>

          <!-- Active Build widget -->
          <div class="glass-panel rounded-sm p-5 w-full" style="border:1px solid rgba(97,197,79,0.12);">
            <div class="flex justify-between items-center mb-4 border-b border-white/8 pb-3">
              <span class="text-label-caps text-tertiary uppercase tracking-widest text-[10px]">Active Build</span>
              <span class="text-label-caps text-primary-container tracking-widest text-[10px]">ID_409X</span>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <div class="flex justify-between text-[11px] text-white/50 mb-1.5">
                  <span class="uppercase tracking-wider">Impressão</span>
                  <span class="text-primary-container font-semibold">80%</span>
                </div>
                <div class="h-px bg-surface-high rounded overflow-hidden">
                  <div class="h-full bg-primary-container glow-effect transition-all duration-1000" style="width:80%;"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-[11px] text-white/50 mb-1.5">
                  <span class="uppercase tracking-wider">Temperatura</span>
                  <span class="text-error font-semibold">265°C</span>
                </div>
                <div class="h-px bg-surface-high rounded overflow-hidden">
                  <div class="h-full bg-error" style="width:95%;"></div>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-container animate-pulse-dot flex-shrink-0"></span>
              <span class="text-[11px] text-tertiary tracking-wide font-mono">PA CF15 · Layer: 0.15mm · Nozzle: 0.4mm</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30 z-10">
      <span class="text-label-caps text-tertiary uppercase tracking-widest text-[10px]">Scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-tertiary to-transparent"></div>
    </div>
  </section>


  <!-- =============================================
       [V2 NOVO] PROVA REAL — Contadores + Depoimento
       ============================================= -->
  <section class="bg-surface-dim py-section relative overflow-hidden" id="prova-real">
    <!-- Glow atmosférico -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(97,197,79,0.05) 0%,transparent 70%);"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-container/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-container/20 to-transparent"></div>

    <div class="max-w-[1600px] mx-auto px-edge">
      <!-- Header -->
      <div class="mb-16 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">00 // Credenciais</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">
            Prova Real.<br/>
            <span class="text-on-surface-variant font-light">Números que não mentem.</span>
          </h2>
        </div>
        <p class="text-body-md text-tertiary max-w-sm leading-relaxed">Cada número abaixo representa um projeto real, um cliente satisfeito, uma peça que funcionou.</p>
      </div>

      <!-- Grid 2 colunas: contadores + depoimento -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Contadores animados -->
        <div class="grid grid-cols-2 gap-4">
          {[
            {id:'cnt-projetos',   target:500,  suffix:'+', label:'Projetos Entregues',   sub:'desde 2022',           icon:'inventory_2'},
            {id:'cnt-prazo',      target:99,   suffix:'%', label:'Taxa de Aprovação',    sub:'no primeiro lote',     icon:'verified'},
            {id:'cnt-materiais',  target:20,   suffix:'+', label:'Materiais no Catálogo',sub:'termoplásticos + metal',icon:'science'},
            {id:'cnt-tecnologias',target:4,    suffix:'',  label:'Tecnologias',          sub:'FDM · SLA · SLS · SLM', icon:'settings_suggest'},
          ].map(c => (
            <div class="glass-panel p-6 lg:p-8 rounded-sm border border-white/6 hover:border-primary-container/20 transition-all duration-300 group">
              <div class="w-9 h-9 rounded-sm bg-primary-container/10 border border-primary-container/20 flex items-center justify-center mb-5 group-hover:bg-primary-container/15 transition-colors duration-300">
                <span class="material-symbols-outlined text-primary-container text-lg" style="font-variation-settings:'FILL' 1;">{c.icon}</span>
              </div>
              <div class="flex items-end gap-1 mb-1">
                <span
                  class="text-[clamp(28px,4vw,48px)] font-black text-white tracking-tighter leading-none tabular-nums"
                  data-counter
                  data-target={c.target}
                  data-decimals="0"
                >0</span>
                <span class="text-[clamp(14px,2vw,22px)] font-bold text-primary-container leading-none mb-1">{c.suffix}</span>
              </div>
              <p class="text-label-caps text-on-surface uppercase tracking-[0.12em] text-[11px] mb-1">{c.label}</p>
              <p class="text-[11px] text-tertiary tracking-wide">{c.sub}</p>
            </div>
          ))}
        </div>

        <!-- Depoimento destaque + case -->
        <div class="flex flex-col gap-4">
          <!-- Testimonial hero -->
          <div class="glass-panel p-8 lg:p-10 rounded-sm relative overflow-hidden" style="border:1px solid rgba(97,197,79,0.10);">
            <!-- Aspas decorativas -->
            <div class="absolute top-4 right-6 text-[80px] leading-none font-serif text-primary-container/8 select-none pointer-events-none">"</div>
            <!-- Stars -->
            <div class="flex gap-1 mb-5">
              {Array(5).fill(0).map(() => (
                <span class="material-symbols-outlined text-primary-container text-base" style="font-variation-settings:'FILL' 1;">star</span>
              ))}
            </div>
            <blockquote class="text-body-lg text-on-surface leading-relaxed mb-7 relative z-10">
              "Peças impressas com rapidez, personalização e muita precisão. Usamos a AUMAF 3D como fornecedora de componentes para máquinas e robôs. <span class="text-primary-container font-medium">Impressionante!</span>"
            </blockquote>
            <div class="flex items-center gap-4">
              <div class="w-11 h-11 rounded-full border border-primary-container/30 flex items-center justify-center bg-primary-container/10 flex-shrink-0">
                <span class="text-primary-container font-bold text-base">R</span>
              </div>
              <div>
                <p class="text-label-caps text-primary-container uppercase tracking-[0.15em] font-bold">Raissa Ninelli</p>
                <p class="text-sm text-tertiary mt-0.5">Diretora · <span class="text-on-surface-variant">Fugini Alimentos</span></p>
              </div>
              <div class="ml-auto">
                <span class="pill-green text-[9px]">Verificado</span>
              </div>
            </div>
          </div>

          <!-- Case destaque: Fórmula SAE -->
          <a href="/blog/formula-sae-case-study-completo" class="glass-panel p-6 rounded-sm flex items-start gap-5 hover:border-primary-container/20 transition-all duration-300 group border border-white/6">
            <div class="w-12 h-12 rounded-sm bg-primary-container/10 border border-primary-container/20 flex items-center justify-center flex-shrink-0 group-hover:bg-primary-container/20 transition-colors duration-300">
              <span class="material-symbols-outlined text-primary-container text-2xl" style="font-variation-settings:'FILL' 1;">sports_score</span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="pill-green text-[9px]">Case Study</span>
                <span class="text-[10px] text-tertiary">USP São Carlos</span>
              </div>
              <p class="text-body-md text-on-surface font-medium leading-snug mb-1 group-hover:text-white transition-colors duration-200">Fórmula SAE 2024 — Componentes de Alta Performance</p>
              <p class="text-sm text-tertiary leading-relaxed">Nylon PA + PET-G CF15 para suspensão e aerodinâmica. Entregue em 5 dias, aprovado sem retrabalho.</p>
            </div>
            <span class="material-symbols-outlined text-white/20 group-hover:text-primary-container/60 transition-colors duration-200 mt-1 flex-shrink-0">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- =============================================
       CAPACIDADES — Zigzag com video containers
       ============================================= -->
  <section class="bg-background py-section">
    <div class="max-w-[1600px] mx-auto px-edge">
      <div class="mb-20 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">01 // Módulos</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Capacidades Core</h2>
        </div>
        <a href="/servicos" class="text-label-caps text-primary-container uppercase tracking-[0.15em] flex items-center gap-2 hover:gap-4 transition-all duration-200 group">
          Todos os Serviços
          <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>

      <div class="divide-y divide-white/5">
        {[
          {num:'01',title:'Prototipagem Rápida',body:'Valide conceitos em horas, não semanas. Processos FDM e SLA entregam protótipos funcionais com geometrias complexas e alta precisão dimensional para ciclos de iteração acelerados.',specs:['FDM / SLA / SLS','Entrega 24–72h','Geometria Complexa'],href:'/servicos',videoId:'VIDEO_CAP_01',videoLabel:'Prototipagem em ação',videoFile:'prototipagem.mp4',image:'/images/cap-prototipagem.webp',reverse:false},
          {num:'02',title:'Peças Funcionais & Metal',body:'Do projeto à peça final em materiais de engenharia: carbono, nylon de alta temperatura e Aço Inox 316L sinterizado por SLM. Componentes para ambientes industriais severos.',specs:['Aço Inox 316L (SLM)','PA CF15','Alta Temperatura'],href:'/servicos',videoId:'VIDEO_CAP_02',videoLabel:'Peça metálica finalizada',videoFile:'metal-parts.mp4',image:'/images/cap-metal-parts.webp',reverse:true},
          {num:'03',title:'Modelagem & Engenharia Reversa',body:'Transformamos desenhos, esboços e peças físicas em modelos digitais precisos. Scanner 3D para captura de geometrias complexas e otimização DfAM para manufatura aditiva.',specs:['CAD Profissional','Scanner 3D','DfAM'],href:'/servicos',videoId:'VIDEO_CAP_03',videoLabel:'Scanner 3D em operação',videoFile:'reverse-engineering.mp4',image:'/images/cap-reverse-engineering.webp',reverse:false},
          {num:'04',title:'Peças de Reposição Sob Demanda',body:'Pare de esperar por peças descontinuadas. Fabricamos substitutas em plástico técnico ou metal em prazo reduzido, sem mínimo de quantidade.',specs:['Sem Mínimo','Sob Medida','Entrega Ágil'],href:'/servicos',videoId:'VIDEO_CAP_04',videoLabel:'Linha de produção customizada',videoFile:'on-demand.mp4',image:'/images/cap-on-demand.webp',reverse:true},
        ].map((item) => (
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center py-20 aos-fade-up">
            <div class:list={item.reverse ? 'lg:order-2' : ''}>
              <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">[{item.num}]</span>
              <h3 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em] mb-5">{item.title}</h3>
              <p class="text-body-lg text-tertiary leading-relaxed mb-7">{item.body}</p>
              <div class="flex flex-wrap gap-2 mb-8">
                {item.specs.map(s => (
                  <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/40 text-primary-container text-label-caps uppercase tracking-widest">{s}</span>
                ))}
              </div>
              <a href={item.href} class="inline-flex items-center gap-2 text-label-caps text-primary-container uppercase tracking-[0.15em] hover:gap-4 transition-all duration-200 group">
                Saiba mais
                <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </a>
            </div>
            <div class:list={item.reverse ? 'lg:order-1' : ''}>
              <div class="relative aspect-square max-w-md mx-auto rounded-sm overflow-hidden bg-surface-base border border-white/8 group/media" style="box-shadow:0 20px 60px rgba(0,0,0,0.6);">
                <!--
                  {item.videoId} — Quando o vídeo final estiver disponível, substituir o <img> abaixo por:
                  <video class="absolute inset-0 w-full h-full object-cover" poster={item.image} autoplay loop muted playsinline>
                    <source src={`/videos/${item.videoFile}`} type="video/mp4" />
                  </video>
                -->
                <img
                  src={item.image}
                  alt={item.videoLabel}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover/media:scale-[1.03]"
                  width="2752"
                  height="1536"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-tech-grid opacity-15 mix-blend-overlay pointer-events-none"></div>
                <div class="absolute inset-0 pointer-events-none" style={`background:radial-gradient(circle at 50% 50%,rgba(97,197,79,0.06) 0%,transparent 60%),linear-gradient(180deg,rgba(0,0,0,0.1) 0%,rgba(0,0,0,0.55) 100%);`}></div>
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
                  <span class="text-[120px] font-black text-white/[0.06] leading-none tracking-tighter mix-blend-overlay">{item.num}</span>
                </div>
                <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/25 to-transparent animate-scan-line"></div>
                <div class="absolute top-4 right-4 text-label-caps text-primary-container/30 text-[10px] tracking-widest uppercase font-mono">{item.videoId}</div>
                <div class="absolute bottom-4 left-4"><span class="pill-green text-[10px]">{item.specs[0]}</span></div>
                <div class="absolute bottom-4 right-4 text-label-caps text-on-surface-variant text-[10px] tracking-widest">{item.videoLabel}</div>
                <div class="absolute top-3 left-3 w-3 h-3 border-t border-l border-primary-container/30"></div>
                <div class="absolute top-3 right-3 w-3 h-3 border-t border-r border-primary-container/30"></div>
                <div class="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-primary-container/30"></div>
                <div class="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-primary-container/30"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- =============================================
       DIFERENCIAIS
       ============================================= -->
  <section class="bg-surface-low py-section section-glow-top relative overflow-hidden">
    <div class="max-w-[1600px] mx-auto px-edge">
      <div class="mb-16 border-b border-white/8 pb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-3">02 // Diferenciais</span>
          <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Por que AUMAF 3D</h2>
        </div>
        <p class="text-body-md text-tertiary max-w-sm leading-relaxed">Precisão industrial, entrega ágil e parceria técnica em cada projeto.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {[
          {icon:'precision_manufacturing',num:'01',title:'Precisão Industrial',body:'FDM industrial calibrado, com inspeção dimensional por paquímetro e micrômetro. Peças consistentes entre lotes, rastreáveis por projeto.',tag:'QUALIDADE'},
          {icon:'category',num:'02',title:'Portfólio de Materiais',body:'Termoplásticos (PLA, PA CF15, TPU, ABS, Policarbonato), resinas, PA12 (SLS) e Aço Inox 316L sinterizado por SLM.',tag:'MATERIAIS'},
          {icon:'tune',num:'03',title:'Feito Sob Medida',body:'Personalização total de geometria, material e acabamento. Sem mínimo de produção para projetos unitários.',tag:'FLEXIBILIDADE'},
          {icon:'support_agent',num:'04',title:'Consultoria Técnica',body:'Equipe especializada indica tecnologia, material e processo ideal. Suporte do arquivo à entrega final.',tag:'SUPORTE'},
          {icon:'location_on',num:'05',title:'Hub de Inovação',body:'Parque Tecnológico Damha II, São Carlos – SP. Polo tecnológico próximo à USP e UFSCar.',tag:'SÃO CARLOS'},
          {icon:'local_shipping',num:'06',title:'Entrega Ágil',body:'Orçamento em até 24h, produção ágil, atendimento nacional com prazo definido desde o primeiro contato.',tag:'LOGÍSTICA'},
        ].map(card => (

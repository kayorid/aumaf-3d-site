---
export const prerender = true
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import InstagramFeed from '../components/instagram/InstagramFeed.astro'
import { COMPANY } from '../lib/company'

const description = 'Solicite orçamento de impressão 3D na AUMAF 3D. Envie seu arquivo .STL, .X_T, .STEP ou .3MF e receba retorno em até 24 horas. São Carlos – SP.'

const projectTypes = [
  'Prototipagem',
  'Peça Funcional',
  'Metal',
  'Modelagem 3D',
  'Engenharia Reversa',
  'Outro',
]

const infoCards = [
  {
    icon: 'location_on',
    label: 'Endereço',
    value: `${COMPANY.address.streetAddress}\n${COMPANY.address.neighborhood}\n${COMPANY.address.addressLocality} – ${COMPANY.address.addressRegion}`,
  },
  {
    icon: 'phone',
    label: 'WhatsApp',
    value: COMPANY.contact.phoneDisplay,
    href: COMPANY.contact.whatsapp,
    external: true,
    ariaLabel: `Falar pelo WhatsApp: ${COMPANY.contact.phoneDisplay} (abre em nova aba)`,
  },
  {
    icon: 'mail',
    label: 'Email',
    value: COMPANY.contact.email,
    href: `mailto:${COMPANY.contact.email}`,
  },
  {
    icon: 'schedule',
    label: 'Horário',
    value: COMPANY.hours.displayPt,
  },
]
---

<Base
  title="Contato — Orçamento de Impressão 3D em São Carlos"
  description={description}
  pageType="ContactPage"
  breadcrumb={[{ name: 'Contato', url: '/contato' }]}
  preloadImage="/images/bg-waves.webp"
>
  <Navbar currentPath="/contato" />

  <!-- Hero dark: headline esquerda + form direita -->
  <section class="min-h-screen bg-background pt-28 pb-20 relative overflow-hidden" aria-labelledby="hero-contato">
    <!-- Bg AI: signal waves (tema contato/conexão) -->
    <div class="absolute inset-0 pointer-events-none bg-no-repeat bg-cover bg-center opacity-[0.28]" aria-hidden="true" style="background-image:url('/images/bg-waves.webp');"></div>
    <div class="absolute inset-0 bg-tech-grid opacity-[0.18] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:linear-gradient(180deg,rgba(0,0,0,0.40) 0%,transparent 25%,rgba(0,0,0,0.55) 100%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 50% 60% at 0% 60%,rgba(97,197,79,0.06) 0%,transparent 55%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 40% 30% at 100% 10%,rgba(97,197,79,0.04) 0%,transparent 60%);"></div>

    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <Breadcrumb items={[{ name: 'Contato' }]} compact />
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Esquerda: headline + info -->
        <div class="pt-2">
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-6">Iniciar Projeto</span>
          <h1 id="hero-contato" class="text-display-xl font-bold uppercase text-white tracking-[-0.04em] leading-none mb-8">
            Solicite seu<br/>Orçamento<br/><span class="text-gradient-glow">em 24h.</span>
          </h1>
          <p class="text-body-lg text-tertiary leading-relaxed max-w-sm mb-12">
            Nossa equipe analisa seu arquivo em até 24 horas e retorna com orçamento detalhado, prazo definido e indicação do melhor material para sua aplicação.
          </p>

          <!-- Info cards -->
          <address class="not-italic space-y-4">
            {infoCards.map((info) => (
              <div class="flex items-start gap-4 p-5 glass-panel rounded-sm group hover:border-primary-container/30 transition-all duration-300">
                <span class="material-symbols-outlined text-primary-container text-xl mt-0.5 flex-shrink-0" aria-hidden="true" style="font-variation-settings:'FILL' 1;">{info.icon}</span>
                <div>
                  <span class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-1">{info.label}</span>
                  {info.href ? (
                    <a
                      href={info.href}
                      target={info.external ? '_blank' : undefined}
                      rel={info.external ? 'noopener noreferrer' : undefined}
                      aria-label={info.ariaLabel ?? undefined}
                      class="text-body-md text-on-surface hover:text-primary-container transition-colors whitespace-pre-line"
                    >
                      {info.value}
                    </a>
                  ) : (
                    <p class="text-body-md text-on-surface whitespace-pre-line">{info.value}</p>
                  )}
                </div>
              </div>
            ))}
          </address>
        </div>

        <!-- Direita: form -->
        <div class="glass-panel rounded-sm p-8 md:p-10 border border-white/8">
          <div class="flex items-center gap-3 mb-8 pb-6 border-b border-white/8">
            <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse-dot glow-effect" aria-hidden="true"></span>
            <span class="text-label-caps text-primary-container uppercase tracking-[0.2em]">Formulário de Projeto</span>
          </div>

          <!-- Banner de contexto — exibido quando o usuário chega via ?material= ou ?ref= -->
          <div
            id="context-banner"
            class="hidden mb-6 rounded-sm border border-primary-container/30 bg-primary-container/8 p-4 flex items-start gap-3"
            role="status"
            aria-live="polite"
          >
            <span class="material-symbols-outlined text-primary-container text-xl shrink-0 mt-0.5" aria-hidden="true" style="font-variation-settings:'FILL' 1;">target</span>
            <div class="min-w-0 flex-1">
              <p class="text-label-caps text-primary-container uppercase tracking-[0.18em] text-[10px] mb-1">Solicitando orçamento para</p>
              <p id="context-banner-text" class="text-body-md text-white font-medium leading-snug">—</p>
              <p id="context-banner-sub" class="text-code-data text-tertiary text-[11px] mt-1 hidden">—</p>
            </div>
            <button
              type="button"
              id="context-banner-clear"
              class="shrink-0 w-7 h-7 inline-flex items-center justify-center rounded-full text-on-surface-variant hover:text-error border border-transparent hover:border-error/40 transition-colors"
              aria-label="Remover contexto"
            ><span class="material-symbols-outlined text-base leading-none" aria-hidden="true">close</span></button>
          </div>

          <form id="contact-form" data-track-form="contact_form" class="space-y-8" novalidate aria-describedby="form-help">
            <p id="form-help" class="sr-only">Campos marcados com asterisco são obrigatórios.</p>
            <input type="hidden" name="material" id="material-hidden" value="" />
            <input type="hidden" name="ref" id="ref-hidden" value="" />

            <!-- Grupo: Dados do Solicitante -->
            <fieldset class="space-y-6 border-0 p-0 m-0">
              <legend class="sr-only">Seus dados</legend>

              <!-- Nome + Sobrenome -->
              <div class="grid grid-cols-2 gap-6">
                <div>
                  <label for="nome" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                    Nome <span aria-hidden="true" class="text-primary-container">*</span>
                    <span class="sr-only">(obrigatório)</span>
                  </label>
                  <input
                    id="nome"
                    name="nome"
                    type="text"
                    required
                    autocomplete="given-name"
                    placeholder="João"
                    aria-describedby="nome-error"
                    aria-invalid="false"
                    class="input-underline"
                  />
                  <p id="nome-error" role="alert" class="text-error-container text-xs mt-1 hidden"></p>
                </div>
                <div>
                  <label for="sobrenome" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                    Sobrenome <span aria-hidden="true" class="text-primary-container">*</span>
                    <span class="sr-only">(obrigatório)</span>
                  </label>
                  <input
                    id="sobrenome"
                    name="sobrenome"
                    type="text"
                    required
                    autocomplete="family-name"
                    placeholder="Silva"
                    aria-describedby="sobrenome-error"
                    aria-invalid="false"
                    class="input-underline"
                  />
                  <p id="sobrenome-error" role="alert" class="text-error-container text-xs mt-1 hidden"></p>
                </div>
              </div>

              <!-- Email + Telefone -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                    Email <span aria-hidden="true" class="text-primary-container">*</span>
                    <span class="sr-only">(obrigatório)</span>
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    inputmode="email"
                    placeholder="joao@empresa.com"
                    aria-describedby="email-hint email-error"
                    aria-invalid="false"
                    class="input-underline"
                  />
                  <p id="email-hint" class="sr-only">Usaremos para retornar com o orçamento.</p>
                  <p id="email-error" role="alert" class="text-error-container text-xs mt-1 hidden"></p>
                </div>
                <div>
                  <label for="telefone" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                    Telefone / WhatsApp
                  </label>
                  <input
                    id="telefone"
                    name="telefone"
                    type="tel"
                    autocomplete="tel"
                    inputmode="tel"
                    placeholder="(16) 99999-9999"
                    class="input-underline"
                  />
                </div>
              </div>

              <!-- Empresa -->
              <div>
                <label for="empresa" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                  Empresa
                </label>
                <input
                  id="empresa"
                  name="empresa"
                  type="text"
                  autocomplete="organization"
                  placeholder="Nome da empresa (opcional)"
                  class="input-underline"
                />
              </div>
            </fieldset>

            <!-- Grupo: Sobre o Projeto -->
            <fieldset class="space-y-6 border-0 p-0 m-0">
              <legend class="sr-only">Sobre o projeto</legend>

              <!-- Tipo de projeto (radiogroup) -->
              <div>
                <span id="tipo-label" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                  Tipo de Projeto
                </span>
                <div class="flex flex-wrap gap-2" role="radiogroup" aria-labelledby="tipo-label" id="subject-pills">
                  {projectTypes.map((s, i) => (
                    <button
                      type="button"
                      role="radio"
                      data-value={s}
                      aria-checked={i === 0 ? 'true' : 'false'}
                      tabindex={i === 0 ? '0' : '-1'}
                      class:list={['pill transition-all duration-200 hover:border-primary-container/70 cursor-pointer', i === 0 ? 'pill-active' : '']}
                    >
                      {s}
                    </button>
                  ))}
                </div>
                <input type="hidden" name="assunto" value={projectTypes[0]} id="assunto-hidden" />
              </div>

              <!-- Mensagem -->
              <div>
                <label for="mensagem" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                  Descreva o Projeto <span aria-hidden="true" class="text-primary-container">*</span>
                  <span class="sr-only">(obrigatório)</span>
                </label>
                <textarea
                  id="mensagem"
                  name="mensagem"
                  rows="4"
                  required
                  placeholder="Descreva a peça, material desejado, quantidade e prazo..."
                  aria-describedby="mensagem-error"
                  aria-invalid="false"
                  class="input-underline resize-none w-full"
                ></textarea>
                <p id="mensagem-error" role="alert" class="text-error-container text-xs mt-1 hidden"></p>
              </div>

              <!-- Upload de arquivo -->
              <div>
                <label for="file-input" class="text-label-caps text-on-surface-variant uppercase tracking-widest block mb-2">
                  Arquivo do Projeto (opcional)
                </label>
                <div
                  id="drop-zone"
                  class="relative border border-dashed border-white/30 rounded-sm p-8 text-center hover:border-primary-container/60 focus-within:border-primary-container transition-all duration-300 cursor-pointer group"
                >
                  <span class="material-symbols-outlined text-3xl text-on-surface-variant group-hover:text-primary-container transition-colors block mb-3" aria-hidden="true">upload_file</span>
                  <p class="text-body-md text-on-surface mb-1">Arraste ou clique para fazer upload</p>
                  <p class="text-code-data text-tertiary">3D: .STL .X_T .STEP .3MF · Complementares: .PDF .JPG .PNG — máx. 15MB</p>
                  <input
                    id="file-input"
                    type="file"
                    name="arquivo"
                    accept=".stl,.x_t,.step,.stp,.3mf,.pdf,.jpg,.jpeg,.png,.webp"
                    aria-describedby="file-name"
                    class="absolute inset-0 opacity-0 cursor-pointer"
                  />
                </div>
                <p id="file-name" aria-live="polite" class="text-code-data text-primary-container mt-2 hidden"></p>
              </div>
            </fieldset>

            <!-- Consentimento de marketing (opcional) — LGPD art. 7º, I -->
            <label for="marketing-consent" class="flex items-start gap-3 p-4 rounded-sm border border-white/10 hover:border-white/20 transition-colors cursor-pointer">
              <input
                id="marketing-consent"
                name="marketingConsent"
                type="checkbox"
                class="mt-0.5 w-4 h-4 accent-primary-container shrink-0"
              />
              <span class="text-sm text-tertiary leading-relaxed">
                Quero receber comunicações comerciais, novidades técnicas e conteúdo do blog por e-mail e/ou WhatsApp. Você pode revogar este consentimento a qualquer momento em
                <a href="/preferencias-de-cookies" class="text-primary-container hover:underline">Preferências</a>
                ou enviando um e-mail ao Encarregado.
              </span>
            </label>

            <!-- Submit -->
            <button
              id="submit-btn"
              type="submit"
              aria-busy="false"
              class="w-full inline-flex items-center justify-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-5 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300 disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <span id="submit-icon" class="material-symbols-outlined text-base" aria-hidden="true" style="font-variation-settings:'FILL' 1;">send</span>
              <span id="submit-text">Enviar Projeto</span>
            </button>

            <p class="text-code-data text-tertiary text-center">Retornamos em até 24 horas úteis.</p>

            <!-- Aviso LGPD inline — base legal art. 7º, V (execução de contrato/procedimento preliminar) -->
            <p class="text-xs text-on-surface-variant text-center leading-relaxed">
              Ao enviar, você concorda com a nossa
              <a href="/politica-de-privacidade" class="text-primary-container hover:underline" data-track="contato_legal_link" data-track-target="politica-privacidade">Política de Privacidade</a>.
              Seus dados serão usados para responder sua solicitação de orçamento conforme o art. 7º, V da LGPD.
              Conheça
              <a href="/lgpd/direitos" class="text-primary-container hover:underline" data-track="contato_legal_link" data-track-target="direitos-lgpd">seus direitos</a>.
            </p>
          </form>

          <!-- Success state -->
          <div id="form-success" tabindex="-1" class="hidden text-center py-12 outline-none" role="status" aria-live="polite">
            <div class="w-16 h-16 rounded-full bg-primary-container/15 border border-primary-container/30 flex items-center justify-center mx-auto mb-6">
              <span class="material-symbols-outlined text-primary-container text-3xl" aria-hidden="true" style="font-variation-settings:'FILL' 1;">check_circle</span>
            </div>
            <h2 class="text-headline-md font-bold uppercase text-white mb-3">Projeto Recebido!</h2>
            <p class="text-body-md text-tertiary leading-relaxed max-w-xs mx-auto">Nossa equipe entrará em contato em até 24 horas úteis com orçamento detalhado.</p>
            <a
              href={COMPANY.contact.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Acompanhar o pedido pelo WhatsApp (abre em nova aba)"
              class="mt-8 inline-flex items-center gap-2 border border-[#25D366]/40 text-[#25D366] text-label-caps uppercase tracking-[0.15em] px-6 py-3 rounded-sm hover:bg-[#25D366]/10 transition-all duration-300 text-[11px]"
            >
              Acompanhar pelo WhatsApp
              <span class="material-symbols-outlined text-sm" aria-hidden="true">open_in_new</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =============================================
       INSTAGRAM FEED — bastidores @aumaf3d
       ============================================= -->
  <InstagramFeed variant="contato" />

  <!-- WhatsApp direto -->
  <section class="bg-surface-low py-16 border-t border-white/5" aria-labelledby="whatsapp-direto">
    <h2 id="whatsapp-direto" class="sr-only">Contato direto pelo WhatsApp</h2>
    <div class="max-w-[1600px] mx-auto px-edge">
      <div class="glass-panel rounded-sm p-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-sm bg-[#25D366]/10 border border-[#25D366]/30 flex items-center justify-center">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true" focusable="false">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </div>
          <div>
            <p class="text-body-md font-semibold text-white">Prefere pelo WhatsApp?</p>
            <p class="text-sm text-tertiary">Fale diretamente com nossa equipe técnica agora.</p>
          </div>
        </div>
        <a
          href={`${COMPANY.contact.whatsapp}?text=${encodeURIComponent('Olá! Gostaria de solicitar um orçamento para impressão 3D.')}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Abrir conversa no WhatsApp da AUMAF 3D (abre em nova aba)"
          class="inline-flex items-center gap-2 border border-[#25D366]/40 text-[#25D366] text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm hover:bg-[#25D366]/10 transition-all duration-300 whitespace-nowrap"
        >
          Abrir WhatsApp
          <span class="material-symbols-outlined text-base" aria-hidden="true">open_in_new</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  import { captureUtm, readUtm } from '../lib/utm'

  // Captura UTMs da URL atual e persiste em sessionStorage
  captureUtm()

  // ── Tipo de Projeto: radiogroup acessível ──────────────────
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('#subject-pills [role="radio"]'))
  const hiddenInput = document.getElementById('assunto-hidden') as HTMLInputElement | null
  const materialHidden = document.getElementById('material-hidden') as HTMLInputElement | null
  const refHidden = document.getElementById('ref-hidden') as HTMLInputElement | null
  const mensagemEl = document.getElementById('mensagem') as HTMLTextAreaElement | null
  const banner = document.getElementById('context-banner')
  const bannerText = document.getElementById('context-banner-text')
  const bannerSub = document.getElementById('context-banner-sub')
  const bannerClear = document.getElementById('context-banner-clear')

  function selectPill(pill: HTMLButtonElement) {
    pills.forEach((p) => {
      const active = p === pill
      p.setAttribute('aria-checked', active ? 'true' : 'false')
      p.tabIndex = active ? 0 : -1
      p.classList.toggle('pill-active', active)
    })
    if (hiddenInput) hiddenInput.value = pill.dataset.value || ''
  }

  // ── Contexto via querystring (?material= ou ?ref=) ─────────
  // Ativa banner, pré-seleciona pill e pré-preenche mensagem
  const params = new URLSearchParams(location.search)
  const materialParam = params.get('material')?.trim() || ''
  const refParam = params.get('ref')?.trim() || ''

  // Mapa "Categoria material → pill Tipo de Projeto"
  // Usado para auto-selecionar a pill apropriada quando vem ?material=
  const materialToPillHints: Array<{ match: RegExp; pill: string }> = [
    { match: /metal|316l|titânio|titanio|alumínio|aluminio|inox|aço|aco/i, pill: 'Metal' },
    { match: /resina|sla|tough|clear|dental|biocompatível|biocompativel/i, pill: 'Prototipagem' },
    { match: /tpu|flex|elastômero|elastomero/i, pill: 'Peça Funcional' },
    { match: /pa|nylon|carbono|fibra|abs|petg|asa|policarbonato|pc/i, pill: 'Peça Funcional' },
    { match: /pla/i, pill: 'Prototipagem' },
  ]

  function pickPillForMaterial(material: string): HTMLButtonElement | null {
    for (const hint of materialToPillHints) {
      if (hint.match.test(material)) {
        return pills.find((p) => p.dataset.value === hint.pill) ?? null
      }
    }
    return pills.find((p) => p.dataset.value === 'Peça Funcional') ?? null
  }

  if (materialParam) {
    if (materialHidden) materialHidden.value = materialParam
    if (banner && bannerText) {
      bannerText.textContent = materialParam
      if (bannerSub) {
        bannerSub.textContent = 'Material pré-selecionado · Descreva geometria, quantidade e prazo abaixo.'
        bannerSub.classList.remove('hidden')
      }
      banner.classList.remove('hidden')
    }
    const targetPill = pickPillForMaterial(materialParam)
    if (targetPill) selectPill(targetPill)
    if (mensagemEl && !mensagemEl.value) {
      mensagemEl.value = `Olá! Tenho interesse em um orçamento usando o material ${materialParam}.\n\nDetalhes da peça (geometria, quantidade, prazo desejado):\n`
      mensagemEl.dispatchEvent(new Event('input'))
    }
  } else if (refParam) {
    if (refHidden) refHidden.value = refParam
    if (banner && bannerText) {
      bannerText.textContent = `Projeto de referência: ${refParam}`
      if (bannerSub) {
        bannerSub.textContent = 'Vimos que você consultou esse projeto do portfolio. Vamos partir dele.'
        bannerSub.classList.remove('hidden')
      }
      banner.classList.remove('hidden')
    }
    if (mensagemEl && !mensagemEl.value) {
      mensagemEl.value = `Olá! Tenho um projeto similar ao "${refParam}" do portfolio. Gostaria de orçamento para:\n\n`
      mensagemEl.dispatchEvent(new Event('input'))
    }
  }

  function slugify(s: string): string {
    return s
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 60)
  }

  bannerClear?.addEventListener('click', () => {
    banner?.classList.add('hidden')
    if (materialHidden) materialHidden.value = ''
    if (refHidden) refHidden.value = ''
    // remove ?material= / ?ref= da URL sem reload
    const url = new URL(location.href)
    url.searchParams.delete('material')
    url.searchParams.delete('ref')
    history.replaceState(null, '', url.toString())
  })

  pills.forEach((pill, i) => {
    pill.addEventListener('click', () => {
      selectPill(pill)
      pill.focus()
    })
    pill.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault()
        const next = pills[(i + 1) % pills.length]
        selectPill(next)
        next.focus()
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault()
        const prev = pills[(i - 1 + pills.length) % pills.length]
        selectPill(prev)
        prev.focus()
      } else if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault()
        selectPill(pill)
      }
    })
  })

  // ── Validação inline ──────────────────────────────────────
  const form = document.getElementById('contact-form') as HTMLFormElement | null
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null
  const submitIcon = document.getElementById('submit-icon')
  const submitText = document.getElementById('submit-text')
  const successEl = document.getElementById('form-success')

  function setError(fieldId: string, message: string | null) {
    const input = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement | null
    const errorEl = document.getElementById(`${fieldId}-error`)
    if (!input || !errorEl) return
    if (message) {
      input.setAttribute('aria-invalid', 'true')
      errorEl.textContent = message
      errorEl.classList.remove('hidden')
    } else {
      input.setAttribute('aria-invalid', 'false')
      errorEl.textContent = ''
      errorEl.classList.add('hidden')
    }
  }

  function validate(): boolean {
    let ok = true
    const required = ['nome', 'sobrenome', 'email', 'mensagem'] as const
    required.forEach((f) => {
      const input = document.getElementById(f) as HTMLInputElement | HTMLTextAreaElement | null
      if (!input) return
      if (!input.value.trim()) {
        setError(f, 'Campo obrigatório.')
        ok = false
      } else if (f === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim())) {
        setError(f, 'Email inválido.')
        ok = false
      } else {
        setError(f, null)
      }
    })
    return ok
  }

  ;['nome', 'sobrenome', 'email', 'mensagem'].forEach((id) => {
    document.getElementById(id)?.addEventListener('blur', () => {
      const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null
      if (input?.getAttribute('aria-invalid') === 'true') {
        if (input.value.trim()) setError(id, null)
      }
    })
  })

  function showGenericError() {
    const mensagemEl = document.getElementById('mensagem-error')
    if (mensagemEl) {
      mensagemEl.textContent = 'Erro ao enviar. Tente novamente ou fale pelo WhatsApp.'
      mensagemEl.classList.remove('hidden')
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!validate() || !submitBtn || !submitIcon || !submitText) return

    submitBtn.disabled = true
    submitBtn.setAttribute('aria-busy', 'true')
    submitIcon.textContent = 'hourglass_top'
    submitText.textContent = 'Enviando...'

    const nome = (document.getElementById('nome') as HTMLInputElement).value.trim()
    const sobrenome = (document.getElementById('sobrenome') as HTMLInputElement).value.trim()
    const email = (document.getElementById('email') as HTMLInputElement).value.trim()
    const telefone = (document.getElementById('telefone') as HTMLInputElement).value.trim()
    const empresa = (document.getElementById('empresa') as HTMLInputElement).value.trim()
    const mensagemUsuario = (document.getElementById('mensagem') as HTMLTextAreaElement).value.trim()
    const assunto = hiddenInput?.value ?? ''
    const material = materialHidden?.value.trim() ?? ''
    const ref = refHidden?.value.trim() ?? ''
    const arquivo = (document.getElementById('file-input') as HTMLInputElement | null)?.files?.[0] ?? null
    const utm = readUtm()

    // ── Enriquecer mensagem com header estruturado contendo TODOS os
    //    metadados que o schema atual de leads não tem campos dedicados.
    //    Garante que admin/email/Botyio recebam o contexto completo do lead.
    const headerLines: string[] = ['━━━ DADOS DO PROJETO ━━━']
    if (assunto) headerLines.push(`Tipo: ${assunto}`)
    if (material) headerLines.push(`Material de interesse: ${material}`)
    if (ref) headerLines.push(`Projeto de referência (portfolio): ${ref}`)
    if (empresa) headerLines.push(`Empresa: ${empresa}`)
    if (telefone) headerLines.push(`Telefone/WhatsApp: ${telefone}`)
    if (arquivo) {
      const sizeKb = (arquivo.size / 1024).toFixed(1)
      headerLines.push(`Arquivo anexo: ${arquivo.name} (${sizeKb} KB) — solicitar via WhatsApp`)
    }
    headerLines.push('━━━━━━━━━━━━━━━━━━━━━━━━')
    const message = `${headerLines.join('\n')}\n\n${mensagemUsuario}`

    // ── Source granular para segmentação no admin/Botyio
    let sourceTag = 'site-contato'
    if (material) sourceTag = `site-contato/material-${slugify(material)}`
    else if (ref) sourceTag = `site-contato/portfolio-${slugify(ref)}`
    else if (assunto) sourceTag = `site-contato/${slugify(assunto)}`

    const marketingConsentEl = document.getElementById('marketing-consent') as HTMLInputElement | null
    const marketingConsent = !!marketingConsentEl?.checked

    const payload = {
      name: `${nome} ${sobrenome}`.trim(),
      email,
      ...(telefone ? { phone: telefone } : {}),
      message,
      source: sourceTag,
      referrer: document.referrer || undefined,
      landingPage: `${location.pathname}${location.search}` || undefined,
      marketingConsent,
      ...utm,
    }

    try {
      const apiUrl = import.meta.env.PUBLIC_API_URL
      if (!apiUrl || typeof apiUrl !== 'string' || !/^https?:\/\//.test(apiUrl)) {
        throw new Error('PUBLIC_API_URL ausente ou inválido no build do site')
      }
      const res = await fetch(`${apiUrl.replace(/\/$/, '')}/api/v1/leads`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })

      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }

      // Correlaciona a sessão de analytics com o lead criado (fecha funil lead_conversion).
      try {
        const body = (await res.clone().json()) as { data?: { id?: string } }
        const leadId = body?.data?.id
        const a = await import('@aumaf/analytics-sdk')
        if (leadId) a.identify({ leadId })
      } catch { /* falha silenciosa — não bloquear UX do form */ }

      form.style.display = 'none'
      if (successEl) {
        successEl.classList.remove('hidden')
        ;(successEl as HTMLElement).focus()
      }
    } catch {
      submitBtn.disabled = false
      submitBtn.setAttribute('aria-busy', 'false')
      submitIcon.textContent = 'send'
      submitText.textContent = 'Enviar Projeto'
      showGenericError()
    }
  })

  // ── File drop zone ────────────────────────────────────────
  const dropZone = document.getElementById('drop-zone')
  const fileInput = document.getElementById('file-input') as HTMLInputElement | null
  const fileName = document.getElementById('file-name')

  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault()
    dropZone.classList.add('border-primary-container/70')
  })
  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-primary-container/70')
  })
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault()
    dropZone.classList.remove('border-primary-container/70')
    const files = (e as DragEvent).dataTransfer?.files
    if (files?.length && fileInput) {
      fileInput.files = files
      showFileName(files[0].name)
    }
  })
  fileInput?.addEventListener('change', () => {
    if (fileInput.files?.[0]) showFileName(fileInput.files[0].name)
  })

  function showFileName(name: string) {
    if (fileName) {
      fileName.textContent = `Arquivo selecionado: ${name}`
      fileName.classList.remove('hidden')
    }
  }
</script>

---
export const prerender = true
import Base from '../layouts/Base.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { definedTermSetSchema } from '../lib/schemas'
import { COMPANY } from '../lib/company'
import { terms } from '../data/glossario'

const description =
  'Glossário técnico de manufatura aditiva — FDM, SLA, SLS, SLM, PLA, PA12, ASA, 316L, infill, lattice, DfAM e mais. Definições objetivas para engenheiros, designers e compradores.'

const url = `${COMPANY.url}/glossario`
// Lista canônica em src/data/glossario.ts (mesma fonte usada por scripts/generate-llm-sources.ts).
---

<Base
  title="Glossário técnico de manufatura aditiva"
  description={description}
  pageType="WebPage"
  schemas={[
    definedTermSetSchema({
      name: 'Glossário de Manufatura Aditiva — AUMAF 3D',
      url,
      terms: terms.map((t) => ({ term: t.term, definition: t.definition, id: t.slug })),
    }),
  ]}
>
  <Navbar currentPath="/glossario" />

  <main class="bg-background pt-28 pb-section relative overflow-hidden">
    <div class="absolute inset-0 bg-tech-grid opacity-[0.12] pointer-events-none" aria-hidden="true"></div>

    <section class="max-w-[1100px] mx-auto px-edge relative z-10">
      <Breadcrumb items={[{ name: 'Glossário' }]} compact />

      <header class="mt-6 mb-12">
        <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-4">Referência // Manufatura Aditiva</span>
        <h1 class="text-display-lg font-bold uppercase text-white tracking-[-0.03em] leading-[0.95] mb-6">
          Glossário<br/><span class="text-gradient-glow">técnico.</span>
        </h1>
        <p class="text-body-lg text-tertiary leading-relaxed max-w-3xl">
          Definições objetivas dos {terms.length} termos essenciais de manufatura aditiva — processos, materiais, conceitos de design e formatos de arquivo. Use como referência durante sua especificação ou em conversas com o setor de compras.
        </p>
      </header>

      <!-- Índice em colunas -->
      <nav aria-label="Índice do glossário" class="glass-panel p-6 rounded-sm border border-white/8 mb-12">
        <p class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] mb-4">Ir para</p>
        <ul role="list" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-2 text-sm">
          {terms.map((t) => (
            <li><a href={`#${t.slug}`} class="text-tertiary hover:text-primary-container transition-colors">{t.term.split(' (')[0]}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Termos -->
      <dl class="space-y-8">
        {terms.map((t) => (
          <article id={t.slug} class="scroll-mt-32 border-l-2 border-primary-container/40 pl-6">
            <dt class="text-headline-sm font-bold text-white uppercase tracking-[-0.01em] mb-2">{t.term}</dt>
            <dd class="text-body-md text-tertiary leading-relaxed">{t.definition}</dd>
          </article>
        ))}
      </dl>

      <!-- CTA final -->
      <div class="mt-16 glass-panel rounded-sm border border-white/8 p-8 text-center">
        <p class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-3">Não achou um termo?</p>
        <h2 class="text-headline-md font-bold text-white uppercase tracking-[-0.02em] mb-4">Fale com a equipe técnica.</h2>
        <p class="text-body-md text-tertiary mb-6 max-w-2xl mx-auto">Nossa equipe responde dúvidas de especificação em até 24h. Mande sua peça ou seu desenho técnico — sugerimos processo, material e acabamento.</p>
        <a
          href="/contato"
          class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300"
          data-track="cta_quote_hero"
          data-track-source="glossario"
        >
          Solicitar orçamento
          <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Base>

---
export const prerender = true

import Base from '../../layouts/Base.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import { COMPANY } from '../../lib/company'
import { itemListSchema } from '../../lib/schemas'
import { fetchPublicPosts } from '../../lib/api'
import { formatPostDateShort } from '../../lib/render-post'

// Carrega todos os posts publicados em build time
const { data: posts } = await fetchPublicPosts({ pageSize: 50 })

const description =
  'Blog AUMAF 3D — guias técnicos de manufatura aditiva, comparativos de processos (FDM, SLA, SLS), seleção de materiais, cases de sucesso e inovação em impressão 3D industrial.'

const featured = posts.find((p) => p.featured)
const others = posts.filter((p) => !p.featured)

const schemas = [
  itemListSchema(
    posts.map((p) => ({
      name: p.title,
      url: `${COMPANY.url}/blog/${p.slug}`,
      description: p.excerpt ?? '',
    })),
  ),
]

const totalDisplay = posts.length
const lastUpdate = posts[0]?.publishedAt ?? new Date().toISOString()
---

<Base
  title="Blog — Manufatura Aditiva e Impressão 3D Industrial"
  description={description}
  pageType="CollectionPage"
  breadcrumb={[{ name: 'Blog', url: '/blog' }]}
  schemas={schemas}
>
  <Navbar currentPath="/blog" />

  <!-- Hero -->
  <section class="bg-background pt-28 pb-20 relative overflow-hidden" aria-labelledby="hero-blog">
    <div class="absolute inset-0 bg-tech-grid opacity-25 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 55% 50% at 70% 0%,rgba(97,197,79,0.06) 0%,transparent 60%);"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(ellipse 30% 40% at 5% 100%,rgba(97,197,79,0.04) 0%,transparent 60%);"></div>
    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <Breadcrumb items={[{ name: 'Blog' }]} compact />
      <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-6">Conteúdo // Conhecimento</span>
      <h1 id="hero-blog" class="text-display-xl font-bold uppercase text-white text-glow-white tracking-[-0.04em] leading-none mb-6">Blog.</h1>
      <p class="text-body-lg text-tertiary max-w-2xl leading-relaxed">
        O guia de manufatura aditiva por especialistas da AUMAF 3D. Conteúdo técnico de quem fabrica peças, não de quem escreve sobre elas.
      </p>
      <ul role="list" class="flex flex-wrap items-center gap-x-6 gap-y-2 mt-8">
        <li class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-container" aria-hidden="true"></span>
          <span class="text-code-data text-on-surface-variant text-[11px] uppercase tracking-widest">{totalDisplay} artigos publicados</span>
        </li>
        <li class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-tertiary" aria-hidden="true"></span>
          <span class="text-code-data text-on-surface-variant text-[11px] uppercase tracking-widest">
            Atualizado em <time datetime={lastUpdate}>{formatPostDateShort(lastUpdate)}</time>
          </span>
        </li>
      </ul>
    </div>
    <div class="line-glow-bright absolute bottom-0 left-[5%] right-[5%] pointer-events-none" aria-hidden="true"></div>
  </section>

  <!-- Post em destaque -->
  {featured && (
    <section class="bg-background pt-16 pb-section" aria-labelledby="featured-heading">
      <h2 id="featured-heading" class="sr-only">Artigo em destaque</h2>
      <div class="max-w-[1600px] mx-auto px-edge">
        <article aria-label={`Artigo em destaque: ${featured.title}`}>
          <a href={`/blog/${featured.slug}`} class="group block focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary-container rounded-sm">
            <div class="glass-panel rounded-sm overflow-hidden border border-primary-container/15 relative hover:border-primary-container/40 transition-all duration-300">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-container/40 to-transparent" aria-hidden="true"></div>
              <div class="grid grid-cols-1 lg:grid-cols-5">
                <div class="lg:col-span-3 relative h-64 lg:h-auto min-h-[300px] bg-gradient-to-br from-primary-container/10 via-surface-high to-surface-base overflow-hidden">
                  {featured.coverImageUrl ? (
                    <img
                      src={featured.coverImageUrl}
                      alt={`Capa: ${featured.title}`}
                      width="1280"
                      height="720"
                      loading="lazy"
                      decoding="async"
                      class="absolute inset-0 w-full h-full object-cover"
                    />
                  ) : (
                    <>
                      <div class="absolute inset-0 bg-tech-grid opacity-40" aria-hidden="true"></div>
                      <div class="absolute inset-0" aria-hidden="true" style="background:radial-gradient(circle at 30% 60%,rgba(97,197,79,0.12) 0%,transparent 65%);"></div>
                      <div class="absolute inset-0 flex items-center justify-center opacity-20" aria-hidden="true">
                        <svg viewBox="0 0 200 200" fill="none" class="w-48 h-48" focusable="false">
                          <rect x="20" y="20" width="160" height="160" stroke="#61c54f" stroke-width="0.5"/>
                          <rect x="50" y="50" width="100" height="100" stroke="#61c54f" stroke-width="0.5"/>
                          <rect x="80" y="80" width="40" height="40" stroke="#61c54f" stroke-width="1" fill="rgba(97,197,79,0.05)"/>
                          <line x1="20" y1="100" x2="180" y2="100" stroke="#61c54f" stroke-width="0.3"/>
                          <line x1="100" y1="20" x2="100" y2="180" stroke="#61c54f" stroke-width="0.3"/>
                          <circle cx="100" cy="100" r="8" fill="#61c54f" opacity="0.6"/>
                          <circle cx="100" cy="100" r="20" stroke="#61c54f" stroke-width="0.5"/>
                          <circle cx="100" cy="100" r="40" stroke="#61c54f" stroke-width="0.3"/>
                        </svg>
                      </div>
                    </>
                  )}
                  <div class="absolute top-4 left-4">
                    <span class="pill-active">Destaque</span>
                  </div>
                </div>
                <div class="lg:col-span-2 p-10 flex flex-col justify-center bg-surface-base">
                  {featured.category && (
                    <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/60 text-primary-container text-label-caps uppercase tracking-widest mb-4 w-fit">{featured.category.name}</span>
                  )}
                  <h3 class="text-headline-md font-bold uppercase text-white tracking-[-0.02em] mb-4 group-hover:text-primary-container transition-colors duration-200">{featured.title}</h3>
                  {featured.excerpt && (
                    <p class="text-body-md text-tertiary leading-relaxed mb-6">{featured.excerpt}</p>
                  )}
                  <div class="flex items-center gap-4 text-code-data text-on-surface-variant mb-6">
                    <time datetime={featured.publishedAt}>{formatPostDateShort(featured.publishedAt)}</time>
                    {featured.readingTimeMin && (
                      <>
                        <span class="w-px h-3 bg-white/30" aria-hidden="true"></span>
                        <span><span class="sr-only">Tempo de leitura: </span>{featured.readingTimeMin} min leitura</span>
                      </>
                    )}
                  </div>
                  <span class="inline-flex items-center gap-2 text-label-caps text-primary-container uppercase tracking-[0.15em] group-hover:gap-4 transition-all duration-200">
                    Ler artigo completo <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
                  </span>
                </div>
              </div>
            </div>
          </a>
        </article>
      </div>
    </section>
  )}

  <!-- Grid de posts -->
  <section class="bg-surface-low border-t border-white/8 py-section" aria-labelledby="all-posts">
    <div class="max-w-[1600px] mx-auto px-edge">
      <header class="mb-12 border-b border-white/12 pb-8">
        <h2 id="all-posts" class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Todos os Posts</h2>
      </header>
      {others.length === 0 && !featured && (
        <p class="text-body-md text-on-surface-variant">Em breve, novos artigos.</p>
      )}
      <ul role="list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {others.map((post) => (
          <li>
            <article class="h-full">
              <a href={`/blog/${post.slug}`} class="group cursor-pointer block focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary-container rounded-sm">
                <div class="relative aspect-[4/3] rounded-sm overflow-hidden bg-gradient-to-br from-surface-high to-surface-base mb-5 border border-white/8 hover:border-primary-container/30 transition-all duration-300">
                  {post.coverImageUrl ? (
                    <img
                      src={post.coverImageUrl}
                      alt={`Capa do artigo: ${post.title}`}
                      width="640"
                      height="480"
                      loading="lazy"
                      decoding="async"
                      class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : (
                    <>
                      <div class="absolute inset-0 bg-tech-grid opacity-25" aria-hidden="true"></div>
                      <div class="absolute inset-0 flex items-center justify-center opacity-20 group-hover:opacity-30 transition-opacity duration-300" aria-hidden="true">
                        <span class="material-symbols-outlined text-5xl text-primary-container">description</span>
                      </div>
                    </>
                  )}
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>
                  {post.category && (
                    <div class="absolute top-4 left-4">
                      <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/60 text-primary-container text-label-caps uppercase tracking-widest text-[10px]">{post.category.name}</span>
                    </div>
                  )}
                </div>
                <h3 class="text-body-lg font-medium text-on-surface group-hover:text-white transition-colors duration-200 leading-snug mb-3">{post.title}</h3>
                {post.excerpt && (
                  <p class="text-sm text-tertiary leading-relaxed mb-3">{post.excerpt}</p>
                )}
                <div class="flex items-center gap-3 text-code-data text-on-surface-variant text-[12px]">
                  {post.readingTimeMin && (
                    <>
                      <span class="material-symbols-outlined text-sm" aria-hidden="true">timer</span>
                      <span><span class="sr-only">Tempo de leitura: </span>{post.readingTimeMin} min leitura</span>
                      <span class="w-px h-3 bg-white/30" aria-hidden="true"></span>
                    </>
                  )}
                  <time datetime={post.publishedAt}>{formatPostDateShort(post.publishedAt)}</time>
                </div>
              </a>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <Footer />
</Base>

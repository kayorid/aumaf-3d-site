---
import Base from '../../layouts/Base.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'

const posts = [
  { cat: 'Guia Técnico', title: 'FDM, SLA ou SLS? O guia definitivo para escolher o processo certo', date: 'Mai 2026', time: '8 min', featured: true, href: '/blog/fdm-vs-sla-vs-sls', excerpt: 'Qual tecnologia entrega melhor resultado para o seu projeto? Comparamos custo, tolerância, materiais e casos de uso reais de cada processo.' },
  { cat: 'Materiais',    title: 'Guia Completo de Materiais: Como Escolher o Filamento Certo para Cada Aplicação',        date: 'Mai 2026', time: '6 min', featured: false, href: '/blog/guia-materiais-impressao-3d',      excerpt: 'PA CF15, PEEK, TPU, 316L — cada material tem seu nicho. Descubra qual é o ideal para carga, temperatura e acabamento do seu projeto.' },
  { cat: 'Case Study',   title: 'Case Completo: Fórmula SAE USP São Carlos 2024 — Do Arquivo à Pista',                   date: 'Mai 2026', time: '5 min', featured: false, href: '/blog/formula-sae-case-study-completo', excerpt: 'Como fabricamos 7 componentes estruturais e aerodinâmicos em 5 dias úteis para a competição mais exigente da engenharia estudantil.' },
  { cat: 'Engenharia',   title: 'Engenharia Reversa Passo a Passo: Como Replicar uma Peça Sem o Projeto Original',        date: 'Mai 2026', time: '7 min', featured: false, href: '/blog/engenharia-reversa-passo-a-passo',  excerpt: 'Scanner 3D, nuvem de pontos, reconstrução paramétrica e impressão final. O processo completo de replicação de peças descontinuadas.' },
  { cat: 'Parceria',     title: 'Parceria de Sucesso: AUMAF 3D e Equipe de Fórmula SAE da USP São Carlos',                date: 'Jun 2024', time: '1 min', featured: false, href: '/blog/formula-sae-usp-sao-carlos',      excerpt: 'Peças estruturais e aerodinâmicas para o carro de competição da equipe de Engenharia Mecânica da USP São Carlos.' },
  { cat: 'Inovação',     title: 'Construtora árabe lança edifício impresso mais alto do mundo',                            date: 'Out 2023', time: '2 min', featured: false, href: '/blog/construtora-arabe-edificio-mais-alto', excerpt: 'Dubai sedia a estrutura impressa em 3D de maior altitude já registrada — e os materiais utilizados surpreendem.' },
]
---

<Base title="Blog" description="O guia de manufatura aditiva por especialistas da AUMAF 3D. Materiais, processos, cases e inovações.">
  <Navbar currentPath="/blog" />

  <!-- Hero -->
  <section class="bg-background pt-36 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-tech-grid opacity-25 pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 55% 50% at 70% 0%,rgba(97,197,79,0.06) 0%,transparent 60%);"></div>
    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <span class="text-label-caps text-primary-container text-glow-sm uppercase tracking-[0.2em] block mb-5">Conteúdo // Conhecimento</span>
      <h1 class="text-display-xl font-bold uppercase text-white text-glow-white tracking-[-0.04em] leading-none mb-5">Blog.</h1>
      <p class="text-body-lg text-tertiary max-w-xl leading-relaxed">O guia de manufatura aditiva por especialistas da AUMAF 3D.</p>
    </div>
    <div class="line-glow-bright absolute bottom-0 left-[5%] right-[5%] pointer-events-none"></div>
  </section>

  <!-- Post em destaque -->
  <section class="bg-background pt-14 pb-section">
    <div class="max-w-[1600px] mx-auto px-edge">
      {posts.filter(p => p.featured).map(post => (
        <a href={post.href} class="group block">
          <div class="glass-panel rounded-sm overflow-hidden border border-primary-container/15 relative hover:border-primary-container/30 transition-all duration-300">
            <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-container/40 to-transparent"></div>
            <div class="grid grid-cols-1 lg:grid-cols-5">
              <!-- Visual -->
              <div class="lg:col-span-3 relative h-64 lg:h-auto min-h-[300px] bg-gradient-to-br from-primary-container/10 via-surface-high to-surface-base overflow-hidden">
                <div class="absolute inset-0 bg-tech-grid opacity-40"></div>
                <div class="absolute inset-0" style="background:radial-gradient(circle at 30% 60%,rgba(97,197,79,0.12) 0%,transparent 65%);"></div>
                <div class="absolute inset-0 flex items-center justify-center opacity-20">
                  <svg viewBox="0 0 200 200" fill="none" class="w-48 h-48">
                    <rect x="20" y="20" width="160" height="160" stroke="#61c54f" stroke-width="0.5"/>
                    <rect x="50" y="50" width="100" height="100" stroke="#61c54f" stroke-width="0.5"/>
                    <rect x="80" y="80" width="40" height="40" stroke="#61c54f" stroke-width="1" fill="rgba(97,197,79,0.05)"/>
                    <line x1="20" y1="100" x2="180" y2="100" stroke="#61c54f" stroke-width="0.3"/>
                    <line x1="100" y1="20" x2="100" y2="180" stroke="#61c54f" stroke-width="0.3"/>
                    <circle cx="100" cy="100" r="8" fill="#61c54f" opacity="0.6"/>
                    <circle cx="100" cy="100" r="20" stroke="#61c54f" stroke-width="0.5"/>
                    <circle cx="100" cy="100" r="40" stroke="#61c54f" stroke-width="0.3"/>
                  </svg>
                </div>
                <div class="absolute top-4 left-4"><span class="pill-active">Destaque</span></div>
                <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-primary-container/20 to-transparent animate-scan-line"></div>
                <div class="absolute top-2 left-2 w-4 h-4 border-t border-l border-primary-container/30"></div>
                <div class="absolute bottom-2 right-2 w-4 h-4 border-b border-r border-primary-container/30"></div>
              </div>
              <!-- Conteúdo -->
              <div class="lg:col-span-2 p-10 flex flex-col justify-center bg-surface-base">
                <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/50 text-primary-container text-label-caps uppercase tracking-widest mb-4 w-fit">{post.cat}</span>
                <h2 class="text-headline-md font-bold uppercase text-white tracking-[-0.02em] mb-4 group-hover:text-primary-container transition-colors duration-200">{post.title}</h2>
                <p class="text-body-md text-tertiary leading-relaxed mb-6">{post.excerpt}</p>
                <div class="flex items-center gap-4 text-code-data text-on-surface-variant mb-6">
                  <span>{post.date}</span>
                  <span class="w-px h-3 bg-white/20"></span>
                  <span>{post.time} leitura</span>
                </div>
                <span class="inline-flex items-center gap-2 text-label-caps text-primary-container uppercase tracking-[0.15em] group-hover:gap-4 transition-all duration-200">
                  Ler artigo <span class="material-symbols-outlined text-base">arrow_forward</span>
                </span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Grid de posts -->
  <section class="bg-surface-low border-t border-white/5 py-section">
    <div class="max-w-[1600px] mx-auto px-edge">
      <div class="mb-12 border-b border-white/8 pb-8">
        <h2 class="text-headline-lg font-bold uppercase text-white tracking-[-0.02em]">Todos os Posts</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {posts.filter(p => !p.featured).map(post => (
          <a href={post.href} class="group cursor-pointer block">
            <div class="relative h-48 rounded-sm overflow-hidden bg-gradient-to-br from-surface-high to-surface-base mb-5 border border-white/5 hover:border-primary-container/15 transition-all duration-300">
              <div class="absolute inset-0 bg-tech-grid opacity-25"></div>
              <div class="absolute inset-0 flex items-center justify-center opacity-15 group-hover:opacity-25 transition-opacity duration-300">
                <span class="material-symbols-outlined text-5xl text-primary-container">description</span>
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="absolute top-4 left-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/40 text-primary-container text-label-caps uppercase tracking-widest text-[10px]">{post.cat}</span>
              </div>
              <div class="absolute bottom-3 left-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span class="text-label-caps text-white uppercase tracking-[0.15em] text-[10px] flex items-center gap-1">Ler artigo <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
              </div>
            </div>
            <h3 class="text-body-lg font-medium text-on-surface-variant group-hover:text-white transition-colors duration-200 leading-snug mb-3">{post.title}</h3>
            <p class="text-sm text-tertiary leading-relaxed mb-3">{post.excerpt}</p>
            <div class="flex items-center gap-3 text-code-data text-on-surface-variant text-[12px]">
              <span class="material-symbols-outlined text-sm text-white/20">timer</span>
              <span>{post.time} leitura</span>
              <span class="w-px h-3 bg-white/15"></span>
              <span>{post.date}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>

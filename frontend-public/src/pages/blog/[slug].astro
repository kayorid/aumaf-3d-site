---
import Base from '../../layouts/Base.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import { COMPANY } from '../../lib/company'
import { blogPostingSchema } from '../../lib/schemas'

export function getStaticPaths() {
  return [
    {
      params: { slug: 'formula-sae-usp-sao-carlos' },
      props: {
        title: 'Parceria de Sucesso: AUMAF 3D e Equipe de Fórmula SAE da USP São Carlos',
        cat: 'Parceria',
        date: '2024-06-26',
        dateDisplay: '26 jun 2024',
        time: '1 min',
        author: 'Equipe AUMAF 3D',
        excerpt: 'Peças estruturais e aerodinâmicas para o carro de competição da equipe de Engenharia Mecânica da USP São Carlos — um case de parceria entre indústria e academia.',
        image: '/images/SAE-formula.avif',
        content: [
          { type: 'paragraph', text: 'A AUMAF 3D firmou parceria com a equipe de Engenharia Mecânica da USP São Carlos para fornecimento de componentes de alta performance para o carro da Fórmula SAE 2024. O desafio: fabricar peças estruturais e aerodinâmicas com tolerância mínima, peso reduzido e prazo de entrega agressivo.' },
          { type: 'heading', text: 'O Desafio Técnico' },
          { type: 'paragraph', text: 'Peças para competições automotivas estudantis precisam atender requisitos rigorosos de peso, resistência mecânica e tolerância dimensional. A equipe necessitava de suportes de suspensão, guias de cabo e elementos aerodinâmicos que fossem simultaneamente leves e resistentes — combinação que torna a impressão 3D industrial a escolha natural.' },
          { type: 'specs', items: [
            { label: 'Parceiro', value: 'USP São Carlos — Eng. Mecânica' },
            { label: 'Evento', value: 'Fórmula SAE Brasil 2024' },
            { label: 'Materiais', value: 'Nylon PA + PET-G CF15' },
            { label: 'Aplicação', value: 'Estrutural + Aerodinâmica' },
            { label: 'Tolerância', value: '±0.05mm' },
            { label: 'Prazo', value: '5 dias úteis' },
          ] },
          { type: 'heading', text: 'Solução: Nylon PA e PET-G CF15' },
          { type: 'paragraph', text: 'Para os suportes de suspensão e guias de cabo, utilizamos Nylon PA — material com alta resistência ao impacto e baixo coeficiente de atrito, ideal para componentes móveis. Para elementos aerodinâmicos, o PET-G CF15 (PETG reforçado com 15% de fibra de carbono picada) entregou a rigidez necessária com densidade significativamente inferior ao alumínio usinado.' },
          { type: 'paragraph', text: 'O processo de manufatura utilizou nossas impressoras FDM de nível industrial com câmara aquecida, garantindo cristalização adequada do Nylon PA e adesão de camadas otimizada no PET-G CF15. Cada peça passou por controle dimensional com paquímetro digital antes de ser liberada.' },
          { type: 'heading', text: 'Resultado' },
          { type: 'paragraph', text: 'As peças foram entregues dentro do prazo e aprovadas pela equipe técnica da USP São Carlos sem necessidade de retrabalho. O carro foi preparado e competiu na Fórmula SAE Brasil 2024, com os componentes AUMAF 3D contribuindo para uma montagem mais ágil e redução de peso total do veículo.' },
          { type: 'quote', text: 'A AUMAF 3D entregou dentro do prazo e com acabamento surpreendente. As peças encaixaram perfeitamente no primeiro teste de montagem.', author: 'Equipe Fórmula SAE USP São Carlos' },
        ],
      },
    },
    {
      params: { slug: 'construtora-arabe-edificio-mais-alto' },
      props: {
        title: 'Construtora árabe lança edifício impresso mais alto do mundo',
        cat: 'Inovação',
        date: '2023-10-07',
        dateDisplay: '7 out 2023',
        time: '2 min',
        author: 'Equipe AUMAF 3D',
        excerpt: 'Uma construtora dos Emirados Árabes Unidos utilizou impressão 3D de concreto para erguer o edifício impresso mais alto do mundo, com 9 andares e 17 metros de altura.',
        image: COMPANY.ogImageDefault,
        content: [
          { type: 'paragraph', text: 'A manufatura aditiva em construção civil atingiu um novo patamar quando uma construtora dos Emirados Árabes Unidos concluiu o edifício impresso em 3D mais alto do mundo: 9 andares, 17 metros de altura, construído em Dubai com tecnologia de impressão robótica de concreto.' },
          { type: 'heading', text: 'Impressão 3D em escala arquitetônica' },
          { type: 'paragraph', text: 'O projeto utilizou uma impressora robótica de pórtico capaz de depositar concreto especial em camadas precisas, seguindo modelos CAD diretamente sem necessidade de formas tradicionais. O resultado é uma redução de 60% no uso de materiais de construção e 80% na mão de obra em relação ao método convencional.' },
          { type: 'paragraph', text: 'Para a AUMAF 3D, este avanço confirma a direção que a manufatura aditiva está tomando: da prototipagem para a produção final, de peças pequenas para estruturas arquitetônicas. Os princípios são os mesmos — deposição de material camada a camada — mas a escala e as implicações para o setor de construção civil são transformadoras.' },
        ],
      },
    },
  ]
}

const { title, cat, date, dateDisplay, time, author, excerpt, content, image } = Astro.props

const url = new URL(Astro.url.pathname, Astro.site).toString()
const ogImg = image && image.startsWith('http') ? image : `${COMPANY.url}${image ?? COMPANY.ogImageDefault}`

const schemas = [
  blogPostingSchema({
    url,
    headline: title,
    description: excerpt,
    image: ogImg,
    datePublished: date,
    authorName: author,
    section: cat,
  }),
]
---

<Base
  title={title}
  description={excerpt}
  ogImage={ogImg}
  ogType="article"
  preloadImage={image}
  article={{ datePublished: date, author, section: cat }}
  breadcrumb={[{ name: 'Blog', url: '/blog' }, { name: title, url: Astro.url.pathname }]}
  schemas={schemas}
>
  <Navbar currentPath="/blog" />

  <!-- Hero do Post -->
  <section class="bg-background pt-28 pb-16 relative overflow-hidden" aria-labelledby="post-title">
    <div class="absolute inset-0 bg-tech-grid opacity-20 pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12 relative z-10">
      <Breadcrumb items={[{ name: 'Blog', url: '/blog' }, { name: cat }]} compact />

      <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/60 text-primary-container text-label-caps uppercase tracking-widest mb-6 block w-fit">{cat}</span>

      <h1 id="post-title" class="text-display-xl font-bold uppercase text-white tracking-[-0.04em] leading-none mb-6">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 text-code-data text-on-surface-variant">
        <span><span class="sr-only">Autor: </span>{author}</span>
        <span class="w-px h-3 bg-white/30" aria-hidden="true"></span>
        <time datetime={date}>{dateDisplay}</time>
        <span class="w-px h-3 bg-white/30" aria-hidden="true"></span>
        <span><span class="sr-only">Tempo de leitura: </span>{time} leitura</span>
      </div>
    </div>
  </section>

  <!-- Cover -->
  <div class="bg-background pb-16">
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12">
      <div class="relative rounded-sm overflow-hidden bg-gradient-to-br from-primary-container/10 to-surface-base border border-white/8 aspect-[16/9]">
        {image && image.endsWith('.avif') || image && image.endsWith('.webp') ? (
          <img
            src={image}
            alt={`Imagem de capa: ${title}`}
            width="1280"
            height="720"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="absolute inset-0 w-full h-full object-cover"
          />
        ) : (
          <>
            <div class="absolute inset-0 bg-tech-grid opacity-40" aria-hidden="true"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-15" aria-hidden="true">
              <svg viewBox="0 0 160 160" fill="none" class="w-48 h-48" focusable="false">
                <polygon points="80,8 148,44 148,116 80,152 12,116 12,44" stroke="#61c54f" stroke-width="1.5" fill="none"/>
                <polygon points="80,28 128,56 128,104 80,132 32,104 32,56" stroke="#61c54f" stroke-width="0.5" fill="none"/>
                <circle cx="80" cy="80" r="24" stroke="#61c54f" stroke-width="1" fill="none"/>
                <circle cx="80" cy="80" r="4" fill="#61c54f"/>
              </svg>
            </div>
          </>
        )}
        <div class="absolute bottom-4 left-4">
          <span class="pill-active">{cat}</span>
        </div>
        <div class="absolute bottom-4 right-4 text-label-caps text-primary-container/40 text-[10px] tracking-widest">AUMAF 3D · {dateDisplay}</div>
      </div>
    </div>
  </div>

  <!-- Conteúdo do Post -->
  <article class="bg-background pb-section">
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12">
      <div class="prose-aumaf">
        {content.map((block) => (
          <>
            {block.type === 'paragraph' && (
              <p class="text-body-lg text-tertiary leading-relaxed mb-6">{block.text}</p>
            )}
            {block.type === 'heading' && (
              <h2 class="text-headline-md font-bold uppercase text-white tracking-[-0.02em] mt-12 mb-5 pb-3 border-b border-white/12">{block.text}</h2>
            )}
            {block.type === 'quote' && (
              <blockquote class="glass-panel border-l-2 border-primary-container p-6 my-8 rounded-sm">
                <p class="text-body-lg text-on-surface italic leading-relaxed mb-3">"{block.text}"</p>
                <footer>
                  <cite class="text-label-caps text-primary-container uppercase tracking-[0.15em] not-italic">— {block.author}</cite>
                </footer>
              </blockquote>
            )}
            {block.type === 'specs' && (
              <figure class="glass-panel rounded-sm p-6 my-8 border border-primary-container/15 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-container/40 to-transparent" aria-hidden="true"></div>
                <figcaption class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] block mb-4">Dados do Projeto</figcaption>
                <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                  {block.items?.map((item: { label: string; value: string }) => (
                    <div class="border-b border-white/12 pb-3">
                      <dt class="text-label-caps text-on-surface-variant uppercase tracking-widest text-[10px] mb-0.5">{item.label}</dt>
                      <dd class="text-body-md text-on-surface font-medium">{item.value}</dd>
                    </div>
                  ))}
                </dl>
              </figure>
            )}
          </>
        ))}
      </div>

      <!-- Share + categoria -->
      <div class="mt-16 pt-8 border-t border-white/12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-center gap-2">
          <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em]">Categoria:</span>
          <span class="inline-flex items-center px-3 py-1 rounded-full border border-primary-container/60 text-primary-container text-label-caps uppercase tracking-widest">{cat}</span>
        </div>
        <div class="flex items-center gap-2" role="group" aria-label="Compartilhar este artigo">
          <a
            href={`https://wa.me/?text=${encodeURIComponent(title + ' — ' + url)}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Compartilhar no WhatsApp (abre em nova aba)"
            class="w-10 h-10 inline-flex items-center justify-center border border-white/30 text-on-surface rounded-sm hover:border-primary-container hover:text-primary-container transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          >
            <span class="material-symbols-outlined text-base" aria-hidden="true">chat</span>
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Compartilhar no LinkedIn (abre em nova aba)"
            class="w-10 h-10 inline-flex items-center justify-center border border-white/30 text-on-surface rounded-sm hover:border-primary-container hover:text-primary-container transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 11.001-4.124 2.062 2.062 0 01-.001 4.124zm1.782 13.019H3.555V9h3.564v11.452z"/>
            </svg>
          </a>
          <a
            href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Compartilhar no X / Twitter (abre em nova aba)"
            class="w-10 h-10 inline-flex items-center justify-center border border-white/30 text-on-surface rounded-sm hover:border-primary-container hover:text-primary-container transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <button
            type="button"
            id="copy-link"
            aria-label="Copiar link deste artigo"
            class="w-10 h-10 inline-flex items-center justify-center border border-white/30 text-on-surface rounded-sm hover:border-primary-container hover:text-primary-container transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
          >
            <span class="material-symbols-outlined text-base" aria-hidden="true">link</span>
          </button>
          <span id="copy-feedback" role="status" aria-live="polite" class="sr-only"></span>
        </div>
      </div>
    </div>
  </article>

  <!-- CTA Próximo Projeto -->
  <section class="bg-surface-low border-t border-white/8 py-16" aria-labelledby="cta-post">
    <h2 id="cta-post" class="sr-only">Iniciar projeto</h2>
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12">
      <div class="glass-panel rounded-sm p-8 flex flex-col md:flex-row items-center justify-between gap-6 border border-primary-container/15 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-container/40 to-transparent" aria-hidden="true"></div>
        <div>
          <p class="text-label-caps text-primary-container uppercase tracking-[0.2em] mb-2">Quer um resultado assim?</p>
          <p class="text-headline-md font-bold uppercase text-white">Inicie seu projeto hoje.</p>
        </div>
        <a href="/contato" class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-300 flex-shrink-0">
          Solicitar orçamento
          <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Mais Posts -->
  <section class="bg-background py-section" aria-labelledby="more-posts">
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12">
      <h2 id="more-posts" class="text-headline-md font-bold uppercase text-white tracking-[-0.02em] mb-8">Mais do Blog</h2>
      <ul role="list" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          { cat: 'Guia Técnico', title: 'FDM, SLA ou SLS? O guia definitivo', dateDisplay: 'Mai 2026', date: '2026-05-01', time: '8 min', href: '/blog/fdm-vs-sla-vs-sls' },
          { cat: 'Materiais', title: 'Guia Completo de Materiais para Impressão 3D', dateDisplay: 'Mai 2026', date: '2026-05-01', time: '6 min', href: '/blog/guia-materiais-impressao-3d' },
        ].map((post) => (
          <li>
            <article>
              <a href={post.href} class="group block focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary-container rounded-sm">
                <div class="relative aspect-[5/3] rounded-sm overflow-hidden bg-gradient-to-br from-surface-base to-surface-dim mb-3">
                  <div class="absolute inset-0 bg-tech-grid opacity-30" aria-hidden="true"></div>
                  <div class="absolute top-3 left-3">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full border border-primary-container/60 text-primary-container text-[10px] uppercase tracking-widest">{post.cat}</span>
                  </div>
                </div>
                <h3 class="text-body-md font-medium text-on-surface group-hover:text-white transition-colors leading-snug mb-2">{post.title}</h3>
                <div class="flex items-center gap-3 text-code-data text-on-surface-variant">
                  <time datetime={post.date}>{post.dateDisplay}</time>
                  <span class="w-px h-3 bg-white/30" aria-hidden="true"></span>
                  <span>{post.time} leitura</span>
                </div>
              </a>
            </article>
          </li>
        ))}
      </ul>
      <div class="mt-8 text-center">
        <a href="/blog" class="inline-flex items-center gap-2 text-label-caps text-primary-container uppercase tracking-[0.15em] hover:gap-4 transition-all duration-200 group">
          Ver todos os posts <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const copyBtn = document.getElementById('copy-link')
  const feedback = document.getElementById('copy-feedback')
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href)
      if (feedback) {
        feedback.textContent = 'Link copiado!'
        setTimeout(() => { feedback.textContent = '' }, 2000)
      }
    } catch {
      if (feedback) feedback.textContent = 'Não foi possível copiar — copie manualmente da barra de endereço.'
    }
  })
</script>

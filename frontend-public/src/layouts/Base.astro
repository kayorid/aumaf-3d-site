---
import '../styles/global.css'

export interface Props {
  title: string
  description?: string
  ogImage?: string
}
const {
  title,
  description = 'Impressão 3D industrial de alta precisão. Peças em metal, carbono e polímeros com tolerância ±0.05mm. São Carlos – SP.',
  ogImage,
} = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---
<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title} | AUMAF 3D</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | AUMAF 3D`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="AUMAF 3D" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | AUMAF 3D`} />
    <meta name="twitter:description" content={description} />

    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#000000" />

    <!-- Preload fonte local Pirulen (logo) -->
    <link rel="preload" href="/fonts/pirulen.otf" as="font" type="font/otf" crossorigin />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Material Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-on-surface antialiased overflow-x-hidden selection:bg-primary-container selection:text-on-primary pb-16">
    <slot />

    <!-- FAB: scroll to top — posicionado acima da navbar bottom (bottom-20 = 64px navbar + 16px gap) -->
    <button
      id="fab-top"
      aria-label="Voltar ao topo"
      class="fixed bottom-20 right-6 z-[60] w-11 h-11 rounded-full bg-surface-high border border-primary-container/30 text-primary-container flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 hover:bg-primary-container hover:text-on-primary hover:scale-110 active:scale-95"
      style="box-shadow:0 0 12px rgba(97,197,79,0.3);"
    >
      <span class="material-symbols-outlined text-lg" style="font-variation-settings:'FILL' 1;">arrow_upward</span>
    </button>
  </body>
</html>

<script>
  const fab = document.getElementById('fab-top')
  window.addEventListener('scroll', () => {
    if (!fab) return
    if (window.scrollY > 400) {
      fab.classList.remove('opacity-0', 'pointer-events-none')
      fab.classList.add('opacity-100')
    } else {
      fab.classList.add('opacity-0', 'pointer-events-none')
      fab.classList.remove('opacity-100')
    }
  }, { passive: true })
  fab?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))
</script>

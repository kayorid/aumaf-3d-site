---
// Listbox custom seguindo o DS Cinematic Additive Manufacturing.
// Renderiza um <select> nativo escondido (para forms e a11y) + UI custom
// controlada por JS. Suporta teclado completo (Up/Down/Home/End/Enter/Esc),
// abre/fecha por click + Esc + click fora, sincroniza com o select escondido
// para que o submit do form preserve o comportamento padrão.

export interface Option {
  value: string
  label: string
  disabled?: boolean
}

interface Props {
  id: string
  name: string
  label: string
  options: Option[]
  required?: boolean
  placeholder?: string
  /** Track no analytics ao mudar valor; usa o id como name do evento se omitido. */
  trackChange?: boolean
}

const {
  id,
  name,
  label,
  options,
  required = false,
  placeholder = 'Selecione…',
  trackChange = true,
} = Astro.props as Props
---

<div class="select-aumaf" data-select-id={id}>
  <label for={`${id}-native`} class="text-label-caps text-on-surface-variant uppercase tracking-[0.18em] block mb-2">
    {label}
  </label>

  <select
    id={`${id}-native`}
    name={name}
    required={required}
    class="sr-only"
    aria-hidden="false"
    tabindex="-1"
  >
    <option value="" disabled selected>{placeholder}</option>
    {options.map((o) => <option value={o.value} disabled={o.disabled}>{o.label}</option>)}
  </select>

  <button
    type="button"
    id={id}
    class="select-aumaf-trigger group w-full flex items-center justify-between gap-3 bg-transparent border-b border-white/15 px-0 py-2 text-on-surface focus-visible:border-primary-container focus-visible:outline-none transition-colors text-left"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls={`${id}-listbox`}
    aria-labelledby={`${id}-label-text`}
    data-track={trackChange ? `${id}_open` : undefined}
  >
    <span class="select-aumaf-value text-on-surface-variant truncate" id={`${id}-label-text`} data-placeholder={placeholder}>
      {placeholder}
    </span>
    <span class="material-symbols-outlined text-on-surface-variant text-lg shrink-0 transition-transform group-aria-expanded:rotate-180" aria-hidden="true">
      expand_more
    </span>
  </button>

  <div
    id={`${id}-panel`}
    class="select-aumaf-panel hidden absolute z-30 mt-1 w-full glass-panel border border-white/15 rounded-sm shadow-2xl max-h-[min(60vh,360px)] overflow-y-auto"
    role="presentation"
    data-anchor={id}
  >
    <ul
      id={`${id}-listbox`}
      class="py-1"
      role="listbox"
      aria-labelledby={`${id}-label-text`}
      tabindex="-1"
    >
      {options.map((o, idx) => (
        <li
          role="option"
          id={`${id}-opt-${idx}`}
          data-value={o.value}
          data-index={idx}
          aria-selected="false"
          aria-disabled={o.disabled ? 'true' : 'false'}
          class:list={[
            'select-aumaf-option cursor-pointer px-4 py-2.5 text-sm text-on-surface transition-colors',
            'hover:bg-primary-container/15 hover:text-white aria-selected:bg-primary-container/25 aria-selected:text-white',
            o.disabled && 'opacity-50 cursor-not-allowed pointer-events-none',
          ]}
        >
          {o.label}
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .select-aumaf {
    position: relative;
  }
  .select-aumaf-trigger[aria-expanded='true'] {
    border-color: rgba(97, 197, 79, 0.6);
  }
  .select-aumaf-trigger[aria-expanded='true'] .material-symbols-outlined {
    transform: rotate(180deg);
  }
  .select-aumaf-panel {
    left: 0;
    right: 0;
    top: 100%;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  type SelectController = {
    root: HTMLElement
    native: HTMLSelectElement
    trigger: HTMLButtonElement
    panel: HTMLElement
    listbox: HTMLElement
    valueLabel: HTMLElement
    options: HTMLElement[]
    placeholder: string
    activeIndex: number
  }

  function setupSelect(root: HTMLElement) {
    const id = root.dataset.selectId
    if (!id) return
    const native = root.querySelector<HTMLSelectElement>(`#${CSS.escape(id)}-native`)
    const trigger = root.querySelector<HTMLButtonElement>(`#${CSS.escape(id)}`)
    const panel = root.querySelector<HTMLElement>(`#${CSS.escape(id)}-panel`)
    const listbox = root.querySelector<HTMLElement>(`#${CSS.escape(id)}-listbox`)
    const valueLabel = root.querySelector<HTMLElement>(`#${CSS.escape(id)}-label-text`)
    if (!native || !trigger || !panel || !listbox || !valueLabel) return

    const options = Array.from(panel.querySelectorAll<HTMLElement>('[role="option"]'))
    const placeholder = valueLabel.dataset.placeholder ?? 'Selecione…'

    const ctrl: SelectController = {
      root,
      native,
      trigger,
      panel,
      listbox,
      valueLabel,
      options,
      placeholder,
      activeIndex: -1,
    }

    function open() {
      panel.classList.remove('hidden')
      trigger.setAttribute('aria-expanded', 'true')
      const selectedIdx = options.findIndex((o) => o.getAttribute('aria-selected') === 'true')
      const firstEnabled = options.findIndex((o) => o.getAttribute('aria-disabled') !== 'true')
      ctrl.activeIndex = selectedIdx >= 0 ? selectedIdx : firstEnabled
      highlight()
      window.requestAnimationFrame(() => {
        const opt = options[ctrl.activeIndex]
        opt?.scrollIntoView({ block: 'nearest' })
      })
    }
    function close(returnFocus = false) {
      panel.classList.add('hidden')
      trigger.setAttribute('aria-expanded', 'false')
      if (returnFocus) trigger.focus()
    }
    function isOpen() {
      return trigger.getAttribute('aria-expanded') === 'true'
    }
    function highlight() {
      options.forEach((o, i) => {
        o.classList.toggle('bg-primary-container/15', i === ctrl.activeIndex)
        o.classList.toggle('text-white', i === ctrl.activeIndex)
      })
    }
    function moveActive(delta: number) {
      if (options.length === 0) return
      let next = ctrl.activeIndex
      for (let step = 0; step < options.length; step++) {
        next = (next + delta + options.length) % options.length
        if (options[next].getAttribute('aria-disabled') !== 'true') break
      }
      ctrl.activeIndex = next
      highlight()
      options[next].scrollIntoView({ block: 'nearest' })
    }
    function commit(idx: number) {
      const opt = options[idx]
      if (!opt || opt.getAttribute('aria-disabled') === 'true') return
      const value = opt.dataset.value ?? ''
      const label = opt.textContent?.trim() ?? ''
      options.forEach((o) => o.setAttribute('aria-selected', 'false'))
      opt.setAttribute('aria-selected', 'true')
      valueLabel.textContent = label || placeholder
      valueLabel.classList.toggle('text-on-surface-variant', !value)
      valueLabel.classList.toggle('text-on-surface', !!value)
      native.value = value
      native.dispatchEvent(new Event('change', { bubbles: true }))
      close(true)
    }

    trigger.addEventListener('click', () => (isOpen() ? close() : open()))
    trigger.addEventListener('keydown', (e) => {
      if (['ArrowDown', 'ArrowUp', 'Enter', ' '].includes(e.key)) {
        e.preventDefault()
        if (!isOpen()) open()
        if (e.key === 'ArrowDown') moveActive(1)
        if (e.key === 'ArrowUp') moveActive(-1)
        if (e.key === 'Enter' || e.key === ' ') commit(ctrl.activeIndex)
      }
    })
    listbox.addEventListener('mouseover', (e) => {
      const target = (e.target as HTMLElement).closest<HTMLElement>('[role="option"]')
      if (!target) return
      const idx = Number(target.dataset.index ?? '-1')
      if (idx >= 0 && target.getAttribute('aria-disabled') !== 'true') {
        ctrl.activeIndex = idx
        highlight()
      }
    })
    listbox.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest<HTMLElement>('[role="option"]')
      if (!target) return
      const idx = Number(target.dataset.index ?? '-1')
      if (idx >= 0) commit(idx)
    })
    listbox.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault()
        close(true)
      } else if (e.key === 'ArrowDown') {
        e.preventDefault()
        moveActive(1)
      } else if (e.key === 'ArrowUp') {
        e.preventDefault()
        moveActive(-1)
      } else if (e.key === 'Home') {
        e.preventDefault()
        ctrl.activeIndex = options.findIndex((o) => o.getAttribute('aria-disabled') !== 'true')
        highlight()
      } else if (e.key === 'End') {
        e.preventDefault()
        for (let i = options.length - 1; i >= 0; i--) {
          if (options[i].getAttribute('aria-disabled') !== 'true') {
            ctrl.activeIndex = i
            highlight()
            break
          }
        }
      } else if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        commit(ctrl.activeIndex)
      } else if (e.key === 'Tab') {
        close()
      }
    })
    document.addEventListener('click', (e) => {
      if (!isOpen()) return
      if (!root.contains(e.target as Node)) close()
    })
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close(true)
    })
  }

  document.querySelectorAll<HTMLElement>('.select-aumaf').forEach(setupSelect)
</script>

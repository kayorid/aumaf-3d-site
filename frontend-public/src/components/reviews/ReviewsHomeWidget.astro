---
import { getReviews } from '../../lib/google-reviews'
import ReviewStars from './ReviewStars.astro'
import ReviewCard from './ReviewCard.astro'

const data = await getReviews()
const cards = data ? data.reviews.slice(0, 3) : []
---

{data && cards.length > 0 && (
  <section class="bg-background py-section section-glow-top relative overflow-hidden" aria-labelledby="home-reviews-title">
    <div class="absolute inset-0 pointer-events-none opacity-[0.04]" aria-hidden="true" style="background:radial-gradient(ellipse 60% 40% at 50% 0%, rgba(97,197,79,0.7) 0%, transparent 65%);"></div>

    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-end mb-12">
        <header class="lg:col-span-7">
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-4">Avaliações verificadas // Google</span>
          <h2 id="home-reviews-title" class="text-headline-lg md:text-display-xl font-bold uppercase text-white tracking-[-0.03em] leading-[0.95]">
            O que dizem<br/>quem já pediu.
          </h2>
        </header>

        <aside class="lg:col-span-5 flex flex-col items-start lg:items-end gap-3" aria-label="Resumo de avaliações">
          <div class="flex items-baseline gap-3">
            <span class="font-pirulen text-6xl md:text-7xl text-white leading-none" style="font-family:'Pirulen',sans-serif;">{data.rating.toFixed(1).replace('.', ',')}</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em]">/ 5</span>
          </div>
          <ReviewStars rating={data.rating} size="lg" />
          <p class="text-sm text-tertiary lg:text-right">
            Baseado em <strong class="text-on-surface font-medium">{data.totalCount} avaliações</strong> no Google Business Profile.
          </p>
        </aside>
      </div>

      <ul role="list" class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
        {cards.map((r) => (
          <li class="flex">
            <ReviewCard review={r} placeUrl={data.placeUrl} />
          </li>
        ))}
      </ul>

      <div class="mt-12 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <a
          href="/avaliacoes"
          class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-7 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container w-fit"
        >
          Ver todas as avaliações
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true" style="font-variation-settings:'FILL' 1;">arrow_forward</span>
        </a>
        <a
          href={data.writeReviewUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Avaliar a AUMAF 3D no Google (abre em nova aba)"
          class="inline-flex items-center gap-2 border border-white/20 hover:border-primary-container hover:text-primary-container text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-7 py-3 rounded-sm transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container w-fit"
        >
          Avalie no Google
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">arrow_outward</span>
        </a>
      </div>
    </div>
  </section>
)}

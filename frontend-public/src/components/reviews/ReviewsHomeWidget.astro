---
import { getReviews } from '../../lib/google-reviews'
import ReviewStars from './ReviewStars.astro'
import ReviewCard from './ReviewCard.astro'

const data = await getReviews()
const cards = data ? data.reviews.slice(0, 9) : []
const carouselId = `home-reviews-${Math.random().toString(36).slice(2, 9)}`
---

{data && cards.length > 0 && (
  <section class="bg-background py-section section-glow-top relative overflow-hidden" aria-labelledby="home-reviews-title">
    <div class="absolute inset-0 pointer-events-none opacity-[0.04]" aria-hidden="true" style="background:radial-gradient(ellipse 60% 40% at 50% 0%, rgba(97,197,79,0.7) 0%, transparent 65%);"></div>

    <div class="max-w-[1600px] mx-auto px-edge relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-end mb-12">
        <header class="lg:col-span-7">
          <span class="text-label-caps text-primary-container uppercase tracking-[0.2em] block mb-4">Avaliações verificadas // Google</span>
          <h2 id="home-reviews-title" class="text-headline-lg md:text-display-xl font-bold uppercase text-white tracking-[-0.03em] leading-[0.95]">
            O que dizem<br/>quem já pediu.
          </h2>
        </header>

        <aside class="lg:col-span-5 flex flex-col items-start lg:items-end gap-3" aria-label="Resumo de avaliações">
          <div class="flex items-baseline gap-3">
            <span class="font-pirulen text-6xl md:text-7xl text-white leading-none" style="font-family:'Pirulen',sans-serif;">{data.rating.toFixed(1).replace('.', ',')}</span>
            <span class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em]">/ 5</span>
          </div>
          <ReviewStars rating={data.rating} size="lg" />
          <p class="text-sm text-tertiary lg:text-right">
            Baseado em <strong class="text-on-surface font-medium">{data.totalCount} avaliações</strong> no Google Business Profile.
          </p>
        </aside>
      </div>

      <!-- ============== CARROSSEL ============== -->
      <div
        class="reviews-carousel relative"
        data-carousel={carouselId}
        data-autoplay="6000"
        role="region"
        aria-roledescription="carrossel"
        aria-label="Avaliações de clientes no Google"
      >
        <!-- Track scrollável com snap -->
        <ul
          role="list"
          class="reviews-track flex gap-5 md:gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2 -mx-edge px-edge"
          data-track
          tabindex="0"
          aria-live="polite"
        >
          {/* Clone do último à esquerda (peek-in vindo da esquerda) */}
          <li
            class="reviews-slide reviews-slide--clone snap-start shrink-0 basis-[85%] sm:basis-[60%] md:basis-[calc((100%-1.5rem)/2)] lg:basis-[calc((100%-3rem)/3)] flex"
            data-slide-clone="prev"
            aria-hidden="true"
          >
            <ReviewCard review={cards[cards.length - 1]} placeUrl={data.placeUrl} />
          </li>

          {cards.map((r, i) => (
            <li
              class="reviews-slide snap-start shrink-0 basis-[85%] sm:basis-[60%] md:basis-[calc((100%-1.5rem)/2)] lg:basis-[calc((100%-3rem)/3)] flex"
              data-slide-index={i}
              aria-roledescription="slide"
              aria-label={`Avaliação ${i + 1} de ${cards.length}`}
            >
              <ReviewCard review={r} placeUrl={data.placeUrl} />
            </li>
          ))}

          {/* Clone do primeiro à direita (peek-out indo para a direita) */}
          <li
            class="reviews-slide reviews-slide--clone snap-start shrink-0 basis-[85%] sm:basis-[60%] md:basis-[calc((100%-1.5rem)/2)] lg:basis-[calc((100%-3rem)/3)] flex"
            data-slide-clone="next"
            aria-hidden="true"
          >
            <ReviewCard review={cards[0]} placeUrl={data.placeUrl} />
          </li>
        </ul>

        <!-- Setas (desktop) -->
        <button
          type="button"
          class="reviews-arrow reviews-arrow--prev hidden md:flex absolute top-1/2 -translate-y-1/2 -left-3 lg:-left-5 z-10 w-11 h-11 items-center justify-center rounded-full bg-surface-base/85 border border-white/12 backdrop-blur-sm text-on-surface hover:text-primary-container hover:border-primary-container/50 transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container disabled:opacity-30 disabled:cursor-not-allowed"
          data-prev
          aria-label="Avaliação anterior"
        >
          <span class="material-symbols-outlined text-xl leading-none" aria-hidden="true">chevron_left</span>
        </button>
        <button
          type="button"
          class="reviews-arrow reviews-arrow--next hidden md:flex absolute top-1/2 -translate-y-1/2 -right-3 lg:-right-5 z-10 w-11 h-11 items-center justify-center rounded-full bg-surface-base/85 border border-white/12 backdrop-blur-sm text-on-surface hover:text-primary-container hover:border-primary-container/50 transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container disabled:opacity-30 disabled:cursor-not-allowed"
          data-next
          aria-label="Próxima avaliação"
        >
          <span class="material-symbols-outlined text-xl leading-none" aria-hidden="true">chevron_right</span>
        </button>

        <!-- Dots indicador -->
        <div class="reviews-dots flex items-center justify-center gap-2 mt-8" role="tablist" aria-label="Selecionar avaliação">
          {cards.map((_, i) => (
            <button
              type="button"
              role="tab"
              class="reviews-dot w-2 h-2 rounded-full bg-white/15 hover:bg-primary-container/60 transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container data-[active=true]:bg-primary-container data-[active=true]:w-6"
              data-dot={i}
              aria-label={`Ir para avaliação ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      </div>

      <div class="mt-12 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <a
          href="/avaliacoes"
          class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-7 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container w-fit"
        >
          Ver todas as avaliações
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true" style="font-variation-settings:'FILL' 1;">arrow_forward</span>
        </a>
        <a
          href={data.writeReviewUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Avaliar a AUMAF 3D no Google (abre em nova aba)"
          class="inline-flex items-center gap-2 border border-white/20 hover:border-primary-container hover:text-primary-container text-on-surface text-label-caps font-bold uppercase tracking-[0.15em] px-7 py-3 rounded-sm transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container w-fit"
        >
          Avalie no Google
          <span class="material-symbols-outlined text-base leading-none" aria-hidden="true">arrow_outward</span>
        </a>
      </div>
    </div>

    <style>
      .reviews-track {
        scrollbar-width: none;
      }
      .reviews-track::-webkit-scrollbar { display: none; }
      .reviews-arrow { will-change: transform; }
    </style>

    <script>
      type CarouselEl = HTMLElement & { __initialized?: boolean }

      function initCarousel(root: CarouselEl) {
        if (root.__initialized) return
        root.__initialized = true

        const track = root.querySelector<HTMLUListElement>('[data-track]')
        const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev]')
        const nextBtn = root.querySelector<HTMLButtonElement>('[data-next]')
        const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-dot]'))
        if (!track) return
        const trackEl: HTMLUListElement = track

        // Layout: [clone-prev] [real 0..N-1] [clone-next]
        // - slides físicos: cards.length + 2
        // - reais: índices 1..cards.length (mapeia para dot 0..N-1)
        const allSlides = Array.from(track.querySelectorAll<HTMLLIElement>('.reviews-slide'))
        const realCount = dots.length
        if (allSlides.length === 0 || realCount === 0) return
        // Sanity: precisamos de exatamente realCount + 2 slides (1 clone em cada ponta)
        const FIRST_REAL = 1
        const LAST_REAL = realCount // índice físico do último real
        const CLONE_PREV = 0
        const CLONE_NEXT = realCount + 1

        const autoplayMs = Number(root.dataset.autoplay) || 0
        let autoplayTimer: ReturnType<typeof setInterval> | null = null
        let isHovering = false
        let isFocusInside = false
        let scrollEndTimer: ReturnType<typeof setTimeout> | null = null
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        // Posicionamento sem disparar scroll handler (evita flicker de update)
        function setScrollLeft(left: number) {
          trackEl.scrollTo({ left, behavior: 'auto' })
        }

        function getPhysicalIndex() {
          const trackLeft = trackEl.scrollLeft
          let bestIdx = FIRST_REAL
          let bestDist = Infinity
          allSlides.forEach((s, i) => {
            const d = Math.abs(s.offsetLeft - trackLeft)
            if (d < bestDist) { bestDist = d; bestIdx = i }
          })
          return bestIdx
        }

        function getRealIndex() {
          const phys = getPhysicalIndex()
          if (phys === CLONE_PREV) return realCount - 1
          if (phys === CLONE_NEXT) return 0
          return phys - 1
        }

        function update() {
          const idx = getRealIndex()
          dots.forEach((d, i) => {
            const active = i === idx
            d.dataset.active = active ? 'true' : 'false'
            d.setAttribute('aria-selected', active ? 'true' : 'false')
          })
        }

        function scrollToPhysical(physIdx: number, behavior: ScrollBehavior = 'smooth') {
          const target = allSlides[Math.max(0, Math.min(allSlides.length - 1, physIdx))]
          if (!target) return
          trackEl.scrollTo({ left: target.offsetLeft, behavior })
        }

        function goToReal(realIdx: number, behavior: ScrollBehavior = 'smooth') {
          const r = ((realIdx % realCount) + realCount) % realCount
          scrollToPhysical(r + 1, behavior)
        }

        function next() {
          const phys = getPhysicalIndex()
          // Próximo slide físico — pode entrar no clone[next] sem problema; o teleport
          // silencioso acontece após scrollEnd
          scrollToPhysical(phys + 1)
        }

        function prev() {
          const phys = getPhysicalIndex()
          scrollToPhysical(phys - 1)
        }

        // Após scroll terminar, se estamos num clone, teleporta silenciosamente para o real equivalente
        function handleScrollSettled() {
          const phys = getPhysicalIndex()
          if (phys === CLONE_NEXT) {
            // Acabamos de chegar no clone do primeiro — teleporta para o real primeiro
            setScrollLeft(allSlides[FIRST_REAL].offsetLeft)
          } else if (phys === CLONE_PREV) {
            // Voltamos no clone do último — teleporta para o real último
            setScrollLeft(allSlides[LAST_REAL].offsetLeft)
          }
        }

        function startAutoplay() {
          if (!autoplayMs || prefersReducedMotion) return
          stopAutoplay()
          autoplayTimer = setInterval(() => {
            if (isHovering || isFocusInside || document.hidden) return
            next()
          }, autoplayMs)
        }

        function stopAutoplay() {
          if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null }
        }

        prevBtn?.addEventListener('click', () => { prev() })
        nextBtn?.addEventListener('click', () => { next() })
        dots.forEach((d, i) => d.addEventListener('click', () => goToReal(i)))

        let scrollRaf: number | null = null
        trackEl.addEventListener('scroll', () => {
          if (scrollRaf) cancelAnimationFrame(scrollRaf)
          scrollRaf = requestAnimationFrame(update)
          // Detecta scrollEnd via debounce 140ms (suficiente após smooth scroll terminar)
          if (scrollEndTimer) clearTimeout(scrollEndTimer)
          scrollEndTimer = setTimeout(handleScrollSettled, 140)
        }, { passive: true })

        trackEl.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') { e.preventDefault(); prev() }
          else if (e.key === 'ArrowRight') { e.preventDefault(); next() }
          else if (e.key === 'Home') { e.preventDefault(); goToReal(0) }
          else if (e.key === 'End') { e.preventDefault(); goToReal(realCount - 1) }
        })

        root.addEventListener('mouseenter', () => { isHovering = true })
        root.addEventListener('mouseleave', () => { isHovering = false })
        root.addEventListener('focusin', () => { isFocusInside = true })
        root.addEventListener('focusout', () => { isFocusInside = false })

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) stopAutoplay()
          else startAutoplay()
        })

        // Posição inicial: primeiro slide REAL (não no clone esquerdo)
        // Aguarda o layout assentar antes de medir offsetLeft
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            setScrollLeft(allSlides[FIRST_REAL].offsetLeft)
            update()
          })
        })

        startAutoplay()
      }

      function initAll() {
        document.querySelectorAll<CarouselEl>('[data-carousel]').forEach(initCarousel)
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAll, { once: true })
      } else {
        initAll()
      }
    </script>
  </section>
)}

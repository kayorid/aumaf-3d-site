---
import { COMPANY } from '../lib/company'
import ReviewsFooterWidget from './reviews/ReviewsFooterWidget.astro'

const year = new Date().getFullYear()

const links = [
  { href: '/servicos', label: 'Serviços' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/materiais', label: 'Materiais' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/avaliacoes', label: 'Avaliações' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
  { href: '/faq', label: 'Perguntas Frequentes' },
  { href: '/guias', label: 'Guias' },
  { href: '/glossario', label: 'Glossário' },
  { href: '/industrias', label: 'Indústrias atendidas' },
]

const socials = [
  {
    href: COMPANY.socials.instagram,
    label: 'Instagram da AUMAF 3D',
    icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z',
  },
  {
    href: COMPANY.socials.linkedin,
    label: 'LinkedIn da AUMAF 3D',
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    href: COMPANY.socials.facebook,
    label: 'Facebook da AUMAF 3D',
    icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
]
---

<footer class="bg-background border-t border-white/8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Rodapé do site</h2>

  <!-- Main footer -->
  <div class="max-w-[1600px] mx-auto px-edge py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-1 mb-6 group focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary-container rounded-sm" aria-label="AUMAF 3D — Página Inicial">
          <span
            class="text-[18px] text-on-surface tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:text-white select-none"
            style="font-family:'Pirulen',sans-serif;"
          >AUMAF</span>
          <span
            class="text-[18px] text-primary-container tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:opacity-80 select-none ml-1"
            style="font-family:'Pirulen',sans-serif;"
          >3D</span>
        </a>
        <p class="text-sm text-tertiary leading-relaxed max-w-xs">
          Manufatura aditiva industrial de alta precisão.<br/>
          {COMPANY.address.addressLocality} – {COMPANY.address.addressRegion}.
        </p>
        <ul role="list" class="flex items-center gap-4 mt-6">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                data-track="social_link"
                data-track-network={s.label}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${s.label} (abre em nova aba)`}
                class="w-9 h-9 border border-white/20 rounded-sm flex items-center justify-center hover:border-primary-container hover:text-primary-container text-tertiary transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                  <path d={s.icon} />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <nav aria-label="Navegação do rodapé">
        <p class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] mb-6">Navegação</p>
        <ul role="list" class="space-y-3">
          {links.map((link) => (
            <li>
              <a href={link.href} data-track="footer_link" data-track-target={link.label} class="text-sm text-tertiary hover:text-white transition-colors duration-200 focus-visible:text-primary-container">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <p class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] mb-6">Contato</p>
        <address class="not-italic space-y-3 text-sm text-tertiary">
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">Endereço</span>
            {COMPANY.address.streetAddress}<br/>
            {COMPANY.address.neighborhood}<br/>
            {COMPANY.address.addressLocality} – {COMPANY.address.addressRegion}
          </div>
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">WhatsApp</span>
            <a
              href={COMPANY.contact.whatsapp}
              data-track="cta_whatsapp_footer"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Falar pelo WhatsApp: ${COMPANY.contact.phoneDisplay} (abre em nova aba)`}
              class="hover:text-primary-container transition-colors focus-visible:text-primary-container"
            >
              {COMPANY.contact.phoneDisplay}
            </a>
          </div>
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">Email</span>
            <a href={`mailto:${COMPANY.contact.email}`} class="hover:text-primary-container transition-colors focus-visible:text-primary-container">
              {COMPANY.contact.email}
            </a>
          </div>
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">Horário</span>
            {COMPANY.hours.displayPt}
          </div>
        </address>
      </div>
    </div>
  </div>

  <!-- Reviews widget -->
  <ReviewsFooterWidget />

  <!-- Legal bar — LGPD links -->
  <div class="border-t border-white/8">
    <div class="max-w-[1600px] mx-auto px-edge py-5">
      <nav aria-label="Documentos legais e privacidade">
        <ul role="list" class="flex flex-wrap items-center justify-center md:justify-start gap-x-6 gap-y-2 text-xs text-on-surface-variant">
          <li>
            <a
              href="/politica-de-privacidade"
              data-track="footer_legal"
              data-track-target="politica-privacidade"
              class="hover:text-primary-container transition-colors focus-visible:text-primary-container"
            >Política de Privacidade</a>
          </li>
          <li>
            <a
              href="/termos-de-uso"
              data-track="footer_legal"
              data-track-target="termos-uso"
              class="hover:text-primary-container transition-colors focus-visible:text-primary-container"
            >Termos de Uso</a>
          </li>
          <li>
            <a
              href="/politica-de-cookies"
              data-track="footer_legal"
              data-track-target="politica-cookies"
              class="hover:text-primary-container transition-colors focus-visible:text-primary-container"
            >Política de Cookies</a>
          </li>
          <li>
            <a
              href="/preferencias-de-cookies"
              data-track="footer_legal"
              data-track-target="preferencias-cookies"
              class="hover:text-primary-container transition-colors focus-visible:text-primary-container"
            >Preferências de Cookies</a>
          </li>
          <li>
            <a
              href="/lgpd/direitos"
              data-track="footer_legal"
              data-track-target="direitos-lgpd"
              class="hover:text-primary-container transition-colors focus-visible:text-primary-container"
            >Seus Direitos LGPD</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8">
    <div class="max-w-[1600px] mx-auto px-edge py-5 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="text-xs text-on-surface-variant">
        © {year} <span class="font-medium text-tertiary">{COMPANY.legalName}</span> · CNPJ {COMPANY.taxId}. Todos os direitos reservados.
      </p>
      <a
        href="https://kayoridolfi.ai"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="kayoridolfi.ai — site do desenvolvedor (abre em nova aba)"
        class="text-xs text-on-surface-variant hover:text-tertiary transition-colors focus-visible:text-primary-container"
      >
        Desenvolvido por kayoridolfi.ai
      </a>
    </div>
  </div>
</footer>

---
import { COMPANY } from '../lib/company'
import { templateConfig } from '@template/shared'
import ReviewsFooterWidget from './reviews/ReviewsFooterWidget.astro'

const year = new Date().getFullYear()

// Achata navegação do footer (config.navigation.footer é uma lista de seções)
// para uma única lista linear, mantendo o comportamento legado.
const links = templateConfig.navigation.footer.flatMap((section) => section.items)

const SOCIAL_ICONS = {
  instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z',
  linkedin: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  facebook: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  twitter: 'M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z',
  github: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
} as const

type SocialKey = keyof typeof SOCIAL_ICONS
const socials = (Object.keys(SOCIAL_ICONS) as SocialKey[]).flatMap((key) => {
  const href = templateConfig.socials[key]
  if (!href) return []
  return [{
    href,
    label: `${key.charAt(0).toUpperCase()}${key.slice(1)} de ${templateConfig.name}`,
    icon: SOCIAL_ICONS[key],
  }]
})

// Lockup
const nameParts = templateConfig.name.trim().split(/\s+/)
const lockupHead = nameParts.slice(0, nameParts.length === 1 ? 1 : -1).join(' ')
const lockupTail = nameParts.length > 1 ? nameParts[nameParts.length - 1] : ''
---

<footer class="bg-background border-t border-white/8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Rodapé do site</h2>

  <!-- Main footer -->
  <div class="max-w-[1600px] mx-auto px-edge py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-1 mb-6 group focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary-container rounded-sm" aria-label={`${templateConfig.name} — Página Inicial`}>
          <span
            class="text-[18px] text-on-surface tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:text-white select-none"
            style="font-family:'Pirulen',sans-serif;"
          >{lockupHead}</span>
          {lockupTail && (
            <span
              class="text-[18px] text-primary-container tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:opacity-80 select-none ml-1"
              style="font-family:'Pirulen',sans-serif;"
            >{lockupTail}</span>
          )}
        </a>
        <p class="text-sm text-tertiary leading-relaxed max-w-xs">
          {templateConfig.shortPitch}<br/>
          {COMPANY.address.addressLocality} – {COMPANY.address.addressRegion}.
        </p>
        <ul role="list" class="flex items-center gap-4 mt-6">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${s.label} (abre em nova aba)`}
                class="w-9 h-9 border border-white/20 rounded-sm flex items-center justify-center hover:border-primary-container hover:text-primary-container text-tertiary transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                  <path d={s.icon} />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <nav aria-label="Navegação do rodapé">
        <p class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] mb-6">Navegação</p>
        <ul role="list" class="space-y-3">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-tertiary hover:text-white transition-colors duration-200 focus-visible:text-primary-container">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <p class="text-label-caps text-on-surface-variant uppercase tracking-[0.2em] mb-6">Contato</p>
        <address class="not-italic space-y-3 text-sm text-tertiary">
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">Endereço</span>
            {COMPANY.address.streetAddress}<br/>
            {COMPANY.address.neighborhood}<br/>
            {COMPANY.address.addressLocality} – {COMPANY.address.addressRegion}
          </div>
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">WhatsApp</span>
            <a
              href={COMPANY.contact.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Falar pelo WhatsApp: ${COMPANY.contact.phoneDisplay} (abre em nova aba)`}
              class="hover:text-primary-container transition-colors focus-visible:text-primary-container"
            >
              {COMPANY.contact.phoneDisplay}
            </a>
          </div>
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">Email</span>
            <a href={`mailto:${COMPANY.contact.email}`} class="hover:text-primary-container transition-colors focus-visible:text-primary-container">
              {COMPANY.contact.email}
            </a>
          </div>
          <div>
            <span class="text-on-surface-variant text-label-caps uppercase block mb-1">Horário</span>
            {COMPANY.hours.displayPt}
          </div>
        </address>
      </div>
    </div>
  </div>

  <!-- Reviews widget -->
  <ReviewsFooterWidget />

  <!-- Bottom bar -->
  <div class="border-t border-white/8">
    <div class="max-w-[1600px] mx-auto px-edge py-5 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="text-xs text-on-surface-variant">
        © {year} {COMPANY.name}. Todos os direitos reservados.
      </p>
      <a
        href="https://kayoridolfi.ai"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="kayoridolfi.ai — site do desenvolvedor (abre em nova aba)"
        class="text-xs text-on-surface-variant hover:text-tertiary transition-colors focus-visible:text-primary-container"
      >
        Desenvolvido por kayoridolfi.ai
      </a>
    </div>
  </div>
</footer>

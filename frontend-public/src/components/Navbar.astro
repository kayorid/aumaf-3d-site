---
export interface Props {
  currentPath?: string
}
const { currentPath = '/' } = Astro.props

const links = [
  { href: '/servicos', label: 'Serviços' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/materiais', label: 'Materiais' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/blog', label: 'Blog' },
]
---

<header
  id="navbar"
  class="fixed top-0 w-full z-50 nav-glass transition-all duration-500"
>
  <nav class="flex justify-between items-center px-edge h-20 max-w-[1440px] mx-auto">
    <!-- Logo AUMAF 3D — Pirulen typeface -->
    <a href="/" class="flex items-center gap-1 group" aria-label="AUMAF 3D — Página Inicial">
      <span
        class="font-pirulen text-[20px] text-white tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:opacity-75 select-none"
        style="font-family:'Pirulen',sans-serif;"
      >AUMAF</span>
      <span
        class="font-pirulen text-[20px] text-primary-container tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:opacity-75 select-none ml-1"
        style="font-family:'Pirulen',sans-serif;"
      >3D</span>
    </a>

    <!-- Desktop Links (lg+) -->
    <ul class="hidden lg:flex items-center gap-6">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-label-caps font-bold uppercase tracking-[0.15em] transition-colors duration-200 pb-0.5',
              currentPath === link.href
                ? 'text-primary-container border-b border-primary-container'
                : 'text-white/50 hover:text-white'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-3">
      <a
        href="/contato"
        class="hidden lg:inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-200"
      >
        Solicitar Orçamento
        <span class="material-symbols-outlined text-base leading-none" style="font-variation-settings:'FILL' 1;">arrow_outward</span>
      </a>

      <!-- Mobile/tablet hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden w-10 h-10 border border-white/20 rounded-sm flex flex-col justify-center items-center gap-1.5 hover:border-primary-container transition-colors"
        aria-label="Abrir menu"
        aria-expanded="false"
      >
        <span class="w-5 h-px bg-white transition-all duration-300" id="bar1"></span>
        <span class="w-5 h-px bg-white transition-all duration-300" id="bar2"></span>
        <span class="w-3 h-px bg-primary-container transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile/Tablet Drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 glass-panel-strong flex-col justify-center items-start px-8 hidden"
  aria-hidden="true"
>
  <div class="mt-20 space-y-1 w-full">
    {links.map((link, i) => (
      <a
        href={link.href}
        class="block py-5 text-headline-md font-bold uppercase tracking-[-0.02em] text-white/70 hover:text-white border-b border-white/5 transition-colors"
        style={`animation-delay: ${i * 80}ms`}
      >
        <span class="text-primary-container text-label-caps mr-4 font-bold">0{i + 1}</span>
        {link.label}
      </a>
    ))}
    <div class="pt-8">
      <a
        href="/contato"
        class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect"
      >
        Solicitar Orçamento
        <span class="material-symbols-outlined text-base leading-none" style="font-variation-settings:'FILL' 1;">arrow_outward</span>
      </a>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  const bar1 = document.getElementById('bar1')
  const bar2 = document.getElementById('bar2')
  const bar3 = document.getElementById('bar3')
  let open = false

  toggle?.addEventListener('click', () => {
    open = !open
    menu?.classList.toggle('hidden', !open)
    menu?.classList.toggle('flex', open)
    menu?.setAttribute('aria-hidden', String(!open))
    toggle.setAttribute('aria-expanded', String(open))
    document.body.style.overflow = open ? 'hidden' : ''
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = open ? 'translateY(5px) rotate(45deg)' : ''
      bar2.style.opacity = open ? '0' : '1'
      bar3.style.transform = open ? 'translateY(-5px) rotate(-45deg)' : ''
      bar3.style.width = open ? '20px' : ''
    }
  })

  // Fechar ao clicar em link do drawer
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      open = false
      menu.classList.add('hidden')
      menu.classList.remove('flex')
      menu.setAttribute('aria-hidden', 'true')
      toggle?.setAttribute('aria-expanded', 'false')
      document.body.style.overflow = ''
      if (bar1 && bar2 && bar3) {
        bar1.style.transform = ''
        bar2.style.opacity = '1'
        bar3.style.transform = ''
        bar3.style.width = ''
      }
    })
  })

  // Hide/show on scroll
  const navbar = document.getElementById('navbar')
  let lastScroll = 0
  window.addEventListener('scroll', () => {
    const current = window.scrollY
    if (current > 100 && current > lastScroll && !open) {
      navbar?.classList.add('-translate-y-full')
    } else {
      navbar?.classList.remove('-translate-y-full')
    }
    lastScroll = current
  }, { passive: true })
</script>

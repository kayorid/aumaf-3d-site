---
export interface Props {
  currentPath?: string
}
const { currentPath = '/' } = Astro.props

const links = [
  { href: '/servicos', label: 'Serviços' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/materiais', label: 'Materiais' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/blog', label: 'Blog' },
]
---

<header
  id="navbar"
  class="fixed top-0 w-full z-50 nav-glass transition-all duration-500"
>
  <nav class="flex justify-between items-center px-edge h-20 max-w-[1440px] mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-7 h-7 border border-primary-container/60 rounded-sm flex items-center justify-center group-hover:border-primary-container group-hover:glow-effect transition-all duration-300">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7 0L14 4V10L7 14L0 10V4L7 0Z" fill="rgba(97,197,79,0.8)"/>
          <path d="M7 3L11 5.5V9.5L7 12L3 9.5V5.5L7 3Z" fill="rgba(0,0,0,0.6)"/>
        </svg>
      </div>
      <span class="text-[18px] font-bold tracking-[-0.02em] text-white uppercase">
        AUMAF <span class="text-primary-container">3D</span>
      </span>
    </a>

    <!-- Desktop Links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-label-caps font-bold uppercase tracking-[0.15em] transition-colors duration-200 pb-0.5',
              currentPath === link.href
                ? 'text-primary-container border-b border-primary-container'
                : 'text-white/50 hover:text-white'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="flex items-center gap-4">
      <a
        href="/contato"
        class="hidden md:inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-3 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-200"
      >
        Solicitar Orçamento
        <span class="material-symbols-outlined text-base leading-none" style="font-variation-settings:'FILL' 1;">arrow_outward</span>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="md:hidden w-10 h-10 border border-white/20 rounded-sm flex flex-col justify-center items-center gap-1.5 hover:border-primary-container transition-colors"
        aria-label="Menu"
      >
        <span class="w-5 h-px bg-white transition-all duration-300" id="bar1"></span>
        <span class="w-5 h-px bg-white transition-all duration-300" id="bar2"></span>
        <span class="w-3 h-px bg-primary-container transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 glass-panel-strong flex-col justify-center items-start px-8 hidden"
>
  <div class="mt-20 space-y-1 w-full">
    {links.map((link, i) => (
      <a
        href={link.href}
        class="block py-5 text-headline-md font-bold uppercase tracking-[-0.02em] text-white/70 hover:text-white border-b border-white/5 transition-colors"
        style={`animation-delay: ${i * 80}ms`}
      >
        <span class="text-primary-container text-label-caps mr-4 font-bold">0{i + 1}</span>
        {link.label}
      </a>
    ))}
    <a
      href="/contato"
      class="mt-8 inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect"
    >
      Solicitar Orçamento
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  const bar1 = document.getElementById('bar1')
  const bar2 = document.getElementById('bar2')
  const bar3 = document.getElementById('bar3')
  let open = false

  toggle?.addEventListener('click', () => {
    open = !open
    menu?.classList.toggle('hidden', !open)
    menu?.classList.toggle('flex', open)
    document.body.style.overflow = open ? 'hidden' : ''
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = open ? 'translateY(5px) rotate(45deg)' : ''
      bar2.style.opacity = open ? '0' : '1'
      bar3.style.transform = open ? 'translateY(-5px) rotate(-45deg)' : ''
      bar3.style.width = open ? '20px' : ''
    }
  })

  // Scroll behavior
  const navbar = document.getElementById('navbar')
  let lastScroll = 0
  window.addEventListener('scroll', () => {
    const current = window.scrollY
    if (current > 80 && current > lastScroll) {
      navbar?.classList.add('-translate-y-full')
    } else {
      navbar?.classList.remove('-translate-y-full')
    }
    lastScroll = current
  }, { passive: true })
</script>

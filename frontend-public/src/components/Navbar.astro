---
import { templateConfig } from '@template/shared'
export interface Props {
  currentPath?: string
}
const { currentPath = '/' } = Astro.props

// Navegação primária lida do templateConfig.
// Excluímos a "/" home (lockup já leva à home) e o /faq (slot dedicado).
const links = templateConfig.navigation.primary.filter(
  (l) => l.href !== '/' && l.href !== '/faq'
)
const helpLink = templateConfig.navigation.primary.find((l) => l.href === '/faq')
  ?? { href: '/faq', label: 'Perguntas Frequentes' }

// Lockup do nome — particiona "AUMAF 3D" -> "AUMAF" + "3D" etc.
const nameParts = templateConfig.name.trim().split(/\s+/)
const lockupHead = nameParts.slice(0, nameParts.length === 1 ? 1 : -1).join(' ')
const lockupTail = nameParts.length > 1 ? nameParts[nameParts.length - 1] : ''
---

<header
  id="navbar"
  class="fixed top-0 w-full z-50 nav-glass border-b border-white/8"
>
  <nav aria-label="Principal" class="flex justify-between items-center px-edge h-16 max-w-[1600px] mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-1 group focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary-container rounded-sm" aria-label={`${templateConfig.name} — Página Inicial`}>
      <span
        class="font-pirulen text-[18px] text-white tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:opacity-75 select-none"
        style="font-family:'Pirulen',sans-serif;"
      >{lockupHead}</span>
      {lockupTail && (
        <span
          class="font-pirulen text-[18px] text-primary-container tracking-[0.06em] leading-none transition-opacity duration-300 group-hover:opacity-75 select-none ml-1"
          style="font-family:'Pirulen',sans-serif;"
        >{lockupTail}</span>
      )}
    </a>

    <!-- Desktop Links (lg+) -->
    <ul class="hidden lg:flex items-center gap-6" role="list">
      {links.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
        return (
          <li>
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'text-[13px] font-light uppercase tracking-[0.2em] transition-all duration-200 pb-0.5',
                isActive
                  ? 'text-primary-container border-b border-primary-container'
                  : 'text-on-surface-variant hover:text-white',
              ]}
            >
              {link.label}
            </a>
          </li>
        )
      })}
    </ul>

    <!-- CTA + Help icon + Hamburger -->
    <div class="flex items-center gap-3">
      <a
        href={helpLink.href}
        aria-label={helpLink.label}
        title={helpLink.label}
        class:list={[
          'hidden lg:inline-flex items-center justify-center w-9 h-9 rounded-sm border transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container mr-1',
          currentPath === helpLink.href
            ? 'border-primary-container/60 text-primary-container'
            : 'border-white/15 text-on-surface-variant hover:border-primary-container/40 hover:text-primary-container',
        ]}
      >
        <span class="material-symbols-outlined text-[18px] leading-none" aria-hidden="true" style="font-variation-settings:'wght' 500;">help_outline</span>
      </a>
      <a
        href="/contato"
        class="hidden lg:inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-6 py-2.5 rounded-sm glow-effect hover:bg-primary-dim transition-all duration-200"
      >
        Solicitar Orçamento
        <span class="material-symbols-outlined text-base leading-none" aria-hidden="true" style="font-variation-settings:'FILL' 1;">arrow_outward</span>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        type="button"
        class="lg:hidden w-10 h-10 border border-white/30 rounded-sm flex flex-col justify-center items-center gap-1.5 hover:border-primary-container transition-colors"
        aria-label="Abrir menu de navegação"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="w-5 h-px bg-white transition-all duration-300" id="bar1" aria-hidden="true"></span>
        <span class="w-5 h-px bg-white transition-all duration-300" id="bar2" aria-hidden="true"></span>
        <span class="w-3 h-px bg-primary-container transition-all duration-300" id="bar3" aria-hidden="true"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile/Tablet Drawer — full screen overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 glass-panel-strong flex-col px-8 hidden overflow-y-auto overscroll-contain"
  aria-hidden="true"
  aria-label="Menu de navegação móvel"
  role="dialog"
  aria-modal="true"
>
  <!-- Botão X dedicado no topo do drawer -->
  <div class="flex justify-end pt-4 pb-2">
    <button
      id="menu-close"
      type="button"
      class="w-11 h-11 inline-flex items-center justify-center rounded-full border border-white/15 bg-surface-low/60 text-on-surface active:text-primary-container active:border-primary-container/40 transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-container"
      aria-label="Fechar menu de navegação"
    ><span class="material-symbols-outlined text-xl leading-none" aria-hidden="true">close</span></button>
  </div>
  <ul role="list" class="mt-2 space-y-1 w-full">
    {[...links, helpLink].map((link, i) => {
      const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
      return (
        <li>
          <a
            href={link.href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'flex items-center min-h-14 py-4 text-headline-md font-bold uppercase tracking-[-0.02em] border-b border-white/8 transition-colors focus-visible:text-primary-container',
              isActive ? 'text-primary-container' : 'text-on-surface hover:text-white',
            ]}
            style={`animation-delay: ${i * 60}ms`}
          >
            <span class="text-primary-container text-label-caps mr-4 font-bold" aria-hidden="true">0{i + 1}</span>
            {link.label}
          </a>
        </li>
      )
    })}
  </ul>
  <div class="pt-8 pb-[max(env(safe-area-inset-bottom),2rem)]">
    <a
      href="/contato"
      class="inline-flex items-center gap-2 bg-primary-container text-on-primary text-label-caps font-bold uppercase tracking-[0.15em] px-8 py-4 rounded-sm glow-effect"
    >
      Solicitar Orçamento
      <span class="material-symbols-outlined text-base leading-none" aria-hidden="true" style="font-variation-settings:'FILL' 1;">arrow_outward</span>
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null
  const menu = document.getElementById('mobile-menu')
  const bar1 = document.getElementById('bar1')
  const bar2 = document.getElementById('bar2')
  const bar3 = document.getElementById('bar3')
  let open = false
  let lastFocus: HTMLElement | null = null

  function setMenu(state: boolean) {
    open = state
    if (!menu || !toggle) return
    menu.classList.toggle('hidden', !open)
    menu.classList.toggle('flex', open)
    menu.setAttribute('aria-hidden', String(!open))
    toggle.setAttribute('aria-expanded', String(open))
    toggle.setAttribute('aria-label', open ? 'Fechar menu de navegação' : 'Abrir menu de navegação')
    document.body.style.overflow = open ? 'hidden' : ''
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = open ? 'translateY(5px) rotate(45deg)' : ''
      bar2.style.opacity = open ? '0' : '1'
      bar3.style.transform = open ? 'translateY(-5px) rotate(-45deg)' : ''
      bar3.style.width = open ? '20px' : ''
    }
    if (open) {
      lastFocus = document.activeElement as HTMLElement
      const firstLink = menu.querySelector<HTMLAnchorElement>('a')
      firstLink?.focus()
    } else {
      lastFocus?.focus()
    }
  }

  toggle?.addEventListener('click', () => setMenu(!open))

  const closeBtn = document.getElementById('menu-close')
  closeBtn?.addEventListener('click', () => setMenu(false))

  // Swipe-to-close no drawer (gesto vertical para cima > 80px fecha)
  if (menu) {
    let sx = 0, sy = 0
    menu.addEventListener('touchstart', (e) => {
      const t = e.changedTouches[0]
      sx = t.clientX; sy = t.clientY
    }, { passive: true })
    menu.addEventListener('touchend', (e) => {
      if (!open) return
      const t = e.changedTouches[0]
      const dx = t.clientX - sx
      const dy = t.clientY - sy
      // Swipe horizontal para a direita (>80px) ou vertical para cima (>80px) fecha
      if ((Math.abs(dx) > 80 && dx > Math.abs(dy)) || (dy < -80 && Math.abs(dy) > Math.abs(dx))) {
        setMenu(false)
      }
    }, { passive: true })
  }

  // Fechar com Esc
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) {
      e.preventDefault()
      setMenu(false)
    }
  })

  // Focus trap simples — Tab no último volta pro primeiro
  menu?.addEventListener('keydown', (e) => {
    if (!open || e.key !== 'Tab') return
    const focusables = Array.from(
      menu.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])'),
    )
    if (focusables.length === 0) return
    const first = focusables[0]
    const last = focusables[focusables.length - 1]
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault()
      last.focus()
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault()
      first.focus()
    }
  })

  // Fechar ao clicar em link
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setMenu(false))
  })
</script>

{
  "permissions": {
    "allow": [
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run test*)",
      "Bash(npm run dev:backend)",
      "Bash(npm run dev:public)",
      "Bash(npm run dev:admin)",
      "Bash(npm run dev:db)",
      "Bash(npx prisma*)",
      "Bash(docker compose*)",
      "Bash(docker-compose*)",
      "Bash(python3 docs/specs/scripts/*)",
      "Bash(bash docs/specs/scripts/*)",
      "Bash(bash scripts/analytics-*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(cat*)",
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(sed*)",
      "Bash(curl*)",
      "Bash(chmod*)",
      "Bash(npx tsx*)",
      "Bash(npx astro*)",
      "Bash(gh pr*)",
      "Bash(gh run*)",
      "Bash(gh api*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git restore*)",
      "Bash(git remote*)",
      "Bash(python3*)",
      "Bash(jq*)",
      "Bash(comm*)",
      "Bash(sort*)",
      "Bash(tail*)",
      "Bash(head*)",
      "Bash(wc*)",
      "Bash(du*)",
      "Bash(printf*)",
      "Bash(echo*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(npx prisma migrate reset*)",
      "Bash(docker system prune*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c 'import sys,json,subprocess,os; d=json.load(sys.stdin); fp=d.get(\"tool_input\",{}).get(\"file_path\",\"\"); root=os.environ.get(\"CLAUDE_PROJECT_DIR\",\".\"); fp and subprocess.run([\"bash\", f\"{root}/scripts/analytics-tagging-check.sh\", fp], check=False)'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/analytics-audit.sh\" 2>&1 | tail -20"
          }
        ]
      }
    ]
  }
}
